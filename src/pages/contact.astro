---
import BaseLayout from '@layouts/BaseLayout.astro';
import Topbar from '@components/layout/Topbar.astro';
import Nav from '@components/layout/Nav.astro';
import Footer from '@components/layout/Footer.astro';
import EyebrowPill from '@components/ui/EyebrowPill.astro';
import CalvinNote from '@components/sections/CalvinNote.astro';
import LogosTicker from '@components/sections/LogosTicker.astro';
import { contact, review, calendly } from '@data/site-config';

/* WhatsApp deep-link volgens wa.me-pattern. Tekst wordt URL-encoded. */
const waUrl = `https://wa.me/${contact.whatsappNumber}?text=${encodeURIComponent(contact.whatsappMessage)}`;
---

<BaseLayout
  title="Contact — Froseo"
  description="Stuur je wensen door of plan een kennismaking. We reageren meestal binnen één werkdag."
>
  <Topbar />
  <Nav />
  <main>
    <article class="contact-page">
      <!-- ============================================================
           Hero
           ============================================================ -->
      <section class="contact-hero">
        <div class="contact-hero-inner">
          <EyebrowPill variant="rare">Contact</EyebrowPill>
          <h1 class="contact-hero-title">
            Waar kunnen wij <em>mee helpen?</em>
          </h1>
          <p class="contact-hero-lead">
            Heb je een vraag over je website, SEO of online marketing? Of wil je bespreken wat slim is voor jouw bedrijf? Stuur ons een bericht of plan direct een kennismaking. Altijd geheel vrijblijvend.
          </p>
          <div class="contact-hero-reviews reviews-inline">
            <div class="review-avatars">
              <div class="review-avatar"></div>
              <div class="review-avatar"></div>
              <div class="review-avatar"></div>
            </div>
            <div class="stars">★★★★★</div>
            <span><strong>{review.ratingDisplay}</strong> · Google reviews</span>
          </div>
        </div>
      </section>

      <!-- ============================================================
           2-kolom hoofdblok: form (links) + directe info (rechts)
           ============================================================ -->
      <section class="contact-main">
        <div class="contact-main-inner">
          <!-- Form -->
          <div class="contact-form-wrap">
            <div class="contact-form-head">
              <h2 class="contact-form-title">Stuur een bericht</h2>
              <p class="contact-form-sub">
                Vul de basics in. We reageren persoonlijk, niet met een autoresponder.
              </p>
            </div>
            <form class="contact-form" method="POST" action="/api/contact" data-contact-form novalidate>
              <div class="form-row">
                <label class="form-field">
                  <span class="form-label">Naam <em>*</em></span>
                  <input type="text" name="name" required autocomplete="name" />
                </label>
                <label class="form-field">
                  <span class="form-label">E-mail <em>*</em></span>
                  <input type="email" name="email" required autocomplete="email" />
                </label>
              </div>
              <div class="form-row">
                <label class="form-field">
                  <span class="form-label">Telefoon</span>
                  <input type="tel" name="phone" autocomplete="tel" />
                </label>
                <label class="form-field">
                  <span class="form-label">Huidige website</span>
                  <input type="url" name="current_website" placeholder="https://" />
                </label>
              </div>
              <label class="form-field">
                <span class="form-label">Bericht <em>*</em></span>
                <textarea name="message" rows="6" required minlength="10" placeholder="Vertel kort wat je zoekt of wat er beter kan."></textarea>
              </label>

              <!-- Honeypot — verborgen voor mensen, bots vullen 't vaak in -->
              <div class="form-honeypot" aria-hidden="true">
                <label>Website (laat dit veld leeg)
                  <input type="text" name="website_url" tabindex="-1" autocomplete="off" />
                </label>
              </div>
              <input type="hidden" name="form_started_at" value="" data-form-started-at />

              <div class="form-foot">
                <button type="submit" class="btn-primary form-submit">Verstuur bericht ↗</button>
                <span class="form-status" data-form-status role="status" aria-live="polite"></span>
              </div>
              <p class="form-note">
                Door dit formulier te versturen ga je akkoord met onze <a href="/privacy">privacy­verklaring</a>.
              </p>
            </form>
          </div>

          <div class="contact-aside">
            <!-- Afspraak-planner als accordion (klik om agenda te openen) -->
            <details class="contact-planner">
              <summary class="contact-planner-summary">
                <span class="contact-planner-icon" aria-hidden="true">📅</span>
                <span class="contact-planner-text">
                  <strong>Plan hier jouw afspraak</strong>
                  <span>Vrijblijvende kennismaking, 30 minuten</span>
                </span>
                <span class="contact-planner-chev" aria-hidden="true">+</span>
              </summary>
              <div class="contact-planner-body">
                {calendly.url ? (
                  <>
                    <div class="calendly-inline-widget" data-url={calendly.url} style="min-width:280px;height:640px;"></div>
                    <script async src="https://assets.calendly.com/assets/external/widget.js"></script>
                  </>
                ) : (
                  <div class="contact-planner-placeholder">
                    <p>Online planner staat binnenkort live. Plan voor nu via WhatsApp of mail, dan zoeken we samen een tijd die past.</p>
                    <div class="contact-planner-placeholder-actions">
                      <a class="btn-primary" href={waUrl} target="_blank" rel="noopener noreferrer">Plan via WhatsApp ↗</a>
                      <a class="btn-ghost" href={`mailto:${contact.email}?subject=${encodeURIComponent('Afspraak inplannen')}`}>Of via mail ↗</a>
                    </div>
                  </div>
                )}
              </div>
            </details>

            <!-- Directe contact-info -->
            <aside class="contact-info">
              <h2 class="contact-info-title">Liever direct contact</h2>

              <a class="contact-info-row" href={`mailto:${contact.email}`}>
                <span class="contact-info-icon" aria-hidden="true">✉</span>
                <span class="contact-info-body">
                  <span class="contact-info-label">Mail ons</span>
                  <span class="contact-info-value">{contact.email}</span>
                </span>
              </a>

              <a class="contact-info-row contact-info-row--whatsapp" href={waUrl} target="_blank" rel="noopener noreferrer">
                <span class="contact-info-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M19.05 4.91A9.82 9.82 0 0012.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 004.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.91-7.01zm-7.01 15.24a8.23 8.23 0 01-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.21 8.21 0 01-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 012.42 5.83c0 4.55-3.7 8.23-8.25 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.17.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.39.11-.51.11-.11.25-.29.38-.43.12-.14.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.57.12.17 1.74 2.66 4.22 3.74.59.25 1.05.4 1.41.51.59.19 1.13.16 1.55.1.47-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29z"/></svg>
                </span>
                <span class="contact-info-body">
                  <span class="contact-info-label">WhatsApp ons</span>
                  <span class="contact-info-value">Direct chatten</span>
                </span>
              </a>

              <a class="contact-info-row" href={`tel:${contact.phoneTel}`}>
                <span class="contact-info-icon" aria-hidden="true">☎</span>
                <span class="contact-info-body">
                  <span class="contact-info-label">Bel ons</span>
                  <span class="contact-info-value">{contact.phoneDisplay}</span>
                </span>
              </a>

              <div class="contact-info-meta">
                <div>
                  <span class="meta-key">Reactietijd</span>
                  <span class="meta-val">{contact.responseTime}</span>
                </div>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <!-- Logo carousel — tussen contact-blok en bezoekadres voor visuele break -->
      <LogosTicker />

      <!-- ============================================================
           Bezoekadres — info-only (Calendly accordion zit in sidebar)
           ============================================================ -->
      <section class="contact-map">
        <div class="contact-map-inner">
          <div class="contact-map-text">
            <EyebrowPill>Bezoekadres</EyebrowPill>
            <h2 class="contact-map-title">
              Onze basis in <em>Utrecht.</em>
            </h2>
            <p class="contact-map-body">
              Even kennismaken? Dan spreken we graag met je af, dit kan in Utrecht of bij jou op kantoor.
            </p>
            <p class="contact-map-note">
              * Wegens verbouwing zitten wij tijdelijk op een andere locatie.
            </p>
            <dl class="contact-map-meta">
              <div><dt>Adres</dt><dd>{contact.address.street}<br />{contact.address.postalCode} {contact.address.city}</dd></div>
              <div><dt>KvK</dt><dd>{contact.kvk}</dd></div>
            </dl>
          </div>
          <div class="contact-map-embed">
            <iframe
              src={contact.mapEmbed}
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`Kaart van ${contact.address.city}`}
            />
          </div>
        </div>
      </section>

      <CalvinNote />
    </article>
  </main>
  <Footer />

  <script>
    /* Form submit met fetch — toont inline status zonder page reload.
       Honeypot + min-time worden in functions/api/contact.ts gecheckt. */
    const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
    const status = document.querySelector<HTMLElement>('[data-form-status]');
    const startedAt = document.querySelector<HTMLInputElement>('[data-form-started-at]');

    /* Set form-render-tijd voor anti-bot check. */
    if (startedAt) startedAt.value = String(Date.now());

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form || !status) return;

      const submitBtn = form.querySelector<HTMLButtonElement>('.form-submit');
      submitBtn?.setAttribute('disabled', 'true');
      status.textContent = 'Versturen…';
      status.className = 'form-status is-loading';

      try {
        const data = new FormData(form);
        const res = await fetch('/api/contact', { method: 'POST', body: data });
        const json = await res.json().catch(() => ({}));

        if (res.ok && json.ok) {
          status.textContent = 'Bericht verzonden. We nemen snel contact op.';
          status.className = 'form-status is-success';
          form.reset();
          /* Reset honeypot timer voor eventuele 2e submission. */
          if (startedAt) startedAt.value = String(Date.now());
        } else {
          status.textContent = json.error ?? 'Versturen mislukt. Probeer het later opnieuw of bel ons.';
          status.className = 'form-status is-error';
        }
      } catch {
        status.textContent = 'Versturen mislukt. Probeer het later opnieuw of bel ons.';
        status.className = 'form-status is-error';
      } finally {
        submitBtn?.removeAttribute('disabled');
      }
    });
  </script>
</BaseLayout>
