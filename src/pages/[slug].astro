---
import BaseLayout from '@layouts/BaseLayout.astro';
import Topbar from '@components/layout/Topbar.astro';
import Nav from '@components/layout/Nav.astro';
import Footer from '@components/layout/Footer.astro';
import EyebrowPill from '@components/ui/EyebrowPill.astro';
import SectionIcon from '@components/ui/SectionIcon.astro';
import ReviewAvatars from '@components/ui/ReviewAvatars.astro';
import BetterCallCalvin from '@components/sections/BetterCallCalvin.astro';
import LogosTicker from '@components/sections/LogosTicker.astro';
import WebsitesShowcase from '@components/sections/WebsitesShowcase.astro';
import CalvinNote from '@components/sections/CalvinNote.astro';
import FAQ from '@components/sections/FAQ.astro';
import PricingPackages from '@components/sections/PricingPackages.astro';
import ContentPackages from '@components/sections/ContentPackages.astro';
import AboPackages from '@components/sections/AboPackages.astro';
import FrameworkBlock from '@components/sections/FrameworkBlock.astro';
import PackagePaths from '@components/sections/PackagePaths.astro';
import PainPoints from '@components/sections/PainPoints.astro';
import Comparison from '@components/sections/Comparison.astro';
import StatsRibbon from '@components/sections/StatsRibbon.astro';
import CTABand from '@components/sections/CTABand.astro';
import OnboardingTimeline from '@components/sections/OnboardingTimeline.astro';
import Testimonial from '@components/sections/Testimonial.astro';
import MaintenanceCheck from '@components/sections/MaintenanceCheck.astro';
import MaintenanceCheckCta from '@components/sections/MaintenanceCheckCta.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import { interpolate, review } from '@data/site-config';
import { aboPackages } from '@data/abo-packages';
import { maintenancePackages } from '@data/maintenance-packages';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services
    .filter((entry) => !entry.data.external)
    .map((entry) => ({
      params: { slug: entry.data.slug },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const s = entry.data;

/* Detecteer of de markdown-body content bevat. Bij lege body slaan we
   de service-body sectie over om geen lege padding-band te tonen. */
const hasBodyContent = (entry.body ?? '').trim().length > 0;

/* Cases die deze service gebruiken — auto-gefilterd voor de "Cases" sectie. */
const allCases = await getCollection('cases', ({ data }) => data.published !== false);
const relatedCases = allCases
  .filter((c) => (c.data.services ?? []).includes(s.slug))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);

/* Voor de visuele WebsitesShowcase tonen we ALLE cases (visueel-eerst proof,
   niet beperkt tot de specifieke dienst). Slice op 6 voor een nette 3x2 grid. */
const showcaseCases = allCases
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);

/* Featured-case-config opbouwen als de service een featuredCaseSlug heeft. */
const featuredCaseEntry = s.showcaseFeatured
  ? allCases.find((c) => c.data.slug === s.showcaseFeatured!.caseSlug)
  : undefined;
const showcaseFeatured = featuredCaseEntry
  ? { caseEntry: featuredCaseEntry, headline: s.showcaseFeatured?.headline }
  : undefined;

const heroLead = s.heroLead ?? s.description;
const pageTitle = s.metaTitle ?? `${s.shortTitle ?? s.title} | Froseo`;
const pageDesc = interpolate(s.metaDescription ?? s.description);

/* JSON-LD Service-schema (+ Offers uit het getoonde pakketset). FAQPage zit
   al in de FAQ-component, LocalBusiness/Organization in BaseLayout. */
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://froseo.nl').toString();
const offerPackages: any[] = s.showAboPackages
  ? aboPackages
  : s.showMaintenancePackages
    ? maintenancePackages
    : [];
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: s.shortTitle ?? s.title,
  serviceType: s.shortTitle ?? s.title,
  description: pageDesc,
  url: canonical,
  provider: { '@type': 'Organization', name: 'Froseo', url: 'https://froseo.nl/' },
  areaServed: { '@type': 'Country', name: 'Nederland' },
  ...(offerPackages.length > 0
    ? {
        offers: offerPackages.map((p) => ({
          '@type': 'Offer',
          name: p.name,
          price: String(p.yearlyMonthlyPrice ?? Math.round((p.yearlyPrice ?? p.monthlyPrice * 12) / 12)),
          priceCurrency: 'EUR',
          url: `${canonical}#pakketten`,
        })),
      }
    : {}),
};
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <Topbar />
  <Nav />
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <Breadcrumbs crumbs={[
      { name: 'Home', href: '/' },
      { name: s.shortTitle ?? s.title, href: `/${s.slug}/` },
    ]} />
    <article class={`service-page ${s.pageClass ?? ''}`}>
      <!-- ============================================================
           Hero
           ============================================================ -->
      <section class={`service-hero ${s.heroImage ? 'has-image' : ''}`}>
        <div class="service-hero-inner">
          <div class="service-hero-text">
            <EyebrowPill>{interpolate(s.heroEyebrow ?? '15+ jaar ervaring · 80+ MKB-projecten')}</EyebrowPill>
            <h1 class={`service-hero-title${s.heroAccentBlock ? ' accent-block' : ''}`}>
              {s.heroTitle ?? s.title}
              {s.heroAccent && <em>{s.heroAccent}</em>}
            </h1>
            {s.heroChecks && s.heroChecks.length > 0 ? (
              <ul class="service-hero-checks">
                {s.heroChecks.map((c) => <li>{interpolate(c)}</li>)}
              </ul>
            ) : (
              <p class="service-hero-lead">{interpolate(heroLead)}</p>
            )}
            <div class="service-hero-actions">
              <a class="btn-primary" href={s.heroPrimaryCta?.href ?? '/contact/'}>
                {s.heroPrimaryCta?.label ?? 'Plan een kennismaking ↗'}
              </a>
              {s.heroSecondaryCta && (
                <a class="btn-ghost" href={s.heroSecondaryCta.href}>
                  {s.heroSecondaryCta.label}
                </a>
              )}
            </div>
            <div class="service-hero-reviews reviews-inline">
              <ReviewAvatars />
              <div class="stars">★★★★★</div>
              <span><strong>{review.ratingDisplay}</strong> · Google reviews</span>
            </div>
          </div>

          {s.heroImage && (
            <div class="service-hero-media">
              <Image
                src={s.heroImage}
                alt={s.heroAlt ?? `${s.shortTitle ?? s.title} — Froseo`}
                title={s.heroAlt ?? `${s.shortTitle ?? s.title} — Froseo`}
                class="service-hero-img"
                widths={[640, 960, 1280, 1600]}
                sizes="(max-width: 1024px) 100vw, 640px"
                loading="eager"
                fetchpriority="high"
              />
            </div>
          )}
        </div>
      </section>

      <!-- Logo carousel — proof / brand recognition direct na hero -->
      <LogosTicker />

      {/* Donker introblok direct na de logo's (keyword-rijke intro hoog op de pagina). */}
      {s.introBlock && (
        <section class="service-infra">
          <div class="service-infra-inner">
            {s.introBlock.eyebrow && (
              <EyebrowPill variant="highlight">{s.introBlock.eyebrow}</EyebrowPill>
            )}
            <h2 class="service-infra-title">
              {s.introBlock.title}
              {s.introBlock.titleAccent && <em>{s.introBlock.titleAccent}</em>}
            </h2>
            {s.introBlock.body.map((p) => (
              <p class="service-infra-body">{interpolate(p)}</p>
            ))}
          </div>
        </section>
      )}

      <!-- ============================================================
           Onderhouds-pakketten (3 cards + custom-strip + maand/jaar toggle).
           Renderd alleen wanneer service.showMaintenancePackages = true.
           ============================================================ -->
      {s.showMaintenancePackages && (
        <PricingPackages
          eyebrow={s.pricingEyebrow}
          title={s.pricingTitle}
          titleAccent={s.pricingTitleAccent}
          lead={s.pricingLead}
          showCustom={!s.showMaintenanceCheck}
        />
      )}

      {/* Onderhoud-pagina's: CTA-kaart i.p.v. de "Andere wensen?"-custom-strip,
          zacht doorsturen naar de gratis-check (#check) onderaan. */}
      {s.showMaintenanceCheck && <MaintenanceCheckCta />}

      {s.showContentPackages && (
        <ContentPackages
          eyebrow={s.pricingEyebrow}
          title={s.pricingTitle}
          titleAccent={s.pricingTitleAccent}
          lead={s.pricingLead}
        />
      )}

      {s.showAboPackages && (
        <AboPackages
          eyebrow={s.pricingEyebrow}
          title={s.pricingTitle}
          titleAccent={s.pricingTitleAccent}
          lead={s.pricingLead}
        />
      )}

      {/* Framework-uitleg + WordPress-vs-Astro before/after-slider.
          Alleen op /website-abonnement zinvol; vervangt de oude
          aboTerms-strip die te zwak was als USP. */}
      {s.slug === 'website-abonnement' && <FrameworkBlock />}

      {/* "Wat zit er inbegrepen?" — open, complementair aan de pakketkaarten
          (themed groepen i.p.v. feature-checklist). Direct na de cards zodat
          het de keuze ondersteunt op het beslismoment. */}
      {s.includedBlock && (
        <section class="included">
          <div class="included-head">
            {s.includedBlock.eyebrow && <EyebrowPill>{s.includedBlock.eyebrow}</EyebrowPill>}
            <h2 class="included-title">
              {s.includedBlock.title} {s.includedBlock.titleAccent && <em>{s.includedBlock.titleAccent}</em>}
            </h2>
            {s.includedBlock.intro && <p class="included-intro">{interpolate(s.includedBlock.intro)}</p>}
          </div>
          <div class="included-grid">
            {s.includedBlock.groups.map((g) => (
              <article class="included-card">
                {g.icon && (
                  <span class="included-card-icon" aria-hidden="true">
                    <SectionIcon name={g.icon} size={26} />
                  </span>
                )}
                <h3 class="included-card-title">{g.title}</h3>
                <p class="included-card-body">{interpolate(g.body)}</p>
              </article>
            ))}
          </div>
          {s.includedBlock.note && <p class="included-note" set:html={interpolate(s.includedBlock.note)} />}
        </section>
      )}

      <!-- ============================================================
           Stats-ribbon — 4 credibility-cijfers. Rustig proof-strookje
           tussen pakketten en pain-points.
           ============================================================ -->
      {s.statsRibbon && s.statsRibbon.length > 0 && (
        <StatsRibbon items={s.statsRibbon} />
      )}

      <!-- ============================================================
           Optionele testimonial-quote — proof-blok tussen StatsRibbon
           en PainPoints. Pakt een testimonial-id uit frontmatter.
           ============================================================ -->
      {s.testimonialId && (
        <Testimonial id={s.testimonialId} variant="card" />
      )}

      <!-- ============================================================
           Propositie-paden — bv. Maatwerk vs. Abonnement.
           Voor onderhoud-pagina's gebruiken we PricingPackages hierboven
           in plaats van propositionPaths.
           ============================================================ -->
      {!s.showMaintenancePackages && !s.showContentPackages && !s.showAboPackages && s.propositionPaths && s.propositionPaths.length > 0 && s.proposalsLayout === 'package' && (
        <PackagePaths
          eyebrow={s.proposalsEyebrow ?? 'Drie opties'}
          title={s.proposalsTitle ? interpolate(s.proposalsTitle) : 'Kies wat past bij <em>jouw situatie.</em>'}
          lead={s.proposalsLead ? interpolate(s.proposalsLead) : undefined}
          packages={s.propositionPaths.map((p) => ({
            name: p.title,
            tagline: p.tagline,
            priceFrom: p.priceFrom,
            priceAmount: p.priceAmount ?? '',
            pricePeriod: p.pricePeriod,
            priceBilling: p.priceBilling,
            body: interpolate(p.body),
            checks: (p.checks ?? []).map((c) => interpolate(c)),
            cta: p.cta ?? { label: 'Plan kennismaking ↗', href: '/contact/' },
            featured: p.isFeatured,
            badge: p.badge,
          }))}
        />
      )}

      {!s.showMaintenancePackages && !s.showContentPackages && !s.showAboPackages && s.propositionPaths && s.propositionPaths.length > 0 && s.proposalsLayout !== 'package' && (
        <section class="service-paths">
          <div class="service-paths-head">
            <EyebrowPill>{s.proposalsEyebrow ?? 'Kies je route'}</EyebrowPill>
            <h2 class="service-paths-title">
              {s.proposalsTitle
                ? <Fragment set:html={interpolate(s.proposalsTitle)} />
                : s.propositionPaths.length === 2
                  ? <>Maatwerk of <em>abonnement.</em></>
                  : `${s.propositionPaths.length} pakketten op een rij.`}
            </h2>
            <p class="service-paths-lead">
              {s.proposalsLead ?? 'Volledig maatwerk waarin we vanaf de basis bouwen, of een doordachte basis voor één vast bedrag per maand. Beide leveren een professionele site die bij je merk past. Het verschil zit in tempo, prijs en hoeveel je zelf bepaalt.'}
            </p>
          </div>
          <div class={`service-paths-grid count-${s.propositionPaths.length}`}>
            {s.propositionPaths.map((p) => (
              <article class={`service-path-card ${p.isFeatured ? 'is-featured' : ''}`}>
                {p.badge && <span class="service-path-badge">{interpolate(p.badge)}</span>}
                {p.tag && <span class="service-path-tag">{interpolate(p.tag)}</span>}
                <h3 class="service-path-title">{p.title}</h3>
                <p class="service-path-body">{interpolate(p.body)}</p>
                {p.checks && p.checks.length > 0 && (
                  <ul class="service-path-checks">
                    {p.checks.map((c) => (
                      <li>
                        <span class="check-icon" aria-hidden="true">✓</span>
                        <span>{interpolate(c)}</span>
                      </li>
                    ))}
                  </ul>
                )}
                {p.note && <p class="service-path-note">{interpolate(p.note)}</p>}
                {p.cta && (
                  <a class="btn-primary service-path-cta" href={p.cta.href}>
                    {p.cta.label}
                  </a>
                )}
              </article>
            ))}
          </div>
        </section>
      )}

      <!-- ============================================================
           Visuele showcase — websites die we bouwden (statisch grid)
           ============================================================ -->
      {!s.hideShowcase && showcaseCases.length > 0 && (
        <WebsitesShowcase
          cases={showcaseCases}
          eyebrow={s.showcaseEyebrow}
          title={s.showcaseTitle}
          titleAccent={s.showcaseTitleAccent}
        />
      )}

      <!-- Positief infrastructuur-blok — donker centered tekstblok als
           alternatief voor painPoints. Voor pagina's waar we positief framen. -->
      {s.infraBlock && (
        <section class="service-infra">
          <div class="service-infra-inner">
            {s.infraBlock.eyebrow && (
              <EyebrowPill variant="highlight">{s.infraBlock.eyebrow}</EyebrowPill>
            )}
            <h2 class="service-infra-title">
              {s.infraBlock.title}
              {s.infraBlock.titleAccent && <em>{s.infraBlock.titleAccent}</em>}
            </h2>
            {s.infraBlock.body.map((p) => (
              <p class="service-infra-body">{interpolate(p)}</p>
            ))}
            {s.infraBlock.cta && (
              <p class="service-infra-cta-row">
                {s.infraBlock.cta.prefix && (
                  <span class="service-infra-cta-prefix">{s.infraBlock.cta.prefix}</span>
                )}
                <a class="service-infra-cta" href={s.infraBlock.cta.href}>
                  {s.infraBlock.cta.label}
                </a>
              </p>
            )}
          </div>
        </section>
      )}

      {/* "Voor wie is dit geschikt?" — donker links/rechts-blok (OverFroseo-stijl):
          kop + begeleidende alinea links, checks rechts. */}
      {s.audienceFit && (
        <section class="audience-fit">
          <div class="audience-fit-inner">
            <div class="audience-fit-head">
              {s.audienceFit.eyebrow && (
                <EyebrowPill variant="highlight" star="◆">{s.audienceFit.eyebrow}</EyebrowPill>
              )}
              <h2 class="audience-fit-title">
                {s.audienceFit.title} {s.audienceFit.titleAccent && <em>{s.audienceFit.titleAccent}</em>}
              </h2>
            </div>
            <div class="audience-fit-body">
              <div class="audience-fit-lead">
                {s.audienceFit.lead.map((p) => (
                  <p set:html={interpolate(p)} />
                ))}
              </div>
              <ul class="audience-fit-checks">
                {s.audienceFit.items.map((it) => (
                  <li>
                    <span class="audience-check-icon" aria-hidden="true">✓</span>
                    <span class="audience-check-text">{it}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </section>
      )}

      <!-- Pain-points grid (negatieve framing, visuele urgency) -->
      {s.painPoints && s.painPoints.length > 0 && (
        <PainPoints
          title={s.painPointsTitle}
          titleAccent={s.painPointsTitleAccent}
          lead={s.painPointsLead}
          items={s.painPoints}
        />
      )}

      <!-- Met-vs-zonder comparison-blok (CRO-trigger) -->
      {s.comparison && (
        <Comparison
          title={interpolate(s.comparison.title)}
          titleAccent={interpolate(s.comparison.titleAccent)}
          withoutLabel={s.comparison.withoutLabel}
          withLabel={s.comparison.withLabel}
          items={s.comparison.items.map((it) => ({ without: interpolate(it.without), with: interpolate(it.with) }))}
          footnote={s.comparison.footnote ? interpolate(s.comparison.footnote) : undefined}
        />
      )}

      <!-- ============================================================
           Mid-page actie-moment tussen Comparison en Body. Twee opties:
           - calvinNote (foto + quote + CTA) wanneer service-specifieke
             prompt nodig is, bv. "niet zeker welk pakket past?"
           - ctaBand (eyebrow + titel + body + 2 buttons) als algemener
             tussen-CTA.
           Als calvinNote gezet is heeft die voorrang en wordt de
           default-positie na de Pillars overgeslagen.
           ============================================================ -->
      {s.calvinNote ? (
        <CalvinNote
          message={s.calvinNote.message}
          ctaLabel={s.calvinNote.ctaLabel}
          ctaHref={s.calvinNote.ctaHref}
        />
      ) : s.ctaBand ? (
        <CTABand
          eyebrow={s.ctaBand.eyebrow}
          title={s.ctaBand.title}
          body={s.ctaBand.body}
          primaryLabel={s.ctaBand.primaryLabel}
          primaryHref={s.ctaBand.primaryHref}
          secondaryLabel={s.ctaBand.secondaryLabel}
          secondaryHref={s.ctaBand.secondaryHref}
        />
      ) : null}

      <!-- ============================================================
           Body / "Wat we doen" — markdown content. Skip de hele sectie
           wanneer de body leeg is (sommige service-pagina's hebben geen
           markdown body en gebruiken alleen frontmatter-blokken).
           ============================================================ -->
      {hasBodyContent && (
        <section class="service-body">
          <div class="service-body-inner">
            <Content />
          </div>
        </section>
      )}

      <!-- ============================================================
           Onboarding-tijdslijn — alternatieve render van approachSteps.
           Verschijnt hier in de pagina-flow (i.p.v. onderaan als cards)
           wanneer approachStyle='timeline'. De cards-render lager in de
           pagina wordt dan overgeslagen.
           ============================================================ -->
      {s.approachStyle === 'timeline' && s.approachSteps && s.approachSteps.length > 0 && (
        <OnboardingTimeline
          items={s.approachSteps}
          eyebrow={s.approachEyebrow}
          title={s.approachTitle}
          titleAccent={s.approachTitleAccent}
        />
      )}

      <!-- ============================================================
           Spotlights — 2-koloms tekst+image cross-sell secties
           Image-positie wisselt per index voor visueel ritme.
           ============================================================ -->
      {s.spotlights && s.spotlights.length > 0 && (
        <section class="service-spotlights">
          {s.spotlights.map((sp, i) => (
            <div class={`service-spotlight ${i % 2 === 1 ? 'is-reversed' : ''}`}>
              <div class="service-spotlight-text">
                {sp.eyebrow && <EyebrowPill variant="rare">{sp.eyebrow}</EyebrowPill>}
                <h2 class="service-spotlight-title">{sp.title}</h2>
                <p class="service-spotlight-body">{interpolate(sp.body)}</p>
                {sp.link && (
                  <a class="btn-primary service-spotlight-cta" href={sp.link.href}>
                    {sp.link.label} ↗
                  </a>
                )}
              </div>
              <div class="service-spotlight-media">
                <Image
                  src={sp.image}
                  alt={sp.title}
                  class="service-spotlight-img"
                  widths={[400, 600, 800, 1000]}
                  sizes="(max-width: 1024px) 100vw, 540px"
                  loading="lazy"
                />
              </div>
            </div>
          ))}
        </section>
      )}

      <!-- ============================================================
           Pijlers — accordion-deep-dive (technisch / content / etc.)
           Houdt de pagina scannable maar levert lengte voor SEO-body.
           ============================================================ -->
      {s.pillars && s.pillars.length > 0 && (
        <section class="service-pillars">
          <div class="service-pillars-head">
            <EyebrowPill>{s.pillarsEyebrow ?? 'Onder de motorkap'}</EyebrowPill>
            <h2 class="service-pillars-title">
              {s.pillarsTitle
                ? <Fragment set:html={s.pillarsTitle} />
                : <>Wat dit <em>inhoudt.</em></>}
            </h2>
          </div>
          <div class="service-pillars-list">
            {s.pillars.map((p, i) => (
              <details class="service-pillar-item" open={i === 0}>
                <summary>
                  <span class="pillar-num">{String(i + 1).padStart(2, '0')}</span>
                  <span class="pillar-title">{p.title}</span>
                  <span class="pillar-ico" aria-hidden="true">+</span>
                </summary>
                <div class="pillar-body">
                  <p>{interpolate(p.body)}</p>
                  {p.link && <a class="pillar-link" href={p.link.href}>{p.link.label} ↗</a>}
                </div>
              </details>
            ))}
          </div>
        </section>
      )}

      <!-- Inline persoonlijke note — default-positie na de Pillars.
           Wanneer een service een eigen `calvinNote` in frontmatter heeft,
           is die hierboven al gerenderd op de mid-page slot; dan slaan
           we hier over om dubbel-rendering te voorkomen. -->
      {!s.calvinNote && <CalvinNote />}

      <!-- ============================================================
           Aanpak (4 stappen) — full-bleed donker blok
           ============================================================ -->
      {s.approachStyle !== 'timeline' && s.approachSteps && s.approachSteps.length > 0 && (
        <section class="service-approach">
          <div class="service-approach-inner">
            <div class="service-approach-head">
              <EyebrowPill>Aanpak</EyebrowPill>
              <h2 class="service-approach-title">
                Hoe we dit <em>aanpakken.</em>
              </h2>
            </div>
            <ol class="service-approach-steps">
              {s.approachSteps.map((step, i) => (
                <li class="service-approach-step">
                  <div class="step-num">{String(i + 1).padStart(2, '0')}</div>
                  <div class="step-content">
                    <h3 class="step-title">{step.title}</h3>
                    <p class="step-body">{interpolate(step.body)}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>
        </section>
      )}

      <!-- ============================================================
           Waarom Froseo — USPs grid
           ============================================================ -->
      {s.usps && s.usps.length > 0 && (
        <section class="service-usps">
          <div class="service-usps-head">
            <EyebrowPill variant="rare">Waarom Froseo</EyebrowPill>
            <h2 class="service-usps-title">
              Wat ons <em>onderscheidt.</em>
            </h2>
          </div>
          <div class="service-usps-grid">
            {s.usps.map((u, i) => (
              <article class={`service-usp-card usp-${i % 4}`}>
                <h3 class="usp-title">{u.title}</h3>
                <p class="usp-body">{interpolate(u.body)}</p>
              </article>
            ))}
          </div>
        </section>
      )}

      <!-- ============================================================
           Cases met deze dienst — auto-gefilterd
           ============================================================ -->
      <!-- (Cases-detail block verwijderd uit service-template: WebsitesShowcase
           hierboven is de single projecten-block. "Alle projecten ↗" CTA zit
           daar al in. Voorkomt duplicate projecten-content op één pagina.) -->

      {s.showMaintenanceCheck ? (
        <MaintenanceCheck formLocation={`${s.slug}-page`} />
      ) : s.closeCta ? (
        <BetterCallCalvin
          eyebrow={s.closeCta.eyebrow ?? 'Een gesprek inplannen?'}
          titleLine1={s.closeCta.titleLine1}
          titleAccent={s.closeCta.titleAccent}
          body={s.closeCta.body}
          primaryLabel={s.closeCta.primaryLabel ?? 'Plan een kennismaking ↗'}
          primaryHref={s.closeCta.primaryHref ?? '/contact/'}
        />
      ) : s.calvinNote ? (
        <BetterCallCalvin
          eyebrow="Advies aanvragen"
          titleLine1="Vraag vrijblijvend"
          titleAccent="advies."
          body={[
            `Stuur even wat je hebt staan, dan kijken we naar de staat van je site en adviseren we welk pakket past. Of dat een Custom-traject logischer is.`,
            'Geen verplichtingen. Als jouw situatie niet bij onze pakketten past, zeggen we dat.'
          ]}
          primaryLabel="Vraag advies aan ↗"
          primaryHref="/contact/?onderwerp=advies-onderhoud"
        />
      ) : (
        <BetterCallCalvin
          eyebrow="Een gesprek inplannen?"
          titleLine1="Klaar om dit"
          titleAccent="te bespreken?"
          body={[
            `Wil je weten of ${s.shortTitle ?? s.title} bij jouw bedrijf past? Plan een vrijblijvende kennismaking van 30 minuten. We kijken samen waar je staat en wat een logische volgende stap is.`,
            'Natuurlijk geheel vrijblijvend. Past het niet, dan zeggen we dat eerlijk.'
          ]}
        />
      )}
    </article>

    <!-- FAQ na de close-CTA, in dezelfde styling als de homepage. -->
    {s.faqs && s.faqs.length > 0 && (
      <FAQ items={s.faqs} />
    )}
  </main>
  <Footer />
</BaseLayout>
