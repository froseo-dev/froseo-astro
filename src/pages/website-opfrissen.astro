---
/**
 * SEO-landingspagina /website-opfrissen.
 *
 * Doel: keyword-pagina voor "website opfrissen" — bezoekers die geen
 * volledige rebuild willen, maar wel snelheid/security/design upgrade.
 * Niet gelinkt vanuit hoofdmenu; bestaat puur voor SEO + leads.
 *
 * Structuur:
 *   - Hero (h1 = "Website opfrissen.")
 *   - LogosTicker
 *   - Intro + interactieve BeforeAfter-slider (Studio Contenido) → hoog
 *     op de pagina zoals Calvin wilde
 *   - 4 USP-cards (Veiligheid / Snelheid / Design / Google Proof)
 *   - LogoBreak naar dark
 *   - "Klein beginnen of alles aanpakken?" 4-modules section (purple-deep)
 *   - LogoBreak terug naar light
 *   - Waarom-blok body-tekst
 *   - Mid CalvinNote (advies-CTA)
 *   - FAQ (herschreven naar Froseo-stijl)
 *   - BetterCallCalvin
 *
 * Achtergrond-ritme: cream → cream → cream → cream → divider → dark →
 * divider → cream → cream → cream → close-cta. De ene dark-sectie geeft
 * visuele afwisseling zonder dat de pagina te druk wordt.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Topbar from '@components/layout/Topbar.astro';
import Nav from '@components/layout/Nav.astro';
import Footer from '@components/layout/Footer.astro';
import EyebrowPill from '@components/ui/EyebrowPill.astro';
import ReviewAvatars from '@components/ui/ReviewAvatars.astro';
import SectionIcon from '@components/ui/SectionIcon.astro';
import LogosTicker from '@components/sections/LogosTicker.astro';
import BeforeAfter from '@components/sections/BeforeAfter.astro';
import HeroReason from '@components/sections/HeroReason.astro';
import CalvinNote from '@components/sections/CalvinNote.astro';
import BetterCallCalvin from '@components/sections/BetterCallCalvin.astro';
import FAQ from '@components/sections/FAQ.astro';
import WebsitesShowcase from '@components/sections/WebsitesShowcase.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { review } from '@data/site-config';
import heroMockup from '@assets/hero/website-opfrissen-hero.webp';
import froseoLogoWit from '@assets/brand/froseo-logo-wit.webp';
import studioContenidoBefore from '@assets/before-after/studio-contenido-before.webp';
import studioContenidoAfter from '@assets/before-after/studio-contenido-after.webp';
import ruthLastersScreenshot from '@assets/website-opfrissen/ruth-lasters.webp';

/* Cases — een aantal projecten die laten zien wat we al hebben
   opgeleverd. Mix van opfris- en rebuild-projecten zodat het
   visueel werkt. */
const allCases = await getCollection('cases', ({ data }) => data.published !== false);
const showcaseSlugs = [
  'renovatie-totaal',
  'rex-the-agency',
  'club12',
  'studio-contenido',
  'steunder',
  'millstreet',
];
const showcaseCases = showcaseSlugs
  .map((slug) => allCases.find((c) => c.data.slug === slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

const pageTitle = 'Website opfrissen: sneller, veiliger en weer fris | Froseo';
const pageDesc =
  'Niet meteen alles opnieuw bouwen, maar wel een veiligere, snellere en frissere website. Een opfrisbeurt vanaf €399, modulair op te bouwen.';

/* 4 USP-cards met SectionIcon-namen. Volgorde komt overeen met de
   modulaire route eronder ("Klein beginnen of alles aanpakken?"). */
/* Vier modules van de "Pak één ding aan, of alles in één keer"-sectie.
   Combineert de oorspronkelijke USP-teksten met de modulaire framing,
   in een iets rijkere paragraaf per module zodat het meer dieptewerk
   ademt dan de oude card-tekst. */
const modules = [
  {
    icon: 'paletteSwatch',
    title: 'Design opgefrist',
    body: 'Geen volledige rebrand, wel een verfrissing waar het telt. Typografie, kleurgebruik, knoppen, witruimte en mobiele uitlijning. We pakken aan wat je site nu visueel dateert, zonder je merk overhoop te halen. Belangrijk: zeven van de tien bezoekers komen via een telefoon. We testen alles op desktop, tablet en mobiel zodat je site overal even strak staat.',
  },
  {
    icon: 'chartUp',
    title: 'Snelheid omhoog',
    body: 'Caching scherp gezet, zware afbeeldingen omgezet naar WebP en je database opgeschoond. Plug-ins die meer remmen dan opleveren halen we eruit. Je laadtijd en Core Web Vitals knappen daar zichtbaar van op, wat je terugziet in zowel de gebruikservaring als in Google.',
  },
  {
    icon: 'shieldCheck',
    title: 'Veiligheid op orde',
    body: 'Sommige WordPress-plug-ins krijgen meerdere updates per week. Loopt dat achter, dan ligt je site er voor een hacker als een open deur bij. We werken alles bij naar de laatste stabiele versie en ruimen op wat je niet meer gebruikt. Inlogbescherming gaat aan, file-permissies kloppen weer en bekende kwetsbaarheden zetten we dicht.',
  },
  {
    icon: 'searchGlass',
    title: 'Google Proof',
    body: 'We trekken je sterke SEO-basis recht: schema, sitemap, metadata, koppenstructuur en interne links. Verouderde content scherpen we waar nodig aan, gebroken URLs vangen we netjes af. Een site die goed onderhouden is wordt ook beter gevonden.',
  },
];

const faqs = [
  {
    q: 'Wanneer is een opfrisbeurt slimmer dan een nieuwe website?',
    a: 'Als de basis van je site nog goed staat (techniek, structuur, merk) maar delen pijnlijk verouderd voelen. Te traag, niet meer mobielvriendelijk, slechte SEO-scores of een ontwerp dat duidelijk uit een ander tijdperk komt. Dan is opfrissen vaak een fractie van de kosten en de tijd van helemaal opnieuw beginnen. Twijfel je? Stuur ons je site, we kijken vrijblijvend mee en zeggen je of opfrissen genoeg is, of dat alles opnieuw bouwen verstandiger is.',
  },
  {
    q: 'Wat kost een opfrisbeurt precies?',
    a: 'Een basis-opfris start vanaf €399 voor een gerichte ronde op één onderdeel, bijvoorbeeld snelheid of veiligheid. Daarboven bouwen we modulair. Jij beslist of we alleen het meest urgente aanpakken of alles in één keer. Tijdens een gratis adviesgesprek geven we een heldere offerte vooraf, op basis van wat we onder de motorkap aantreffen.',
  },
  {
    q: 'Werken jullie alleen met WordPress-sites?',
    a: 'Voor opfrisbeurten ja. WordPress is ons specialisme en daar halen we de meeste winst. Andere platforms (Drupal, Webflow, Wix) doen we incidenteel op uurbasis voor losse opdrachten, maar de modulaire opfrisbeurt is specifiek voor WordPress ingericht.',
  },
  {
    q: 'Hoe lang duurt een gemiddelde opfrisbeurt?',
    a: 'Een gerichte module (snelheid, veiligheid of een design-refresh) is meestal binnen één of twee weken klaar. Een volledige ronde over alle vier de onderdelen is gemiddeld drie tot vier weken werk. We doen dit zonder dat je site langer dan strikt nodig uit de lucht hoeft.',
  },
  {
    q: 'Verlies ik mijn Google-rankings als jullie aan mijn site werken?',
    a: 'Nee. Dat is juist een van de redenen waarom we modulair werken: we vervangen je structuur niet, we verbeteren wat er staat. Bij wijzigingen die SEO raken (URL-structuur, content, redirects) stellen we vooraf een migratieplan op zodat rankings behouden blijven. Bij Renovatie Totaal en andere klanten hebben we hier ervaring mee.',
  },
  {
    q: 'Doen jullie ook onderhoud nadat de opfrisbeurt klaar is?',
    a: 'Ja, en dat raden we vaak ook aan. Een opfrisbeurt is eenmalig. Doorlopend onderhoud houdt je site daarna up-to-date en veilig. Daar hebben we vaste maandelijkse pakketten voor (Basic Care, Standard Care, Pro Care) inclusief premium plug-in-licenties.',
  },
  {
    q: 'Kunnen jullie ook helpen als ik geen idee heb waar te beginnen?',
    a: 'Ja. Stuur ons je site of geef toegang, dan duiken we erin en sturen we je een overzichtje. Waar zit de meeste winst, welke modules zijn urgent, welke kunnen wachten. Met of zonder vervolg-traject kun je er zelf al wat mee.',
  },
];
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <Topbar />
  <Nav />
  <main>
    <article class="opfris-page">
      <!-- ============================================================
           Hero — keyword-h1 staat hier direct in de h1-tag omdat de
           URL-slug en pagina-titel het primaire SEO-target dragen.
           Geen deferred-h1-trick nodig zoals op /website-laten-maken-zzp.
           ============================================================ -->
      <section class="service-hero has-image">
        <div class="service-hero-inner">
          <div class="service-hero-text">
            <EyebrowPill>Vanaf €399</EyebrowPill>
            <h1 class="service-hero-title">
              Website <em>opfrissen.</em>
            </h1>
            <ul class="service-hero-checks">
              <li>Snelheid en techniek weer on point</li>
              <li>Beveiliging en updates op orde, kwetsbaarheden dicht</li>
              <li>Design en content opgefrist zonder alles opnieuw te bouwen</li>
            </ul>
            <div class="service-hero-actions">
              <a class="btn-primary" href="/contact/?onderwerp=website-opfrissen">
                Vraag een opfris-analyse aan ↗
              </a>
            </div>
            <div class="service-hero-reviews reviews-inline">
              <ReviewAvatars />
              <div class="stars">★★★★★</div>
              <span><strong>{review.ratingDisplay}</strong> · Google reviews</span>
            </div>
          </div>

          <div class="service-hero-media">
            <Image
              src={heroMockup}
              alt="Website laten opfrissen door Froseo: opgefriste sites van Studio Contenido en Rex The Agency"
              title="Website laten opfrissen door Froseo: opgefriste sites van Studio Contenido en Rex The Agency"
              class="service-hero-img"
              widths={[640, 960, 1280, 1600]}
              sizes="(max-width: 1024px) 100vw, 640px"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>
      </section>

      <LogosTicker />

      <!-- ============================================================
           Waarom je website laten opfrissen — direct onder de logo-
           ticker. Donker-paars met ruitjes-pattern (zelfde tokens als
           de ticker), screenshot van Ruth Lasters als achtergrond met
           glassy tekst-card eroverheen. Concrete redenen, geen vage
           AI-taal. Volgt de problem-first volgorde i.p.v. eerst een
           visuele voor/na-hook.
           ============================================================ -->
      <HeroReason
        variant="left"
        eyebrow="Waarom opfrissen"
        title="Waarom je website laten"
        titleAccent="opfrissen?"
        body={[
          'Je site werkt nog, maar voelt traag. Plug-ins lopen achter. Het design oogt verouderd en je "voelt" hem niet meer. En je posities in Google zakken zonder dat je weet waarom.',
          'Met een opfrisbeurt pak je gericht aan wat achterloopt: snelheid, beveiliging, een fris ontwerp en je SEO-basis. Je houdt wat goed staat. Vaak voor een fractie van een nieuwe site.',
        ]}
        image={ruthLastersScreenshot}
        imageAlt="Opgefriste website voor Ruth Lasters door Froseo"
        imageTag="ruthlasters.com"
        ctaLabel="Plan een kennismaking ↗"
        ctaHref="/contact/?onderwerp=website-opfrissen"
      />

      <!-- ============================================================
           Interactieve before/after — Studio Contenido. Komt na het
           waarom-blok zodat de bezoeker eerst de redenen heeft gezien
           voordat de visuele proof volgt.
           ============================================================ -->
      <section class="opfris-ba">
        <div class="opfris-ba-inner">
          <div class="opfris-ba-head">
            <EyebrowPill variant="rare">Voor en na</EyebrowPill>
            <h2 class="opfris-ba-title">
              Van verouderd naar <em>fris.</em>
            </h2>
            <p class="opfris-ba-lead">
              Studio Contenido had een site die werkte, maar visueel en technisch
              achterliep op waar het merk inmiddels stond. Niet alles opnieuw, wel
              een gerichte opfrisbeurt op design, structuur en techniek. Sleep
              de handle om het verschil te zien.
            </p>
          </div>
          <BeforeAfter
            before={studioContenidoBefore}
            after={studioContenidoAfter}
            beforeAlt="Website van Studio Contenido voor de opfrisbeurt door Froseo"
            afterAlt="Opgefriste website voor Studio Contenido door Froseo"
          />
          <div class="opfris-ba-cta">
            <a class="btn-ghost" href="/cases/">Bekijk meer cases ↗</a>
          </div>
        </div>
      </section>

      <!-- ============================================================
           Modulair-aanpak sectie op donker-paarse achtergrond met
           Froseo-logo-watermark. Combineert wat eerder in twee aparte
           blokken (USPs + modules) stond tot één rijkere sectie. Direct
           daaronder, ZONDER section-break (zelfde paarse achtergrond):
           een mid-page CalvinNote en een cross-sell-card naar onderhoud
           zodat de hele "wat doen we voor je"-flow visueel als één
           geheel leest.
           ============================================================ -->
      <section class="opfris-modules">
        <Image
          src={froseoLogoWit}
          alt=""
          class="opfris-modules-watermark"
          aria-hidden="true"
          widths={[800, 1200, 1600]}
          sizes="(max-width: 1024px) 90vw, 1200px"
          loading="lazy"
        />
        <div class="opfris-modules-inner">
          <div class="opfris-modules-head">
            <EyebrowPill onDark>Modulair</EyebrowPill>
            <h2 class="opfris-modules-title">
              Pak één ding aan, of <em>alles in één keer.</em>
            </h2>
            <p class="opfris-modules-lead">
              We starten altijd met een vrijblijvende analyse van je site.
              Geen onderbuik-advies, maar een lijstje onderbouwd met data
              over waar bij jou de meeste winst zit. Daarna beslis jij welke
              modules we oppakken: alles tegelijk, of stap voor stap in je
              eigen tempo. Je betaalt alleen voor wat je daadwerkelijk laat
              doen.
            </p>
          </div>
          <div class="opfris-modules-grid">
            {modules.map((m, i) => (
              <article class="opfris-module-card">
                <SectionIcon name={m.icon} class="opfris-module-icon" size={36} />
                <div class="opfris-module-num">{String(i + 1).padStart(2, '0')}</div>
                <h3 class="opfris-module-title">{m.title}</h3>
                <p class="opfris-module-body">{m.body}</p>
              </article>
            ))}
          </div>

          {/* Mid-page advies-CTA op dezelfde paarse achtergrond, zodat
              het visueel onderdeel is van de modulaire-aanpak-flow. */}
          <div class="opfris-modules-note">
            <CalvinNote
              message="Twijfel je of een opfrisbeurt voor jouw site genoeg is, of dat een complete vernieuwing verstandiger is? Stuur ons toegang, dan kijken we onder de motorkap en sturen je een eerlijk advies terug."
              ctaLabel="Vraag advies aan ↗"
              ctaHref="/contact/?onderwerp=website-opfrissen-advies"
            />
          </div>

          {/* Cross-sell naar onderhoud — natuurlijke vervolg-stap. Geen
              aparte section: blijft binnen de paarse modules-section zodat
              alles als één samenhangend "wat we doen + hoe verder" leest. */}
          <div class="opfris-cross">
            <div class="opfris-cross-text">
              <EyebrowPill variant="primary" onDark>Na de opfrisbeurt</EyebrowPill>
              <h3 class="opfris-cross-title">
                Wil je dat je site <em>netjes blijft staan?</em>
              </h3>
              <p class="opfris-cross-body">
                Een opfrisbeurt brengt je site terug in topvorm. Maar WordPress,
                plug-ins en je thema blijven daarna ook bewegen.
              </p>
              <p class="opfris-cross-body">
                Wil je je site doorlopend in goede handen houden? Zet 'm dan
                bij ons in onderhoud voor een vast maandbedrag. Drie pakketten
                waar je uit kiest, van basis-updates tot een pakket waar je
                nergens meer naar omkijken hebt.
              </p>
              <a class="btn-primary opfris-cross-cta" href="/website-onderhoud/">
                Bekijk onderhoudspakketten ↗
              </a>
            </div>
            <div class="opfris-cross-right">
              {/* Sneak-peek van de Basic Care card. Bullets matchen 1-op-1
                  met src/data/maintenance-packages.ts (Basic Care features).
                  Geen verzonnen USPs zoals 'dagelijkse backups' (zit pas in
                  Standard Care) of '€10/u korting' (bestaat niet meer). */}
              <div class="pricing-card opfris-cross-card" aria-hidden="true">
                <header class="pricing-card-head opfris-cross-card-head">
                  <h3 class="pricing-card-name">Care Packages</h3>
                  <p class="pricing-card-tagline">Doorlopend in goede handen.</p>
                  <div class="pricing-card-price opfris-cross-card-price">
                    <span class="opfris-cross-vanaf">Vanaf</span>
                    <span class="pricing-amount-prefix">€</span>
                    <span class="pricing-amount">19</span>
                    <span class="pricing-period">/ maand</span>
                  </div>
                  <p class="pricing-card-for">Drie pakketten</p>
                </header>
                <ul class="pricing-card-features">
                  <li>
                    <span class="check-icon" aria-hidden="true">✓</span>
                    <span>Maandelijkse updates met restore-point</span>
                  </li>
                  <li>
                    <span class="check-icon" aria-hidden="true">✓</span>
                    <span>Wekelijkse backups en beveiligingsscan</span>
                  </li>
                  <li>
                    <span class="check-icon" aria-hidden="true">✓</span>
                    <span>24/7 uptime-monitoring</span>
                  </li>
                  <li>
                    <span class="check-icon" aria-hidden="true">✓</span>
                    <span>Support via mail, telefoon en WhatsApp</span>
                  </li>
                  <li class="is-highlight">
                    <span class="check-icon" aria-hidden="true">✓</span>
                    <span>Standard en Pro met premium plug-inlicenties</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================================================
           Projecten — wat we eerder hebben opgeleverd. Mix van opfris-
           en rebuild-cases zodat bezoekers zien dat we beide kanten op
           kunnen.
           ============================================================ -->
      <WebsitesShowcase
        cases={showcaseCases}
        eyebrow="Recent werk"
        title="Een greep uit"
        titleAccent="ons werk."
      />

      <BetterCallCalvin
        eyebrow="Aan de slag?"
        titleLine1="Tijd voor een"
        titleAccent="opfrisbeurt."
        body={[
          'Een mailtje, een WhatsApp of een gesprek van 30 minuten: jij bepaalt hoe laagdrempelig we beginnen.',
          'We kijken vrijblijvend mee en zeggen je wat zinnig is voor jouw site. Past het niet, dan zeggen we dat ook.',
        ]}
        primaryLabel="Plan een afspraak ↗"
        primaryHref="/contact/?onderwerp=website-opfrissen"
      />
    </article>

    <FAQ
      eyebrow="Veelgestelde vragen"
      titleLine1="Vragen over"
      titleAccent="opfrissen."
      items={faqs}
    />
  </main>
  <Footer />
</BaseLayout>
