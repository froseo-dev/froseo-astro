<BaseLayout title={pageTitle} description={pageDesc}>
  <Topbar />
  <Nav />
  <main>
    <article class="zzp-page">

      <!-- ============================================================
           1. HERO - H1 (was tagloze div). Geen bullets meer, wel een
           korte lead die de zoekterm draagt.
           ============================================================ -->
      <section class="service-hero has-image">
        <div class="service-hero-inner">
          <div class="service-hero-text">
            <EyebrowPill>Voor zzp'ers</EyebrowPill>
            <h1 class="service-hero-title">
              Website laten maken <em>zzp.</em>
            </h1>
            <p class="zzp-hero-lead">
              Wij maken professionele websites voor zzp'ers. Razendsnel, goed
              vindbaar in Google en snel online.
            </p>
            <div class="service-hero-actions">
              <a class="btn-primary" href="/contact/?onderwerp=zzp-website">Bespreek mijn zzp-website ↗</a>
              <a class="btn-ghost" href="#cases">Bekijk voorbeelden ↓</a>
            </div>
            <div class="service-hero-reviews reviews-inline">
              <ReviewAvatars />
              <div class="stars">★★★★★</div>
              <span><strong>{review.ratingDisplay}</strong> · Google reviews</span>
            </div>
          </div>

          <div class="service-hero-media">
            <Image
              src={heroMockup}
              alt="Website laten maken voor zzp'er door Froseo: Steunder op desktop, Prime Performance op mobiel"
              title="Website laten maken voor zzp'er door Froseo: Steunder op desktop, Prime Performance op mobiel"
              class="service-hero-img"
              widths={[640, 960, 1280, 1600]}
              sizes="(max-width: 1024px) 100vw, 640px"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>
      </section>

      <LogosTicker />

      <!-- ============================================================
           2. Waarom Froseo - 4 icoon-cards. Cream achtergrond.
           ============================================================ -->
      <section class="zzp-why">
        <div class="zzp-why-inner">
          <header class="zzp-why-head">
            <EyebrowPill variant="rare">Waarom Froseo</EyebrowPill>
            <h2 class="zzp-why-title">
              Waarom zzp'ers <em>met ons werken.</em>
            </h2>
          </header>
          <div class="zzp-why-grid">
            {whyFroseo.map((u) => (
              <article class="zzp-why-card">
                <SectionIcon name={u.icon} class="zzp-why-icon" size={44} />
                <h3 class="zzp-why-card-title">{u.title}</h3>
                <p class="zzp-why-card-body">{u.body}</p>
              </article>
            ))}
          </div>
        </div>
