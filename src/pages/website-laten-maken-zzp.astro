---

<BaseLayout title={pageTitle} description={pageDesc}>
  <Topbar />
  <Nav />
  <main>
    <article class="zzp-page">

      <!-- ============================================================
           1. HERO - H1 (was tagloze div). Geen bullets meer, wel een
           korte lead die de zoekterm draagt.
           ============================================================ -->
      <section class="service-hero has-image">
        <div class="service-hero-inner">
          <div class="service-hero-text">
            <EyebrowPill>Voor zzp'ers</EyebrowPill>
            <h1 class="service-hero-title">
              Website laten maken <em>zzp.</em>
            </h1>
            <p class="zzp-hero-lead">
              Wij maken professionele websites voor zzp'ers. Razendsnel, goed
              vindbaar in Google en snel online.
            </p>
            <div class="service-hero-actions">
              <a class="btn-primary" href="/contact/?onderwerp=zzp-website">Bespreek mijn zzp-website ↗</a>
              <a class="btn-ghost" href="#cases">Bekijk voorbeelden ↓</a>
            </div>
            <div class="service-hero-reviews reviews-inline">
              <ReviewAvatars />
              <div class="stars">★★★★★</div>
              <span><strong>{review.ratingDisplay}</strong> · Google reviews</span>
            </div>
          </div>

          <div class="service-hero-media">
            <Image
              src={heroMockup}
              alt="Website laten maken voor zzp'er door Froseo: Steunder op desktop, Prime Performance op mobiel"
              title="Website laten maken voor zzp'er door Froseo: Steunder op desktop, Prime Performance op mobiel"
              class="service-hero-img"
              widths={[640, 960, 1280, 1600]}
              sizes="(max-width: 1024px) 100vw, 640px"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>
      </section>

      <LogosTicker />

      <!-- ============================================================
           2. Waarom Froseo - 4 icoon-cards. Cream achtergrond.
           ============================================================ -->
      <section class="zzp-why">
        <div class="zzp-why-inner">
          <header class="zzp-why-head">
            <EyebrowPill variant="rare">Waarom Froseo</EyebrowPill>
            <h2 class="zzp-why-title">
              Waarom zzp'ers <em>met ons werken.</em>
            </h2>
          </header>
          <div class="zzp-why-grid">
            {whyFroseo.map((u) => (
              <article class="zzp-why-card">
                <div class="zzp-why-icon-wrap">
                  <SectionIcon name={u.icon} class="zzp-why-icon" size={28} />
                </div>
                <h3 class="zzp-why-card-title">{u.title}</h3>
                <p class="zzp-why-card-body">{u.body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- ============================================================
           3b. Testimonial - echte zzp-klant (Auke, Club12) vlak voor
           de pakketten. Trust-boost op het moment dat de bezoeker
           naar de prijzen kijkt.
           ============================================================ -->
      <Testimonial id="auke-club12" variant="card" />

      <!-- ============================================================
           3. Donker blok A - h2 + 3 pakketten + CalvinNote.
           H1 is verhuisd naar de hero; hier nu een h2.
           ============================================================ -->
      <section class="zzp-deal">
        <div class="zzp-deal-inner">
          <header class="zzp-deal-head">
            <EyebrowPill variant="highlight">Drie routes</EyebrowPill>
            <h2 class="zzp-deal-title">
              Welke route past bij jouw <em>zzp-website?</em>
            </h2>
            <p class="zzp-deal-lead">
              Drie manieren om als zzp'er online te komen. Geen investering vooraf? Kijk naar het <a class="zzp-link-light" href="/website-abonnement/">website abonnement voor zzp'ers</a>. Iets uitgebreiders nodig met meerdere pagina's? Een <a class="zzp-link-light" href="/webdesign/">maatwerk website laten maken</a> past dan beter. Liever klein starten? Een one-pager is vaak genoeg.
            </p>
          </header>

          <PackagePaths hideHead bare packages={priceOptions} />

          <div class="zzp-deal-note">
            <CalvinNote
              message="Twijfel je welke route bij je past? Stuur even wat je hebt staan of waar je naar zoekt, dan denken we vrijblijvend mee en geven we eerlijk advies."
              ctaLabel="Vraag vrijblijvend advies aan ↗"
              ctaHref="/contact/?onderwerp=zzp-website-advies"
            />
          </div>
        </div>
      </section>

      <!-- ============================================================
           4. CASES (showcase).
           ============================================================ -->
      <div id="cases">
        <WebsitesShowcase
          cases={showcaseCases}
          eyebrow="Voorbeelden"
          title="Voorbeelden voor zzp'ers"
          titleAccent="en kleine bedrijven."
        />
      </div>

      <!-- ============================================================
           4b. Zo verloopt een traject - 4 stappen in horizontaal
           timeline-blok (Approach met watermark). Dekt 'hoe werkt
           het'-zoekintentie en neemt koopangst weg ('wat gebeurt
           er nadat ik contact opneem').
           ============================================================ -->
      <Approach
        eyebrow="Zo werkt een traject"
        titleLine1="Van eerste mail tot"
        titleAccent="live zzp-website."
