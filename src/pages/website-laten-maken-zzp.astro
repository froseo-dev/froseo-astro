---
/**
 * SEO-landingspagina /website-laten-maken-zzp/.
 *
 * Custom Astro-page met afwisselende blokken die aansluiten op
 * site-componenten (service-hero, CalvinNote, BetterCallCalvin, Comparison,
 * FAQ, WebsitesShowcase) en de donker-pattern-styling van de Aanpak-sectie.
 *
 * Sectievolgorde:
 *   1. Hero (cream, standaard service-hero)
 *   2. LogosTicker
 *   3. Donker blok A: H1 + lead + 3 pakketten + CalvinNote-CTA
 *   4. Showcase (cases)
 *   5. Donker blok B: 'Wat we standaard regelen' (4 USP-cards) +
 *      'Wanneer is het de investering waard?' (checks)
 *   6. Comparison 'Zelf vs laten maken' + CTA-afsluiter
 *   7. Branches - 4 categorie-cards (cream, met accent-stripe)
 *   8. BetterCallCalvin
 *   9. FAQ
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Topbar from '@components/layout/Topbar.astro';
import Nav from '@components/layout/Nav.astro';
import Footer from '@components/layout/Footer.astro';
import EyebrowPill from '@components/ui/EyebrowPill.astro';
import ReviewAvatars from '@components/ui/ReviewAvatars.astro';
import SectionIcon from '@components/ui/SectionIcon.astro';
import LogosTicker from '@components/sections/LogosTicker.astro';
import PackagePaths from '@components/sections/PackagePaths.astro';
import WebsitesShowcase from '@components/sections/WebsitesShowcase.astro';
import CalvinNote from '@components/sections/CalvinNote.astro';
import BetterCallCalvin from '@components/sections/BetterCallCalvin.astro';
import Comparison from '@components/sections/Comparison.astro';
import FAQ from '@components/sections/FAQ.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { review, pricing } from '@data/site-config';
import heroMockup from '@assets/hero/website-laten-maken-zzp-hero.webp';

const pageTitle = "Website laten maken als zzp'er | Vanaf €89/m | Froseo";
const pageDesc =
  `Laat als zzp'er een professionele website maken die snel laadt, vertrouwen wekt en klaar is voor Google. Kies maatwerk of een all-in website abonnement vanaf ${pricing.abboFromInline}.`;

const allCases = await getCollection('cases', ({ data }) => data.published !== false);
const showcaseSlugs = [
  'renovatie-totaal',
  'club12',
  'prime-performance',
  'steunder',
  'studio-contenido',
  'theo-mackaay',
];
const showcaseCases = showcaseSlugs
  .map((slug) => allCases.find((c) => c.data.slug === slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

/* Drie pakket-routes - opgebouwd in de stijl van de service-path-cards
   (tag-pill bovenin, body, check-lijst, button). Featured = POPULAIR. */
/* Drie routes voor zzp'ers in vaste volgorde: abonnement (featured/eerst),
   one-pager, maatwerk. Pricing-card stijl via <PackagePaths>. */
const priceOptions = [
  {
    name: 'Website-abonnement',
    tagline: 'Compleet, vaste maandprijs.',
    priceFrom: true,
    priceAmount: 89,
    pricePeriod: '/maand',
    body: "Voor zzp'ers die snel en zonder gedoe professioneel online willen staan. Vaste maandprijs, duidelijke afspraken en ruimte voor kleine aanpassingen.",
    checks: [
      'Snel live met een professionele website',
      'Razendsnel: we streven naar 90+ Google PageSpeed',
      'Sterke basis voor snelheid, vindbaarheid en conversie',
      'Inclusief hosting, beheer en kleine wijzigingen',
    ],
    cta: { label: 'Bekijk abonnementen', href: '/website-abonnement/' },
    featured: true,
    badge: 'Meest gekozen',
  },
  {
    name: 'One-pager website',
    tagline: 'Compact, snel en professioneel.',
    priceFrom: true,
    priceAmount: 499,
    body: 'Een strakke, snelle one-pager die professioneel overkomt zodra iemand je naam googelt. Modern design, gericht op conversie.',
    checks: [
      'Strakke, moderne one-page opzet',
      'Snel live: vaak binnen 2 weken',
      'Geoptimaliseerd voor mobiel en conversie',
      'Compact en doelgericht',
    ],
    cta: { label: 'Vraag offerte aan', href: '/contact/?onderwerp=zzp-onepager' },
  },
  {
    name: 'Maatwerk website',
    tagline: 'Voor complexere websites.',
    priceFrom: true,
    priceAmount: 999,
    body: "Voor zzp'ers die meer pagina's, sterkere structuur en lokale SEO-basis nodig hebben. Klaar om mee te groeien.",
    checks: [
      "Aparte dienst- en landingspagina's",
      'Sterke basis voor SEO, snelheid en conversie',
      'Volledige vrijheid in design en structuur',
      'Klaar voor uitbreiding naar SEO-traject',
    ],
    cta: { label: 'Plan een kennismaking', href: '/contact/?onderwerp=zzp-maatwerk' },
  },
];

const investmentWorth = [
  'Klanten je eerst online checken voordat ze contact opnemen.',
  'Je afhankelijk bent van aanvragen uit je regio.',
  'Je niet alleen via-via gevonden wilt worden.',
  'Je je diensten beter wilt uitleggen dan op social media past.',
  'Je betrouwbaar wilt overkomen naast je concurrenten.',
  'Je Google wilt gebruiken als structureel kanaal voor nieuwe klanten.',
];

const usps = [
  {
    icon: 'shieldCheck',
    title: 'Google Proof',
    body: "Elke site wordt Google Proof opgeleverd, klaar om lokaal gevonden te worden. Goede techniek, snelle pagina's en de juiste structuur zitten er vanaf de basis in.",
  },
  {
    icon: 'locationPin',
    title: 'Lokaal vindbaar',
    body: "Als zzp'er richt je je vaak op je eigen regio. We zorgen dat je in jouw plaats en branche bovenaan in Google opduikt.",
  },
  {
    icon: 'paletteSwatch',
    title: 'Huisstijl en design',
    body: 'Je logo en huisstijl horen bij je online identiteit. Hulp nodig met het ontwerp? We denken graag mee.',
  },
  {
    icon: 'toolbox',
    title: 'Full-service',
    body: 'Bedrijfs-e-mail, hosting, technisch beheer en onderhoud: we regelen het allemaal. Jij blijft je werk doen, wij houden je site scherp.',
  },
];

const comparison = {
  title: 'Zelf maken of je zzp-website',
  titleAccent: 'laten maken?',
  withoutLabel: 'Zelf maken',
  withLabel: 'Door Froseo laten maken',
  items: [
    { without: 'Goedkoop starten', with: 'Vanaf dag één professioneel oogt' },
    { without: 'Veel zelf uitzoeken en aanmodderen', with: 'Wij regelen het, jij houdt tijd over voor je werk' },
    { without: 'Prima voor een simpele start', with: 'Betere basis voor SEO en conversie' },
    { without: 'Vaak beperkt maatwerk', with: 'Flexibeler uit te breiden naarmate je groeit' },
    { without: 'Kost vooral je eigen tijd', with: 'Kost geld, maar bespaart tijd en gedoe' },
  ],
};

/* Branches - vier gegroepeerde categorieen, met accent-kleur per categorie
   voor visueel interessantere cards. */
const segments = [
  {
    title: 'Vakmensen',
    accent: 'var(--accent-rare, #b6007b)',
    branches: 'Dakdekkers, aannemers, loodgieters, schilders, stukadoors, installateurs, schoorsteenvegers, timmermannen, elektriciens, tuinmannen en hoveniers.',
    body: "Snelle, mobiel-eerst sites met offerteformulieren, een klikbaar telefoonnummer en lokale SEO. Klanten zoeken vakmensen vaak met spoed en op de telefoon.",
  },
  {
    title: 'Gezondheid en coaching',
    accent: 'var(--color-teal, #00807d)',
    branches: "Personal trainers, coaches, yogastudio's en (massage)therapeuten.",
    body: 'Sites die rust uitstralen, je aanpak en aanbod helder tonen en bezoekers een laagdrempelige intake aanbieden. Vertrouwen wekken is hier het halve werk.',
  },
  {
    title: 'Beauty en lifestyle',
    accent: 'var(--accent-primary, #6901aa)',
    branches: 'Kappers, nagelstylisten, tattoo artists en schoonheidsspecialisten.',
    body: "Visuele sites die je werk laten spreken: strakke portfolio, reviews en een eenvoudige boekingsoptie. Klanten beslissen vaak binnen seconden op mobiel.",
  },
  {
    title: 'Creatief en dienstverlening',
    accent: 'var(--accent-highlight, #f5c518)',
    branches: 'Fotografen, ontwerpers, consultants en kleine bureaus.',
    body: "Sites met sterke beeldtaal, duidelijke dienstenpagina's en ruimte voor je verhaal en je werk. Past bij zzp'ers waar de eerste indruk telt.",
  },
];

const faqs = [
  {
    q: "Wat kost een website laten maken als zzp'er?",
    a: `Dat hangt af van wat je nodig hebt. Een one-pager begint rond de €499, een maatwerk-website vanaf €999. Wil je geen investering vooraf, dan kun je kiezen voor het website abonnement vanaf ${pricing.abboFromInline}, inclusief hosting en onderhoud. In een vrijblijvend gesprek bespreken we welke optie past en geven we vooraf een heldere prijs.`,
  },
  {
    q: "Kan ik als zzp'er ook een website abonnement nemen?",
    a: `Ja, juist voor zzp'ers is dat vaak de slimste route. Geen grote investering vooraf, een vast bedrag per maand en hosting, onderhoud en kleine wijzigingen zitten erbij. Het abonnement start vanaf ${pricing.abboFromInline} en is maandelijks opzegbaar na drie maanden.`,
  },
  {
    q: 'Wat is het verschil tussen een goedkope en een professionele zzp-website?',
    a: "Voor een paar honderd euro kun je ergens een site laten bouwen. Prima als je alleen een digitaal visitekaartje nodig hebt. Wil je professioneel overkomen, lokaal gevonden worden en later kunnen uitbreiden, dan is de basis belangrijker dan alleen de laagste prijs. Denk aan snelheid, mobiele ervaring, structuur, goede teksten en structureel onderhoud.",
  },
  {
    q: "Is een one-page website genoeg voor een zzp'er?",
    a: 'Vaak wel. Als je vooral professioneel wilt overkomen wanneer iemand je naam googelt, of een aanvraag mogelijk wilt maken, dan is een goed gebouwde one-pager prima. Wil je op meerdere diensten of plaatsen lokaal gevonden worden, dan is een uitgebreidere site met aparte pagina\'s slimmer.',
  },
  {
    q: "Kan mijn website later worden uitgebreid met SEO-pagina's?",
    a: "Zeker. We bouwen flexibel: starten met een one-pager of compacte site kan, en later breiden we uit met dienst- of locatiepagina's zodra je lokaal beter gevonden wilt worden. Geen opnieuw beginnen, gewoon doorbouwen op dezelfde basis.",
  },
  {
    q: "Maken jullie ook websites voor startende zzp'ers?",
    a: "Ja. Veel startende zzp'ers kiezen voor het abonnement of een compacte one-pager: snel professioneel online zonder grote investering vooraf. We denken mee over wat je wel en nog niet nodig hebt.",
  },
  {
    q: 'Is WordPress of Astro beter voor mijn zzp-website?',
    a: 'Dat hangt af van wat je site moet doen. WordPress is fijn als je vaak zelf content wilt aanpassen en bloggen. Astro is razendsnel en ideaal voor sites die vooral moeten presteren in Google en op mobiel. We adviseren wat past bij jouw situatie en doelen.',
  },
  {
    q: "Word ik goed gevonden in Google als zzp'er?",
    a: 'Jazeker. We bouwen je site met lokale SEO als basis. Dat betekent dat je goed scoort op zoekopdrachten als "loodgieter Utrecht" of "personal trainer Haarlem". We zorgen voor een sterke technische basis, snelle laadtijd en koppeling met je Google Business-profiel.',
  },
  {
    q: 'Ik heb weinig tijd. Hoeveel moet ik zelf doen?',
    a: "Je levert wat basisinformatie aan (diensten, logo, eventueel wat foto's), wij doen de rest: ontwerp, techniek, teksten en inrichting. Geen dagenlang puzzelen of zelf alles schrijven.",
  },
  {
    q: 'Regelen jullie ook hosting en e-mail?',
    a: 'Ja. Domeinnaam, snelle hosting en professionele e-mailadressen (zoals info@jouwbedrijf.nl) regelen we. Wil je je mail koppelen aan Gmail of Outlook? Ook dat doen we voor je.',
  },
  {
    q: 'Ik heb al werk via-via. Heb ik dan wel een website nodig?',
    a: 'Ook dan is een site slim. Veel mensen kijken eerst online of iemand betrouwbaar overkomt voordat ze contact opnemen. Daarnaast helpt het je voorbereid te zijn op rustigere periodes.',
  },
];
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <Topbar />
  <Nav />
  <main>
    <article class="zzp-page">

      <!-- ============================================================
           1. HERO - standaard service-hero-patroon.
           ============================================================ -->
      <section class="service-hero has-image">
        <div class="service-hero-inner">
          <div class="service-hero-text">
            <EyebrowPill>Voor zzp'ers</EyebrowPill>
            <div class="service-hero-title">
              Betaalbare websites <em>voor ZZP'ers.</em>
            </div>
            <ul class="service-hero-checks">
              <li>Maatwerk of all-in website abonnement vanaf {pricing.abboFromShort}</li>
              <li>Sterke structuur, snelle techniek en lokale SEO-basis</li>
              <li>Wij regelen design, teksten, hosting en onderhoud</li>
            </ul>
            <div class="service-hero-actions">
              <a class="btn-primary" href="/contact/?onderwerp=zzp-website">Bespreek mijn zzp-website ↗</a>
              <a class="btn-ghost" href="#cases">Bekijk voorbeelden ↓</a>
            </div>
            <div class="service-hero-reviews reviews-inline">
              <ReviewAvatars />
              <div class="stars">★★★★★</div>
              <span><strong>{review.ratingDisplay}</strong> · Google reviews</span>
            </div>
          </div>

          <div class="service-hero-media">
            <Image
              src={heroMockup}
              alt="Website laten maken voor zzp'er door Froseo: Steunder op desktop, Prime Performance op mobiel"
              title="Website laten maken voor zzp'er door Froseo: Steunder op desktop, Prime Performance op mobiel"
              class="service-hero-img"
              widths={[640, 960, 1280, 1600]}
              sizes="(max-width: 1024px) 100vw, 640px"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>
      </section>

      <LogosTicker />

      <!-- ============================================================
           2. Donker blok A - H1 + intro + 3 pakketten + advies-CTA.
           Echte site-donker (surface-dark + bg-decoration-dark) zoals
           de Aanpak-sectie.
           ============================================================ -->
      <section class="zzp-deal">
        <div class="zzp-deal-inner">
          <header class="zzp-deal-head">
            <EyebrowPill variant="highlight">Voor zzp'ers</EyebrowPill>
            <h1 class="zzp-deal-title">
              Website laten maken als <em>zzp'er</em>
            </h1>
            <p class="zzp-deal-lead">
              Snel online, vertrouwen wekkend en klaar om aanvragen op te leveren. Welke route slim is hangt af van waar je staat: geen investering vooraf? Het abonnement. Betaalbaar professioneel? Een one-pager. Echt lokaal vindbaar? Maatwerk.
            </p>
          </header>

          <PackagePaths hideHead bare packages={priceOptions} />


          <div class="zzp-deal-note">
            <CalvinNote
              message="Twijfel je welke route bij je past? Stuur even wat je hebt staan of waar je naar zoekt, dan denken we vrijblijvend mee en geven we eerlijk advies."
              ctaLabel="Vraag vrijblijvend advies aan ↗"
              ctaHref="/contact/?onderwerp=zzp-website-advies"
            />
          </div>
        </div>
      </section>

      <!-- ============================================================
           3. CASES (showcase).
           ============================================================ -->
      <div id="cases">
        <WebsitesShowcase
          cases={showcaseCases}
          eyebrow="Voorbeelden"
          title="Websites die we maakten voor"
          titleAccent="zzp'ers en kleine bedrijven."
        />
      </div>

      <!-- ============================================================
           4. Donker blok B - 'Wat we standaard regelen' (4 cards) +
           'Wanneer is het de investering waard?' (checks).
           Gecombineerd in 1 donkere sectie zoals de homepage-WhyFroseo.
           ============================================================ -->
      <section class="zzp-care">
        <div class="zzp-care-inner">
          <header class="zzp-care-head">
            <EyebrowPill variant="highlight">Wat we regelen</EyebrowPill>
            <h2 class="zzp-care-title">
              Wat we voor ZZP'ers <em>standaard regelen.</em>
            </h2>
          </header>
          <div class="zzp-care-grid">
            {usps.map((u) => (
              <article class="zzp-care-card">
                <SectionIcon name={u.icon} class="zzp-care-icon" size={44} />
                <h3 class="zzp-care-card-title">{u.title}</h3>
                <p class="zzp-care-card-body">{u.body}</p>
              </article>
            ))}
          </div>

          <div class="zzp-care-divider"></div>

          <header class="zzp-care-sub">
            <EyebrowPill variant="rare">Wanneer wel, wanneer niet</EyebrowPill>
            <h2 class="zzp-care-sub-title">
              Wanneer is een zzp-website de <em>investering waard?</em>
            </h2>
          </header>
          <ul class="zzp-care-list">
            {investmentWorth.map((item, i) => (
              <li>
                <span class="zzp-care-num">{String(i + 1).padStart(2, '0')}</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <p class="zzp-care-after">
            Voor sommige zzp'ers is een digitaal visitekaartje al genoeg. Voor anderen is de website het belangrijkste verkoopkanaal. Daarom bouwen we niet één standaardpakket voor iedereen, maar kijken we naar wat jouw bedrijf nodig heeft.
          </p>
          <div class="zzp-care-cta">
            <a class="btn-primary" href="/contact/?onderwerp=zzp-website-advies">Plan een vrijblijvend gesprek ↗</a>
          </div>
        </div>
      </section>

      <!-- ============================================================
           5. COMPARISON + CTA.
           ============================================================ -->
      <Comparison
        title={comparison.title}
        titleAccent={comparison.titleAccent}
        withoutLabel={comparison.withoutLabel}
        withLabel={comparison.withLabel}
        items={comparison.items}
      />
      <section class="zzp-compare-after">
        <div class="zzp-compare-after-inner">
          <p>
            Twijfel je nog? We denken eerlijk mee. Soms is zelf starten prima. Maar als je site klanten moet overtuigen of lokaal vindbaar moet worden, is professioneel laten maken meestal slimmer.
          </p>
          <a class="btn-ghost" href="/contact/?onderwerp=zzp-website-advies">Stel je vraag ↗</a>
        </div>
      </section>

      <!-- ============================================================
           6. BRANCHES - 4 categorie-cards (cream + accent-stripe).
           ============================================================ -->
      <section class="zzp-segments">
        <div class="zzp-segments-inner">
          <header class="zzp-segments-head">
            <EyebrowPill variant="rare">Voor welke zzp'ers</EyebrowPill>
            <h2 class="zzp-segments-title">
              Voor welke ZZP'ers maken we <em>websites?</em>
            </h2>
            <p class="zzp-segments-lead">
              Eigenlijk voor elke zzp'er die professioneel online wil zijn. Een greep uit ons werk:
            </p>
          </header>
          <div class="zzp-segments-grid">
            {segments.map((s) => (
              <article class="zzp-segment-card" style={`--seg-accent: ${s.accent}`}>
                <h3>{s.title}</h3>
                <p class="zzp-segment-body">{s.body}</p>
                <p class="zzp-segment-branches"><strong>Bijvoorbeeld:</strong> {s.branches}</p>
              </article>
            ))}
          </div>
          <div class="zzp-segments-cta">
            <a class="btn-primary" href="/contact/?onderwerp=zzp-website">Vraag een offerte aan ↗</a>
            <a class="btn-ghost" href="/portfolio/">Bekijk ons portfolio ↗</a>
          </div>
        </div>
      </section>

      <BetterCallCalvin
        eyebrow="Tijd voor een kennismaking?"
        titleLine1="Plan een korte"
        titleAccent="kennismaking."
        body={[
          'Een mailtje, een WhatsApp of een gesprek van 30 minuten: jij bepaalt hoe laagdrempelig we beginnen.',
          'Geheel vrijblijvend. Past het niet, dan zeggen we dat eerlijk.',
        ]}
        primaryLabel="Plan een afspraak ↗"
        primaryHref="/contact/?onderwerp=zzp-website"
      />
    </article>

    <FAQ
      eyebrow="Veelgestelde vragen"
      titleLine1="Vragen over een website laten maken als"
      titleAccent="zzp'er."
      items={faqs}
    />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ============================================================
     DONKER BLOK A - H1 + pakketten + CalvinNote.
     Echte site-donker via surface-dark + bg-decoration-dark
     (zelfde pattern als de Aanpak-sectie).
     ============================================================ */
  .zzp-deal {
    background: var(--surface-dark);
    background-image: var(--bg-decoration-dark);
    background-size: var(--backdrop-size);
    background-repeat: var(--backdrop-repeat);
    color: var(--text-on-dark, #fff);
    padding: clamp(3.5rem, 6vw, 5.5rem) var(--gutter, 1.5rem);
  }
  .zzp-deal-inner { max-width: var(--container-max, 1200px); margin: 0 auto; }
  .zzp-deal-head {
    text-align: center;
    max-width: 56rem;
    margin: 0 auto 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .zzp-deal-title {
    font-family: var(--font-display, sans-serif);
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0;
    color: #fff;
  }
  .zzp-deal-title em { color: var(--accent-highlight); font-style: normal; }
  .zzp-deal-lead { line-height: 1.65; opacity: 0.88; margin: 0; max-width: 50rem; }

  /* Pakket-cards staan nu in <PackagePaths>; CSS daar in het component. */

  /* CalvinNote ingebed in dezelfde donkere sectie. */
  .zzp-deal-note { margin-top: clamp(2.5rem, 5vw, 3.5rem); }

  /* ============================================================
     DONKER BLOK B - 'Wat we standaard regelen' + 'Wanneer is het waard?'
     Gecombineerd in 1 sectie zoals de homepage-WhyFroseo.
     ============================================================ */
  .zzp-care {
    background: var(--surface-dark);
    background-image: var(--bg-decoration-dark);
    background-size: var(--backdrop-size);
    background-repeat: var(--backdrop-repeat);
    color: var(--text-on-dark, #fff);
    padding: clamp(3.5rem, 6vw, 5.5rem) var(--gutter, 1.5rem);
  }
  .zzp-care-inner { max-width: var(--container-max, 1200px); margin: 0 auto; }
  .zzp-care-head,
  .zzp-care-sub {
    text-align: center;
    max-width: 56rem;
    margin: 0 auto 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
  }
  .zzp-care-title,
  .zzp-care-sub-title {
    font-family: var(--font-display, sans-serif);
    font-weight: 800;
    font-size: clamp(1.9rem, 3.6vw, 2.7rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0;
    color: #fff;
  }
  .zzp-care-title em { color: var(--accent-highlight); font-style: normal; }
