---
/**
 * SEO-landingspagina /website-laten-maken-zzp/.
 *
 * Doel: ranken op "website laten maken zzp", "zzp website laten maken",
 * "website voor zzp'er", "zzp-website" plus longtail-varianten.
 *
 * Architectuur: pakket-conversie blijft hoog op de pagina, maar tussen
 * de blokken zit nu meer inhoudelijke diepte (kost-uitleg, kwaliteits-
 * checks, vergelijkings-blokken en uitgeschreven branche-alinea's) zodat
 * de pagina aan de zoekintentie "koopgids" voldoet. Zonder lopende lappen
 * tekst — elk nieuw blok is een visuele module (kaarten, icoon-grid,
 * vergelijking, accordion).
 *
 * H1 is verhuisd naar de hero (was eerder een tagloze div); de donker-
 * sectie met de pakketten draagt nu een h2.
 *
 * Sectie-volgorde:
 *   1. Hero (h1)
 *   2. LogosTicker
 *   3. Waarom Froseo (4 icoon-cards)
 *   4. Donker blok: 3 pakketten + CalvinNote
 *   5. Showcase
 *   6. Waar moet een goede zzp-website aan voldoen (5 icoon-cards)
 *   7. Donker blok: Wanneer is het de investering waard?
 *   8. Comparison: zelf maken of laten maken
 *   9. One-pager of complete zzp-website (4-koloms keuzehulp)
 *  10. Branches met uitgeschreven alinea's
 *  11. BetterCallCalvin
 *  12. FAQ
 *
 * Eerder waren er drie secties die dubbel-op zaten met andere blokken
 * (Wat-kost-cards = pakketten, Twee-uitgelichte-cases = showcase,
 * Wat-we-regelen = Waarom Froseo). Die zijn verwijderd.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Topbar from '@components/layout/Topbar.astro';
import Nav from '@components/layout/Nav.astro';
import Footer from '@components/layout/Footer.astro';
import EyebrowPill from '@components/ui/EyebrowPill.astro';
import ReviewAvatars from '@components/ui/ReviewAvatars.astro';
import SectionIcon from '@components/ui/SectionIcon.astro';
import LogosTicker from '@components/sections/LogosTicker.astro';
import PackagePaths from '@components/sections/PackagePaths.astro';
import WebsitesShowcase from '@components/sections/WebsitesShowcase.astro';
import CalvinNote from '@components/sections/CalvinNote.astro';
import BetterCallCalvin from '@components/sections/BetterCallCalvin.astro';
import Comparison from '@components/sections/Comparison.astro';
import Testimonial from '@components/sections/Testimonial.astro';
import Approach from '@components/sections/Approach.astro';
import FAQ from '@components/sections/FAQ.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { review, pricing } from '@data/site-config';
import heroMockup from '@assets/hero/website-laten-maken-zzp-hero.webp';

const pageTitle = "Website laten maken als zzp'er | Vanaf €89/m | Froseo";
const pageDesc =
  `Website laten maken zzp: een professionele site die snel laadt, vertrouwen wekt en klaar is voor Google. Kies maatwerk of een website abonnement vanaf ${pricing.abboFromInline}.`;

const allCases = await getCollection('cases', ({ data }) => data.published !== false);
const showcaseSlugs = [
  'renovatie-totaal',
  'club12',
  'prime-performance',
  'steunder',
  'studio-contenido',
  'theo-mackaay',
];
const showcaseCases = showcaseSlugs
  .map((slug) => allCases.find((c) => c.data.slug === slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

/* === Waarom Froseo — 4 icoon-cards bovenin de pagina. Bewust positief en
   concreet geformuleerd, zonder grote claims. */
const whyFroseo = [
  {
    icon: 'archiveStack',
    title: 'Tientallen zzp-sites opgeleverd',
    body: "Van personal trainers tot dakdekkers en fotografen. We weten wat een zzp-website nodig heeft om vertrouwen te wekken en aanvragen op te leveren.",
  },
  {
    icon: 'chartUp',
    title: 'Snelle sites gericht op aanvragen',
    body: 'Razendsnelle techniek, een duidelijke knop op de juiste plek en formulieren die werken op je telefoon. Zo komt jouw werk binnen via je website.',
  },
  {
    icon: 'toolbox',
    title: 'Een oplossing die bij je past',
    body: 'Een abonnement, een one-pager of een maatwerk-traject. Je kiest de route die past bij je budget, je tempo en wat je site moet doen.',
  },
  {
    icon: 'locationPin',
    title: 'Lokale SEO-basis vanaf dag één',
    body: 'Snelle techniek, duidelijke koppen, schema-markup en lokale zoekwoorden zitten erin gebakken. Klaar om in jouw regio en branche beter gevonden te worden.',
  },
];

/* === Drie pakket-routes voor zzp'ers, in vaste volgorde:
   abonnement (featured), one-pager, maatwerk. */
const priceOptions = [
  {
    name: 'Website-abonnement',
    tagline: 'Compleet, vaste maandprijs.',
    priceFrom: true,
    priceAmount: 89,
    pricePeriod: '/maand',
    body: "Voor zzp'ers die snel en zonder gedoe professioneel online willen staan. Vaste maandprijs, duidelijke afspraken en ruimte voor kleine aanpassingen.",
    checks: [
      'Snel live met een professionele website',
      'Razendsnel: we streven naar 90+ Google PageSpeed',
      'Sterke basis voor snelheid, vindbaarheid en conversie',
      'Inclusief hosting, beheer en kleine wijzigingen',
    ],
    cta: { label: 'Bekijk abonnementen', href: '/website-abonnement/' },
    featured: true,
    badge: 'Meest gekozen',
  },
  {
    name: 'One-pager website',
    tagline: 'Compact, snel en professioneel.',
    priceFrom: true,
    priceAmount: 499,
    body: 'Een strakke one-pager die professioneel overkomt zodra iemand je naam googelt. Modern design, gericht op conversie.',
    checks: [
      'Strakke, moderne one-page opzet',
      'Snel live: vaak binnen 2 weken',
      'Geoptimaliseerd voor mobiel en conversie',
      'Compact en doelgericht',
    ],
    cta: { label: 'Vraag offerte aan', href: '/contact/?onderwerp=zzp-onepager' },
  },
  {
    name: 'Maatwerk website',
    tagline: 'Voor complexere websites.',
    priceFrom: true,
    priceAmount: 999,
    body: "Voor zzp'ers die meer pagina's, sterkere structuur en een lokale SEO-basis nodig hebben. Klaar om mee te groeien.",
    checks: [
      "Aparte dienst- en landingspagina's",
      'Sterke basis voor SEO, snelheid en conversie',
      'Volledige vrijheid in design en structuur',
      'Klaar voor uitbreiding naar SEO-traject',
    ],
    cta: { label: 'Plan een kennismaking', href: '/contact/?onderwerp=zzp-maatwerk' },
  },
];

const investmentWorth = [
  'Klanten je eerst online checken voordat ze contact opnemen.',
  'Je afhankelijk bent van aanvragen uit je regio.',
  'Je niet alleen via-via gevonden wilt worden.',
  'Je je diensten beter wilt uitleggen dan op social media past.',
  'Je betrouwbaar wilt overkomen naast je concurrenten.',
  'Je Google wilt gebruiken als structureel kanaal voor nieuwe klanten.',
];

/* === Kwaliteits-checks: waar voldoet een goede zzp-website aan?
   Vijf icoon-cards. Bewust de SEO-card breed gehouden ("interne
   links, lokale zoekwoorden") zodat het matcht met semantische
   varianten van de zoekterm. */
const qualityChecks = [
  {
    icon: 'target',
    title: 'Duidelijke positionering',
    body: 'Binnen seconden duidelijk wat je doet en voor wie. Geen vage homepage met drie boodschappen tegelijk.',
  },
  {
    icon: 'paletteSwatch',
    title: 'Sterke mobiele ervaring',
    body: 'Telefoonnummer, contactknop en formulier werken direct goed op mobiel. Cookiebar die geen halve scherm vult.',
  },
  {
    icon: 'shieldCheck',
    title: 'Vertrouwen op de pagina',
    body: "Reviews, cases, foto's, afgeronde projecten en een echte over-mij. Mensen kopen pas wanneer ze geloven dat je levert.",
  },
  {
    icon: 'searchGlass',
    title: 'SEO-basis',
    body: 'Snelle techniek, duidelijke koppen, lokale zoekwoorden en goede interne links. Klaar om lokaal beter gevonden te worden.',
  },
  {
    icon: 'chartUp',
    title: 'Conversie en actie',
    body: 'De site stuurt op een concrete volgende stap: bellen, mailen, WhatsApp, offerte of een afspraak inplannen.',
  },
];

const comparison = {
  title: 'Zelf maken of je zzp-website',
  titleAccent: 'laten maken?',
  withoutLabel: 'Zelf maken',
  withLabel: 'Door Froseo laten maken',
  items: [
    { without: 'Goedkoop starten', with: 'Vanaf dag één professioneel oogt' },
    { without: 'Veel zelf uitzoeken en aanmodderen', with: 'Wij regelen het, jij houdt tijd over voor je werk' },
    { without: 'Prima voor een simpele start', with: 'Betere basis voor SEO en conversie' },
    { without: 'Vaak beperkt maatwerk', with: 'Flexibeler uit te breiden naarmate je groeit' },
    { without: 'Kost vooral je eigen tijd', with: 'Kost geld, maar bespaart tijd en gedoe' },
  ],
};

/* === Vier-koloms keuzehulp: welke vorm past bij welke situatie?
   Geen rauwe markdown-tabel maar vier gestylede cards in een grid. */
const choiceCards = [
  {
    title: 'One-pager',
    fit: 'Starters · netwerkverkeer · eenvoudige diensten',
    body: 'Snel online en professioneel zodra iemand je naam intikt. Genoeg als je vooral van warm verkeer leeft.',
  },
  {
    title: 'Compacte website',
    fit: 'Meerdere diensten · meer uitleg nodig',
    body: "Een paar pagina's voor diensten, werkwijze en contact. Voldoende ademruimte om je verhaal te vertellen.",
  },
  {
    title: 'Maatwerk',
    fit: 'Lokale SEO · meerdere landingspagina\'s · groei via Google',
    body: 'Bouwen op vindbaarheid. Per dienst of regio een eigen landingspagina, ingericht om in Google te groeien.',
  },
  {
    title: 'Abonnement',
    fit: 'Geen investering vooraf · alles geregeld per maand',
    body: 'Hosting, onderhoud en kleine wijzigingen in een vast maandbedrag. Geen losse facturen, geen verrassingen.',
  },
];

/* === Branche-segments met UITGESCHREVEN ALINEA's (terug van weggeweest).
   Vier categorieen, per categorie een echte alinea + branche-lijstje. */
const segments = [
  {
    title: 'Vakmensen',
    accent: 'var(--accent-rare, #b6007b)',
    body: "Werk je als dakdekker, loodgieter of installateur, dan word je gevonden als het ergens misgaat. Iemand zoekt op \"lekkage dak\" of \"dakdekker [plaats]\" en pakt de telefoon. Mobiel-eerst, een klikbaar telefoonnummer, een kort offerteformulier en een fotosectie voor je vakwerk. Lokale SEO-basis vanaf dag één.",
    branches: 'Aannemers, schilders, stukadoors, elektriciens, hoveniers, timmermannen, schoorsteenvegers en tuinmannen.',
  },
  {
    title: 'Gezondheid en coaching',
    accent: 'var(--color-teal, #00807d)',
    body: 'Je verkoopt een aanpak, geen product. Die moet rust en vertrouwen uitstralen. Methode helder, aanbod overzichtelijk en een laagdrempelige intake. Vertrouwen wekken is hier het halve werk.',
    branches: "Personal trainers, coaches, yogastudio's en (massage)therapeuten.",
  },
  {
    title: 'Beauty en lifestyle',
    accent: 'var(--accent-primary, #6901aa)',
    body: 'Hier beslist iemand binnen seconden, vaak op de telefoon. Strakke portfolio, echte reviews en een boekingsoptie zonder drempel. Snel op mobiel, met visuals die je werk laten spreken.',
    branches: 'Kappers, nagelstylisten, tattoo artists en schoonheidsspecialisten.',
  },
  {
    title: 'Creatief en dienstverlening',
    accent: 'var(--accent-highlight, #f5c518)',
    body: "De eerste indruk is je hele pitch. Sterke beeldtaal, duidelijke dienstenpagina's en ruimte voor je verhaal. Flexibel uitbreidbaar met cases of een blog als je site moet meegroeien.",
    branches: 'Fotografen, ontwerpers, consultants en kleine bureaus.',
  },
];

/* === FAQ — bestaande items + vijf nieuwe longtail-vragen (achteraan)
   plus link in de "vernieuwen"-vraag naar /website-opfrissen/ en in de
   "Utrecht"-vraag naar /website-laten-maken-utrecht/. */
const faqs = [
  {
    q: "Wat kost een website laten maken als zzp'er?",
    a: `Dat hangt af van wat je nodig hebt. Een one-pager begint rond de €499, een maatwerk-website vanaf €999. Wil je geen investering vooraf, dan kun je kiezen voor het website abonnement vanaf ${pricing.abboFromInline}, inclusief hosting en onderhoud. In een vrijblijvend gesprek bespreken we welke optie past en geven we vooraf een heldere prijs.`,
  },
  {
    q: "Kan ik als zzp'er ook een website abonnement nemen?",
    a: `Ja, juist voor zzp'ers is dat vaak de slimste route. Geen grote investering vooraf, een vast bedrag per maand en hosting, onderhoud en kleine wijzigingen zitten erbij. Het abonnement start vanaf ${pricing.abboFromInline} en is maandelijks opzegbaar na drie maanden.`,
  },
  {
    q: 'Wat is het verschil tussen een goedkope en een professionele zzp-website?',
    a: 'Voor een paar honderd euro kun je ergens een site laten bouwen. Prima als je alleen een digitaal visitekaartje nodig hebt. Wil je professioneel overkomen, lokaal gevonden worden en later kunnen uitbreiden, dan is de basis belangrijker dan alleen de laagste prijs. Denk aan snelheid, mobiele ervaring, structuur, goede teksten en structureel onderhoud.',
  },
  {
    q: "Is een one-page website genoeg voor een zzp'er?",
    a: 'Vaak wel. Als je vooral professioneel wilt overkomen wanneer iemand je naam googelt, of een aanvraag mogelijk wilt maken, dan is een goed gebouwde one-pager prima. Wil je op meerdere diensten of plaatsen lokaal gevonden worden, dan is een uitgebreidere site met aparte pagina\'s slimmer.',
  },
  {
    q: "Kan mijn website later worden uitgebreid met SEO-pagina's?",
    a: "Zeker. We bouwen flexibel: starten met een one-pager of compacte site kan, en later breiden we uit met dienst- of locatiepagina's zodra je lokaal beter gevonden wilt worden. Geen opnieuw beginnen, gewoon doorbouwen op dezelfde basis.",
  },
  {
    q: "Maken jullie ook websites voor startende zzp'ers?",
    a: "Ja. Veel startende zzp'ers kiezen voor het abonnement of een compacte one-pager: snel professioneel online zonder grote investering vooraf. We denken mee over wat je wel en nog niet nodig hebt.",
  },
  {
    q: 'Is WordPress of Astro beter voor mijn zzp-website?',
    a: 'Dat hangt af van wat je site moet doen. WordPress is fijn als je vaak zelf content wilt aanpassen en bloggen. Astro is razendsnel en ideaal voor sites die vooral moeten presteren in Google en op mobiel. We adviseren wat past bij jouw situatie en doelen.',
  },
  {
    q: "Word ik goed gevonden in Google als zzp'er?",
    a: 'We bouwen je site met een lokale SEO-basis. Dat betekent een sterke technische basis, snelle laadtijd en koppeling met je Google Business-profiel, zodat je in jouw regio en branche beter gevonden wordt op zoekopdrachten als "loodgieter Utrecht" of "personal trainer Haarlem".',
  },
  {
    q: 'Ik heb weinig tijd. Hoeveel moet ik zelf doen?',
    a: "Je levert wat basisinformatie aan (diensten, logo, eventueel wat foto's), wij doen de rest: ontwerp, techniek, teksten en inrichting. Geen dagenlang puzzelen of zelf alles schrijven.",
  },
  {
    q: 'Regelen jullie ook hosting en e-mail?',
    a: 'Ja. Domeinnaam, snelle hosting en professionele e-mailadressen (zoals info@jouwbedrijf.nl) regelen we. Wil je je mail koppelen aan Gmail of Outlook? Ook dat doen we voor je.',
  },
  {
    q: 'Ik heb al werk via-via. Heb ik dan wel een website nodig?',
