---
/**
 * SEO-landingspagina /website-laten-maken-zzp/.
 *
 * Focus: zzp-zoekintentie. MKB komt zijdelings voor maar is bewust geen
 * hoofdpositionering. De pagina is uniek opgebouwd (custom Astro-page,
 * niet via de services-collection) zodat we vrij blokken kunnen schikken
 * en achtergrondkleuren kunnen afwisselen voor visueel ritme.
 *
 * Sectievolgorde (afwisselend licht/donker/teal):
 *   1. Hero (cream)               - visuele "h1" als div
 *   2. LogosTicker
 *   3. Echte h1 + lead (cream)
 *   4. Prijs/keuze - 3 cards      (cream-deep)
 *   5. USPs - 4 cards             (cream)
 *   6. Wanneer is het waard?      (donkerpaars + grid)
 *   7. Showcase (cases)
 *   8. Comparison "Zelf vs laten maken?"
 *   9. CalvinNote
 *  10. Segments - 4 grouped cards (cream)
 *  11. Goedkoop vs klanten        (teal)
 *  12. Vakman CTA                 (donker)
 *  13. BetterCallCalvin
 *  14. FAQ
 *
 * Pagina is bewust niet in het hoofdmenu opgenomen.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Topbar from '@components/layout/Topbar.astro';
import Nav from '@components/layout/Nav.astro';
import Footer from '@components/layout/Footer.astro';
import EyebrowPill from '@components/ui/EyebrowPill.astro';
import ReviewAvatars from '@components/ui/ReviewAvatars.astro';
import SectionIcon from '@components/ui/SectionIcon.astro';
import LogosTicker from '@components/sections/LogosTicker.astro';
import WebsitesShowcase from '@components/sections/WebsitesShowcase.astro';
import CalvinNote from '@components/sections/CalvinNote.astro';
import BetterCallCalvin from '@components/sections/BetterCallCalvin.astro';
import Comparison from '@components/sections/Comparison.astro';
import FAQ from '@components/sections/FAQ.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { review, pricing, contact } from '@data/site-config';
import heroMockup from '@assets/hero/website-laten-maken-zzp-hero.webp';

const pageTitle = "Website laten maken als zzp'er | Vanaf €89/m | Froseo";
const pageDesc =
  `Laat als zzp'er een professionele website maken die snel laadt, vertrouwen wekt en klaar is voor Google. Kies maatwerk of een all-in website abonnement vanaf ${pricing.abboFromInline}.`;

/* Cases voor de showcase - handmatig geselecteerd. */
const allCases = await getCollection('cases', ({ data }) => data.published !== false);
const showcaseSlugs = [
  'renovatie-totaal',
  'club12',
  'prime-performance',
  'steunder',
  'studio-contenido',
  'theo-mackaay',
];
const showcaseCases = showcaseSlugs
  .map((slug) => allCases.find((c) => c.data.slug === slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

/* Drie prijs/keuze-routes. Abonnement bewust eerst (vaakst gekozen). */
const priceOptions = [
  {
    name: 'Website abonnement',
    forWhom: 'Geen investering vooraf, alles geregeld',
    price: `Vanaf ${pricing.abboFromInline}`,
    description: "Een professionele site voor een vast maandbedrag. Hosting, technisch beheer en kleine wijzigingen zitten erbij. Geen opstartkosten en maandelijks opzegbaar na drie maanden.",
    cta: { label: 'Bekijk het abonnement', href: '/website-abonnement/' },
    featured: true,
  },
  {
    name: 'One-pager website',
    forWhom: "Startende zzp'er, professioneel online",
    price: 'Vanaf €499',
    description: "Een strakke, snelle one-pager die professioneel overkomt zodra iemand je naam googelt. Modern design, gericht op conversie.",
    cta: { label: 'Vraag een offerte aan', href: '/contact/?onderwerp=zzp-onepager' },
  },
  {
    name: 'Maatwerk website',
    forWhom: "Zzp'er met meerdere diensten of lokale ambitie",
    price: 'Vanaf €1499',
    description: "Maatwerk met aparte dienstenpagina's, sterke structuur en lokale SEO-basis. Klaar om mee te groeien naarmate je bedrijf groeit.",
    cta: { label: 'Bekijk maatwerk webdesign', href: '/webdesign/' },
  },
];

/* Wanneer is een zzp-website de investering waard? - korte checks. */
const investmentWorth = [
  'Klanten je eerst online checken voordat ze contact opnemen.',
  'Je afhankelijk bent van aanvragen uit je regio.',
  'Je niet alleen via-via gevonden wilt worden.',
  'Je je diensten beter wilt uitleggen dan op social media past.',
  'Je betrouwbaar wilt overkomen naast je concurrenten.',
  'Je Google wilt gebruiken als structureel kanaal voor nieuwe klanten.',
];

/* USPs - vier korte cards. */
const usps = [
  {
    icon: 'shieldCheck',
    title: 'Google Proof',
    body: "Elke site wordt Google Proof opgeleverd, klaar om lokaal gevonden te worden. Goede techniek, snelle pagina's en de juiste structuur zitten er vanaf de basis in.",
  },
  {
    icon: 'locationPin',
    title: 'Lokaal vindbaar',
    body: "Als zzp'er richt je je vaak op je eigen regio. We zorgen dat je in jouw plaats en branche bovenaan in Google opduikt.",
  },
  {
    icon: 'paletteSwatch',
    title: 'Huisstijl en design',
    body: 'Je logo en huisstijl horen bij je online identiteit. Hulp nodig met het ontwerp? We denken graag mee.',
  },
  {
    icon: 'toolbox',
    title: 'Full-service',
    body: 'Van webdesign tot onderhoud: we nemen alles uit handen. Alleen een nieuwe website nodig? Ook prima.',
  },
];

/* Comparison: zelf maken vs laten maken. */
const comparison = {
  title: 'Zelf maken of je zzp-website',
  titleAccent: 'laten maken?',
  withoutLabel: 'Zelf maken',
  withLabel: 'Door Froseo laten maken',
  items: [
    { without: 'Goedkoop starten', with: 'Vanaf dag één professioneel oogt' },
    { without: 'Veel zelf uitzoeken en aanmodderen', with: 'Wij regelen het, jij houdt tijd over voor je werk' },
    { without: 'Prima voor een simpele start', with: 'Betere basis voor SEO en conversie' },
    { without: 'Vaak beperkt maatwerk', with: 'Flexibeler uit te breiden naarmate je groeit' },
    { without: 'Kost vooral je eigen tijd', with: 'Kost geld, maar bespaart tijd en gedoe' },
  ],
};

/* Branches: vier groepen i.p.v. 18 losse accordions. */
const segments = [
  {
    title: 'Vakmensen',
    branches: 'Dakdekkers, aannemers, loodgieters, schilders, stukadoors, installateurs, schoorsteenvegers, timmermannen, elektriciens, tuinmannen en hoveniers.',
    body: "Snelle, mobiel-eerst sites met offerteformulieren, een klikbaar telefoonnummer en lokale SEO. Klanten zoeken vakmensen vaak met spoed en op de telefoon. Daar bouwen we op.",
  },
  {
    title: 'Gezondheid en coaching',
    branches: "Personal trainers, coaches, yogastudio's en (massage)therapeuten.",
    body: 'Sites die rust uitstralen, je aanpak en aanbod helder tonen en bezoekers een laagdrempelige intake aanbieden. Vertrouwen wekken is hier het halve werk.',
  },
  {
    title: 'Beauty en lifestyle',
    branches: 'Kappers, nagelstylisten, tattoo artists en schoonheidsspecialisten.',
    body: "Visuele sites die je werk laten spreken: strakke portfolio, reviews en een eenvoudige boekingsoptie. Klanten beslissen vaak binnen seconden op mobiel.",
  },
  {
    title: 'Creatief en dienstverlening',
    branches: 'Fotografen, ontwerpers, consultants en kleine bureaus.',
    body: "Sites met sterke beeldtaal, duidelijke dienstenpagina's en ruimte voor je verhaal en je werk. Past bij zzp'ers waar de eerste indruk telt.",
  },
];

const faqs = [
  {
    q: "Wat kost een website laten maken als zzp'er?",
    a: `Dat hangt af van wat je nodig hebt. Een one-pager begint rond de €499, een maatwerk-website vanaf €1499. Wil je geen investering vooraf, dan kun je kiezen voor het website abonnement vanaf ${pricing.abboFromInline}, inclusief hosting en onderhoud. In een vrijblijvend gesprek bespreken we welke optie het beste past en geven we vooraf een heldere prijs.`,
  },
  {
    q: "Kan ik als zzp'er ook een website abonnement nemen?",
    a: `Ja, juist voor zzp'ers is dat vaak de slimste route. Geen grote investering vooraf, een vast bedrag per maand en hosting, onderhoud en kleine wijzigingen zitten erbij. Het abonnement start vanaf ${pricing.abboFromInline} en is maandelijks opzegbaar na drie maanden.`,
  },
  {
    q: "Is een one-page website genoeg voor een zzp'er?",
    a: 'Vaak wel. Als je vooral professioneel wilt overkomen wanneer iemand je naam googelt, of een aanvraag mogelijk wilt maken, dan is een goed gebouwde one-pager prima. Wil je op meerdere diensten of plaatsen lokaal gevonden worden, dan is een uitgebreidere site met aparte pagina\'s slimmer.',
  },
  {
    q: "Kan mijn website later worden uitgebreid met SEO-pagina's?",
    a: "Zeker. We bouwen flexibel: starten met een one-pager of compacte site kan, en later breiden we uit met dienst- of locatiepagina's zodra je lokaal beter gevonden wilt worden. Geen opnieuw beginnen, gewoon doorbouwen op dezelfde basis.",
  },
  {
    q: "Maken jullie ook websites voor startende zzp'ers?",
    a: "Ja. Veel startende zzp'ers kiezen voor het abonnement of een compacte one-pager: snel professioneel online zonder grote investering vooraf. We denken mee over wat je wel en nog niet nodig hebt.",
  },
  {
    q: 'Is WordPress of Astro beter voor mijn zzp-website?',
    a: 'Dat hangt af van wat je site moet doen. WordPress is fijn als je vaak zelf content wilt aanpassen en bloggen. Astro is razendsnel en ideaal voor sites die vooral moeten presteren in Google en op mobiel. We adviseren wat past bij jouw situatie en doelen.',
  },
  {
    q: "Word ik goed gevonden in Google als zzp'er?",
    a: 'Jazeker. We bouwen je site met lokale SEO als basis. Dat betekent dat je goed scoort op zoekopdrachten als "loodgieter Utrecht" of "personal trainer Haarlem". We zorgen voor een sterke technische basis, snelle laadtijd en koppeling met je Google Business-profiel.',
  },
  {
    q: 'Ik heb weinig tijd. Hoeveel moet ik zelf doen?',
    a: "Je levert wat basisinformatie aan (diensten, logo, eventueel wat foto's), wij doen de rest: ontwerp, techniek, teksten en inrichting. Geen dagenlang puzzelen of zelf alles schrijven.",
  },
  {
    q: 'Regelen jullie ook hosting en e-mail?',
    a: 'Ja. Domeinnaam, snelle hosting en professionele e-mailadressen (zoals info@jouwbedrijf.nl) regelen we. Wil je je mail koppelen aan Gmail of Outlook? Ook dat doen we voor je.',
  },
  {
    q: 'Ik heb al werk via-via. Heb ik dan wel een website nodig?',
    a: 'Ook dan is een site slim. Veel mensen kijken eerst online of iemand betrouwbaar overkomt voordat ze contact opnemen. Daarnaast helpt het je voorbereid te zijn op rustigere periodes.',
  },
];

const waUrl = `https://wa.me/${contact.whatsappNumber}?text=${encodeURIComponent(contact.whatsappMessage)}`;
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <Topbar />
  <Nav />
  <main>
    <article class="zzp-page">

      <!-- ============================================================
           HERO - visuele "h1" als div, echte <h1> volgt lager.
           ============================================================ -->
      <section class="service-hero has-image">
        <div class="service-hero-inner">
          <div class="service-hero-text">
            <EyebrowPill>Voor zzp'ers</EyebrowPill>
            <div class="service-hero-title">
              Een professionele zzp-website, <em>zonder gedoe.</em>
            </div>
            <p class="service-hero-lead">
              Snel online, vertrouwen wekkend en klaar om aanvragen op te leveren. Wij bouwen je website, jij blijft je werk doen.
            </p>
            <ul class="service-hero-checks">
              <li>Betaalbaar maatwerk of all-in <a href="/website-abonnement/">website abonnement</a> vanaf {pricing.abboFromShort}</li>
              <li>Sterke structuur, snelle techniek en <a href="/lokale-seo/">lokale SEO</a>-basis</li>
              <li>Wij regelen design, teksten, hosting en onderhoud</li>
            </ul>
            <div class="service-hero-actions">
              <a class="btn-primary" href="/contact/?onderwerp=zzp-website">Bespreek mijn zzp-website ↗</a>
              <a class="btn-ghost" href="#cases">Bekijk voorbeelden ↓</a>
            </div>
            <div class="service-hero-reviews reviews-inline">
              <ReviewAvatars />
              <div class="stars">★★★★★</div>
              <span><strong>{review.ratingDisplay}</strong> · Google reviews</span>
            </div>
          </div>

          <div class="service-hero-media">
            <Image
              src={heroMockup}
              alt="Website laten maken voor zzp'er door Froseo: Steunder op desktop, Prime Performance op mobiel"
              title="Website laten maken voor zzp'er door Froseo: Steunder op desktop, Prime Performance op mobiel"
              class="service-hero-img"
              widths={[640, 960, 1280, 1600]}
              sizes="(max-width: 1024px) 100vw, 640px"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>
      </section>

      <LogosTicker />

      <!-- ============================================================
           Echte <h1> + intro-lead (compact, lager op de pagina).
           ============================================================ -->
      <section class="zzp-intro">
        <div class="zzp-intro-inner">
          <EyebrowPill variant="rare">Voor zzp'ers</EyebrowPill>
          <h1 class="zzp-intro-h1">Website laten maken als <em>zzp'er</em></h1>
          <p class="zzp-intro-lead">
            Je bent hier waarschijnlijk omdat je een site wilt die professioneel oogt, klanten oplevert en niet te veel gedoe geeft. We bouwen sites die daar precies op gericht zijn: snel, vindbaar en passend bij wat jij doet. Geen vage bureau-praat, wel een eerlijk gesprek over wat je echt nodig hebt.
          </p>
        </div>
      </section>

      <!-- ============================================================
           PRIJS/KEUZE - drie kaarten (cream-deep achtergrond).
           ============================================================ -->
      <section class="zzp-price">
        <div class="zzp-price-inner">
          <div class="zzp-price-head">
            <EyebrowPill>Drie routes</EyebrowPill>
            <h2 class="zzp-price-title">Wat kost een website laten maken als <em>zzp'er?</em></h2>
            <p class="zzp-price-lead">
              Welke route slim is, hangt af van waar je staat. Wil je geen investering vooraf? Het abonnement. Wil je betaalbaar professioneel online voor een eerste indruk? Een one-pager. Wil je echt lokaal gevonden worden op meerdere diensten? Maatwerk.
            </p>
          </div>
          <div class="zzp-price-grid">
            {priceOptions.map((opt) => (
              <article class={`zzp-price-card${opt.featured ? ' is-featured' : ''}`}>
                {opt.featured && <span class="zzp-price-badge">Meest gekozen door zzp'ers</span>}
                <h3 class="zzp-price-name">{opt.name}</h3>
                <p class="zzp-price-for">{opt.forWhom}</p>
                <div class="zzp-price-amount">{opt.price}</div>
                <p class="zzp-price-desc">{opt.description}</p>
                <a class={opt.featured ? 'btn-primary' : 'btn-ghost'} href={opt.cta.href}>{opt.cta.label} ↗</a>
              </article>
            ))}
          </div>
          <p class="zzp-price-note">
            Twijfel je tussen de routes? Stuur een korte mail of <a href={waUrl} target="_blank" rel="noopener noreferrer">WhatsApp</a>, dan kijken we vrijblijvend mee.
          </p>
        </div>
      </section>

      <!-- ============================================================
           USPs - vier korte cards.
           ============================================================ -->
      <section class="zzp-usps">
        <div class="zzp-usps-inner">
          <div class="zzp-usps-grid">
            {usps.map((u) => (
              <article class="zzp-usp-card">
                <SectionIcon name={u.icon} class="zzp-usp-icon" size={44} />
                <h3 class="zzp-usp-title">{u.title}</h3>
                <p class="zzp-usp-body">{u.body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- ============================================================
           Wanneer is het de investering waard? - donker blok + grid.
           ============================================================ -->
      <section class="zzp-worth">
        <div class="zzp-worth-inner">
          <EyebrowPill variant="highlight">Wanneer wel, wanneer niet</EyebrowPill>
          <h2 class="zzp-worth-title">Wanneer is een zzp-website de <em>investering waard?</em></h2>
          <ul class="zzp-worth-list">
            {investmentWorth.map((item) => (
              <li><span class="zzp-worth-check" aria-hidden="true">✓</span><span>{item}</span></li>
            ))}
          </ul>
          <p class="zzp-worth-after">
            Voor sommige zzp'ers is een digitaal visitekaartje al genoeg. Voor anderen is de website het belangrijkste verkoopkanaal. Daarom bouwen we niet één standaardpakket voor iedereen, maar kijken we naar wat jouw bedrijf nodig heeft.
          </p>
        </div>
      </section>

      <!-- ============================================================
           SHOWCASE - cases als proof.
           ============================================================ -->
      <div id="cases">
        <WebsitesShowcase
          cases={showcaseCases}
          eyebrow="Voorbeelden"
          title="Websites die we maakten voor"
          titleAccent="zzp'ers en kleine bedrijven."
        />
      </div>

      <!-- ============================================================
           COMPARISON - zelf maken of laten maken.
           ============================================================ -->
      <Comparison
        title={comparison.title}
        titleAccent={comparison.titleAccent}
        withoutLabel={comparison.withoutLabel}
        withLabel={comparison.withLabel}
        items={comparison.items}
      />
      <section class="zzp-compare-after">
        <p>
          Twijfel je? We denken eerlijk mee. Soms is zelf starten prima. Maar als je site klanten moet overtuigen of lokaal vindbaar moet worden, is professioneel laten maken meestal slimmer.
        </p>
      </section>

      <!-- ============================================================
           CALVIN NOTE
           ============================================================ -->
      <CalvinNote
        message="Twijfel je welke route past, of past het abonnement bij jouw situatie? Stuur even wat je hebt staan, dan kijken we mee en geven we eerlijk advies."
        ctaLabel="Vraag advies aan ↗"
        ctaHref="/contact/?onderwerp=zzp-website-advies"
      />

      <!-- ============================================================
           SEGMENTS - vier gegroepeerde categorie-cards.
           ============================================================ -->
      <section class="zzp-segments">
        <div class="zzp-segments-inner">
          <div class="zzp-segments-head">
            <EyebrowPill variant="rare">Voor welke zzp'ers</EyebrowPill>
            <h2 class="zzp-segments-title">Voor welke zzp'ers maken we <em>websites?</em></h2>
            <p class="zzp-segments-lead">
              Eigenlijk voor elke zzp'er die professioneel online wil zijn. Een greep uit ons werk:
            </p>
          </div>
          <div class="zzp-segments-grid">
            {segments.map((s) => (
              <article class="zzp-segment-card">
                <h3 class="zzp-segment-title">{s.title}</h3>
                <p class="zzp-segment-branches">{s.branches}</p>
                <p class="zzp-segment-body">{s.body}</p>
              </article>
            ))}
          </div>
          <p class="zzp-segments-after">
            Staat je vak hier niet bij? Geen probleem. Stuur even een berichtje, dan kijken we mee.
            <a href="/portfolio/">Bekijk ook ons portfolio ↗</a>
          </p>
        </div>
      </section>

      <!-- ============================================================
           Goedkoop vs klanten - teal band.
           ============================================================ -->
      <section class="zzp-cheap">
        <div class="zzp-cheap-inner">
          <EyebrowPill variant="highlight">Wat krijg je voor je geld?</EyebrowPill>
          <h2 class="zzp-cheap-title">Goedkope zzp-website of een website die <em>klanten oplevert?</em></h2>
          <p class="zzp-cheap-body">
            Voor een paar honderd euro kun je ergens een site laten bouwen. Prima als je alleen een digitaal visitekaartje nodig hebt. Wil je professioneel overkomen, goed gevonden worden en later kunnen uitbreiden, dan is de basis belangrijker dan alleen de laagste prijs. Denk aan snelheid, mobiele ervaring, <a href="/lokale-seo/">lokale SEO</a>, duidelijke dienstenpagina's, goede teksten en <a href="/website-onderhoud/">structureel onderhoud</a>.
          </p>
        </div>
      </section>

      <!-- ============================================================
           Vakman CTA - donker afsluitblok.
           ============================================================ -->
      <section class="zzp-vakman-cta">
        <div class="zzp-vakman-cta-inner">
          <h2 class="zzp-vakman-cta-title">Als vakman of vakvrouw door ons je <em>website laten maken?</em></h2>
          <p class="zzp-vakman-cta-body">
            Dakdekker, kapper, coach, personal trainer of iets daartussenin: we kijken graag mee wat past bij jouw bedrijf. Een mailtje of WhatsApp is genoeg om te beginnen.
          </p>
          <div class="zzp-vakman-cta-actions">
            <a class="btn-primary" href="/contact/?onderwerp=zzp-website">Neem contact op ↗</a>
            <a class="btn-ghost" href={waUrl} target="_blank" rel="noopener noreferrer">Of via WhatsApp ↗</a>
          </div>
        </div>
      </section>

      <BetterCallCalvin
        eyebrow="Tijd voor een kennismaking?"
        titleLine1="Plan een korte"
        titleAccent="kennismaking."
        body={[
          'Een mailtje, een WhatsApp of een gesprek van 30 minuten: jij bepaalt hoe laagdrempelig we beginnen.',
          'Geheel vrijblijvend. Past het niet, dan zeggen we dat eerlijk.',
        ]}
        primaryLabel="Plan een afspraak ↗"
        primaryHref="/contact/?onderwerp=zzp-website"
      />
    </article>

    <FAQ
      eyebrow="Veelgestelde vragen"
      titleLine1="Vragen over een website laten maken als"
      titleAccent="zzp'er."
      items={faqs}
    />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ============================================================
     Echte H1 + intro-lead - compact blok na de hero.
     ============================================================ */
  .zzp-intro { padding: clamp(2rem, 4vw, 3rem) var(--gutter, 1.5rem); }
  .zzp-intro-inner {
    max-width: 60rem;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
  }
  .zzp-intro-h1 {
    font-family: var(--font-display, sans-serif);
    font-weight: 800;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    line-height: 1.15;
    margin: 0;
  }
  .zzp-intro-h1 em { color: var(--accent-primary); font-style: normal; }
  .zzp-intro-lead {
    line-height: 1.65;
    color: var(--text-muted, #555);
    max-width: 50rem;
    margin: 0;
  }

  /* ============================================================
     Prijs/keuze - drie kaarten op een dieper-cream vlak.
     ============================================================ */
  .zzp-price {
    background: var(--surface-page-deep);
    padding: clamp(3rem, 6vw, 5rem) var(--gutter, 1.5rem);
  }
  .zzp-price-inner { max-width: var(--container-max, 1200px); margin: 0 auto; }
