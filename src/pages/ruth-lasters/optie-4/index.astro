---
import RuthDemoLayout from "../../../layouts/RuthDemoLayout.astro";
import RuthSwitcher from "../../../components/RuthSwitcher.astro";

/* ──────────────────────────────────────────────────────────────────────────
   OPTIE 4 — "Salon"
   Klassiek-elegante hero in resort-stijl: full-bleed video in kleur op de
   achtergrond, transparante menubalk die bij scroll donker wordt, gecentreerde
   titel met geschreven serif (Cormorant Garamond). Lichtere, professionele
   kleurcombi die bij de video past: warm bot/crème, diep dusky-blue als donkere
   ankers, terracotta-accent (volwassen echo van de rode boeken) en stoffig
   lucht-blauw. Opbouw is een variant op optie 2, niet identiek.
   Het filmpje komt verderop nog terug als klein rond "badge" (speels, herkenbaar).
   ────────────────────────────────────────────────────────────────────────── */

const img = (seed: string, w = 1400, h = 1000) =>
  `https://picsum.photos/seed/${seed}/${w}/${h}`;

const oeuvre = [
  { title: "Tijgerbrood", year: "2023", genre: "Poëzie", seed: "rl4-tijgerbrood" },
  { title: "VIN", year: "2019", genre: "Proza", seed: "rl4-vin" },
  { title: "Lichtmeters", year: "2015", genre: "Poëzie", seed: "rl4-lichtmeters" },
  { title: "Vlaggenbrief", year: "2014", genre: "Proza", seed: "rl4-vlaggenbrief" },
  { title: "Vouwplannen", year: "2007", genre: "Poëzie", seed: "rl4-vouwplannen" },
  { title: "Poolijs", year: "2006", genre: "Roman", seed: "rl4-poolijs" },
];

const prijzen = [
  { jaar: "2023", naam: "Arkprijs van het Vrije Woord" },
  { jaar: "2022", naam: "Melopee Poëzieprijs" },
  { jaar: "2022", naam: "Poëziewedstrijd der Lage Landen" },
  { jaar: "2015", naam: "Herman de Coninckprijs" },
  { jaar: "2009", naam: "Debuutprijs Het Liegend Konijn" },
  { jaar: "2007", naam: "Vlaamse Debuutprijs" },
];

const agenda = [
  { datum: "24 okt", plaats: "Poetry International, Rotterdam", soort: "Voordracht" },
  { datum: "08 nov", plaats: "Passa Porta, Brussel", soort: "Gesprek" },
  { datum: "21 nov", plaats: "Boekenbeurs, Antwerpen", soort: "Signeersessie" },
  { datum: "maart ’26", plaats: "Éditions Corlevour, Parijs", soort: "Boekpresentatie" },
];
---

<RuthDemoLayout title="Ruth Lasters — optie 4 (Salon)" bg="#f4f0e8" ink="#20262a">
  <!-- ══════════════════════ HEADER (transparant → donker bij scroll) ══════════════════════ -->
  <header class="head" id="head">
    <div class="head__bar">
      <a href="#nav" class="head__menu" aria-label="Menu">
        <span class="head__menu-icon"></span> Menu
      </a>
      <div class="head__center">
        <a href="#top" class="head__brand">Ruth Lasters</a>
      </div>
      <a href="#contact" class="head__book">Nieuwsbrief</a>
    </div>
    <nav class="head__nav" id="nav" aria-label="Hoofdmenu">
      <a href="#oeuvre">Boeken</a>
      <a href="#onderwijs">Onderwijs</a>
      <a href="#werk">Werk</a>
      <a href="#over">Over</a>
      <a href="#agenda">Agenda</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <!-- ══════════════════════ HERO (full-color video) ══════════════════════ -->
  <section class="hero" id="top">
    <video class="hero__video" autoplay muted loop playsinline preload="auto">
      <source src="/ruth-demo/hero.mp4" type="video/mp4" />
    </video>
    <div class="hero__veil"></div>

    <div class="hero__content">
      <p class="hero__kicker">Dichter · auteur · leerkracht</p>
      <h1 class="hero__title">Ruth Lasters</h1>
      <p class="hero__sub">The Inconvenient Ruth</p>
    </div>

    <a href="#intro" class="hero__scroll" aria-label="Scroll naar beneden">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M6 9l6 6 6-6" />
      </svg>
    </a>
  </section>

  <!-- ══════════════════════ INTRO (twee kolommen + video-badge) ══════════════════════ -->
  <section class="intro" id="intro">
    <div class="intro__inner">
      <div class="intro__lead reveal">
        <span class="eyebrow">Welkom</span>
        <h2 class="intro__title">Taal die<br /><em>niet sust.</em></h2>
        <span class="intro__badge" aria-hidden="true">
          <video autoplay muted loop playsinline preload="auto">
            <source src="/ruth-demo/hero.mp4" type="video/mp4" />
          </video>
        </span>
      </div>
      <div class="intro__body reveal">
        <p>
          Ik schrijf alsof taal nog iets te verliezen heeft. Sinds mijn debuut
          <em>Poolijs</em> laat ik poëzie, roman en pamflet door elkaar lopen.
        </p>
        <p>
          Het leverde me een paar prijzen op, en ooit een breuk met de stad
          Antwerpen, toen die mijn gedicht over onderwijs-elitisme niet wilde
          publiceren. Ik geef nog altijd les. Dat hoor je in alles wat ik maak.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════ FEATURE — Désirs à l'essai ══════════════════════ -->
  <section class="feature" id="werk">
    <div class="feature__media reveal">
      <img src={img("rl4-french", 1200, 1500)} alt="Sfeerbeeld nieuwe bundel" loading="lazy" />
      <span class="feature__year">2026</span>
    </div>
    <div class="feature__body reveal">
      <span class="eyebrow">Voor het eerst in het Frans</span>
      <h2 class="feature__title">Désirs à l’essai</h2>
      <p>
        Een ruime keuze uit mijn drie Nederlandstalige bundels, vertaald door
        Daniel Cunin en uitgegeven door Éditions Corlevour. Mijn werk verscheen
        al in het Duits en het Spaans; in maart 2026 komt het Frans erbij.
      </p>
      <dl class="feature__facts">
        <div><dt>Vertaling</dt><dd>Daniel Cunin</dd></div>
        <div><dt>Uitgever</dt><dd>Éditions Corlevour</dd></div>
        <div><dt>Presentatie</dt><dd>Parijs, maart 2026</dd></div>
      </dl>
      <a href="#agenda" class="link-arrow">Naar de presentatie <span>→</span></a>
    </div>
  </section>

  <!-- ══════════════════════ OEUVRE ══════════════════════ -->
  <section class="oeuvre" id="oeuvre">
    <div class="section-head reveal">
      <span class="eyebrow">Mijn boeken</span>
      <h2 class="section-head__title">Wat ik tot nu toe schreef.</h2>
    </div>
    <div class="oeuvre__grid">
      {oeuvre.map((b, i) => (
        <article class="book reveal">
          <a href="#" class="book__cover">
            <img src={img(b.seed, 700, 900)} alt={`Cover ${b.title}`} loading="lazy" />
            <span class="book__no">{String(i + 1).padStart(2, "0")}</span>
          </a>
          <div class="book__foot">
            <div>
              <h3 class="book__title">{b.title}</h3>
              <span class="book__genre">{b.genre}</span>
            </div>
            <span class="book__year">{b.year}</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ══════════════════════ ONDERWIJS — donker dusky-blue anker ══════════════════════ -->
  <section class="bord" id="onderwijs">
    <div class="bord__bg">
      <img src={img("rl4-classroom", 2000, 1300)} alt="Lege klas" loading="lazy" />
    </div>
    <div class="bord__inner reveal">
      <span class="eyebrow eyebrow--clay">Het project</span>
      <h2 class="bord__title">Mevrouw, u staat voor het bord!</h2>
      <p class="bord__lede">
        Ik geef les én ik schrijf over de burn-outgolf die het onderwijs
        teistert. Toen Antwerpen mijn gedicht over kansenongelijkheid weigerde,
        legde ik het stadsdichterschap neer. De pen bleek scherper dan het ambt.
      </p>
      <blockquote class="bord__quote">
        Een school die haar zwakste leerling laat vallen, valt zelf.
      </blockquote>
      <a href="#" class="btn btn--clay">Lees mijn blog</a>
    </div>
  </section>

  <!-- ══════════════════════ OVER MIJ ══════════════════════ -->
  <section class="about" id="over">
    <div class="about__text reveal">
      <span class="eyebrow">Over mij</span>
      <h2 class="about__title">Antwerpen, 1979.<br />En nog altijd voor de klas.</h2>
      <p>
        Ik debuteerde in 2006 met de roman <em>Poolijs</em>, een jaar later
        volgde mijn poëziedebuut <em>Vouwplannen</em>. Sindsdien wissel ik romans
        en dichtbundels af. Het persoonlijke en het maatschappelijke houd ik
        daarin niet gescheiden.
      </p>
      <p>
        Naast het schrijven sta ik voor de klas. Die twee dingen kleuren elkaar:
        van mijn bundels tot de opiniestukken die ik schrijf over het onderwijs.
      </p>
      <div class="awards">
        <span class="awards__label">Een paar prijzen onderweg</span>
        <ul class="awards__list">
          {prijzen.map((p) => (
            <li>
              <span class="awards__year">{p.jaar}</span>
              <span class="awards__name">{p.naam}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class="about__portrait reveal">
      <img src={img("rl4-portrait", 1100, 1400)} alt="Portret Ruth Lasters" loading="lazy" />
    </div>
  </section>

  <!-- ══════════════════════ AGENDA ══════════════════════ -->
  <section class="agenda" id="agenda">
    <div class="section-head section-head--row reveal">
      <span class="eyebrow">Agenda</span>
      <h2 class="section-head__title">Waar ik binnenkort sta.</h2>
    </div>
    <ul class="agenda__list">
      {agenda.map((a) => (
        <li class="agenda__item reveal">
          <span class="agenda__date">{a.datum}</span>
          <span class="agenda__place">{a.plaats}</span>
          <span class="agenda__kind">{a.soort}</span>
          <span class="agenda__arrow">→</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- ══════════════════════ CONTACT / NEWSLETTER ══════════════════════ -->
  <section class="contact" id="contact">
    <div class="contact__inner reveal">
      <span class="eyebrow eyebrow--clay">Blijf in de buurt</span>
      <h2 class="contact__title">Nieuwe bundels, voordrachten<br />en het scherpe randje.</h2>
      <form class="contact__form" onsubmit="return false">
        <input type="email" placeholder="jouw e-mailadres" aria-label="E-mailadres" required />
        <button type="submit" class="btn btn--clay">Schrijf me in</button>
      </form>
      <p class="contact__fine">
        Voor optredens, lezingen en pers: <a href="mailto:info@ruthlasters.com">info@ruthlasters.com</a>
      </p>
    </div>
  </section>

  <!-- ══════════════════════ FOOTER ══════════════════════ -->
  <footer class="foot">
    <div class="foot__top">
      <span class="foot__brand">Ruth Lasters</span>
      <nav class="foot__nav" aria-label="Footer">
        <a href="#oeuvre">Boeken</a>
        <a href="#onderwijs">Onderwijs</a>
        <a href="#over">Over</a>
        <a href="#agenda">Agenda</a>
        <a href="#contact">Contact</a>
      </nav>
      <div class="foot__social">
        <a href="#" aria-label="Instagram">IG</a>
        <a href="#" aria-label="Facebook">FB</a>
        <a href="#" aria-label="LinkedIn">IN</a>
      </div>
    </div>
    <div class="foot__bottom">
      <span>© {new Date().getFullYear()} Ruth Lasters</span>
      <span class="foot__credit">Demo-ontwerp — Froseo</span>
    </div>
  </footer>

  <RuthSwitcher active="optie4" />

  <script is:inline>
    const head = document.getElementById("head");
    const onScroll = () => head.classList.toggle("head--scrolled", window.scrollY > 40);
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("is-in");
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.16 }
    );
    document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
  </script>
</RuthDemoLayout>

<style>
  /* ════════════ TOKENS ════════════ */
  :root {
    --bone: #f4f0e8;
    --bone-2: #ebe5d8;
    --ink: #20262a;
    --dusk: #1c2c35; /* diep dusky-blue, donkere ankers */
    --dusk-2: #16242c;
    --clay: #b6543f; /* terracotta accent */
    --clay-deep: #9d452f;
    --blue: #6f93a8; /* stoffig lucht-blauw */
    --muted: #8a8478;
    --muted-light: #b9b0a0;
    --line: rgba(32, 38, 42, 0.14);
    --line-light: rgba(244, 240, 232, 0.18);
    --display: "Cormorant Garamond", Georgia, serif;
    --sans: "Inter", system-ui, sans-serif;
    --maxw: 1280px;
    --pad: clamp(1.25rem, 5vw, 5rem);
  }

  /* ════════════ PRIMITIVES ════════════ */
  .eyebrow {
    display: inline-block;
    font-family: var(--sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: 1.3rem;
  }
  .eyebrow--clay {
    color: #e0a08c;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.95rem 1.8rem;
    border-radius: 2px;
    transition: transform 0.25s ease, background 0.25s ease, color 0.25s ease;
  }
  .btn--clay {
    background: var(--clay);
    color: #fff;
  }
  .btn--clay:hover {
    background: var(--clay-deep);
    transform: translateY(-2px);
  }

  .link-arrow {
    font-family: var(--sans);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--clay);
    display: inline-flex;
    gap: 0.6rem;
    align-items: center;
  }
  .link-arrow span {
    transition: transform 0.25s ease;
  }
  .link-arrow:hover span {
    transform: translateX(5px);
  }

  .reveal {
    opacity: 0;
    transform: translateY(26px);
    transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.is-in {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  .section-head {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 var(--pad);
  }
  .section-head__title {
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(2.1rem, 4.6vw, 3.8rem);
    line-height: 1.02;
    letter-spacing: 0;
    max-width: 16ch;
  }
  .section-head--row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .section-head--row .section-head__title {
    max-width: none;
  }

  /* ════════════ HEADER ════════════ */
  .head {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    color: #fff;
    transition: background 0.4s ease, backdrop-filter 0.4s ease;
  }
  .head--scrolled {
    background: rgba(22, 36, 44, 0.92);
    backdrop-filter: blur(14px);
  }
  .head__bar {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 1.15rem var(--pad);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }
  .head__menu {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    justify-self: start;
  }
  .head__menu-icon {
    width: 22px;
    height: 9px;
    border-top: 1px solid currentColor;
    border-bottom: 1px solid currentColor;
    display: inline-block;
  }
  .head__center {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .head__brand {
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(1.3rem, 2vw, 1.7rem);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .head__book {
    justify-self: end;
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .head__nav {
    border-top: 1px solid rgba(255, 255, 255, 0.22);
    display: flex;
    justify-content: center;
    gap: clamp(1.2rem, 3vw, 2.6rem);
    padding: 0.85rem var(--pad);
    font-family: var(--sans);
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: border-color 0.4s ease;
  }
  .head--scrolled .head__nav {
    border-top-color: rgba(255, 255, 255, 0.12);
  }
  .head__nav a {
    opacity: 0.82;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: opacity 0.2s ease, border-color 0.2s ease;
  }
  .head__nav a:hover {
    opacity: 1;
    border-bottom-color: rgba(255, 255, 255, 0.7);
  }
  .head__menu,
  .head__book {
    white-space: nowrap;
  }
  @media (max-width: 760px) {
    .head__nav {
      display: none;
    }
  }

  /* ════════════ HERO ════════════ */
  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-items: center;
    overflow: hidden;
    background: var(--dusk-2);
  }
  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.02) contrast(1.02) brightness(0.9);
  }
  .hero__veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(
        180deg,
        rgba(18, 28, 34, 0.5) 0%,
        rgba(18, 28, 34, 0.2) 30%,
        rgba(18, 28, 34, 0.28) 60%,
        rgba(18, 28, 34, 0.66) 100%
      ),
      radial-gradient(70% 60% at 50% 45%, transparent, rgba(18, 28, 34, 0.4));
  }
  .hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    padding: 0 var(--pad);
  }
  .hero__kicker {
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 1.4rem;
    text-shadow: 0 1px 14px rgba(0, 0, 0, 0.4);
  }
  .hero__title {
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(3.6rem, 11vw, 9.5rem);
    line-height: 0.96;
    letter-spacing: 0.005em;
    text-shadow: 0 2px 38px rgba(0, 0, 0, 0.4);
  }
  .hero__sub {
    font-family: var(--display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.4rem, 3.4vw, 2.5rem);
    color: rgba(255, 255, 255, 0.92);
    margin-top: 0.6rem;
    text-shadow: 0 2px 22px rgba(0, 0, 0, 0.45);
  }
  .hero__scroll {
    position: absolute;
    bottom: 2.2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    width: 64px;
    height: 38px;
    display: grid;
    place-items: center;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.45);
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(4px);
    transition: background 0.25s ease;
    animation: bob 2.2s ease-in-out infinite;
  }
  .hero__scroll:hover {
    background: rgba(255, 255, 255, 0.16);
  }
  @keyframes bob {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 7px); }
  }

  /* ════════════ INTRO ════════════ */
  .intro {
    background: var(--bone);
    padding: clamp(5rem, 12vh, 9rem) 0;
  }
  .intro__inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 var(--pad);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 6rem);
    align-items: center;
  }
  .intro__lead {
    position: relative;
  }
  .intro__title {
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(2.6rem, 6vw, 5rem);
    line-height: 0.98;
    color: var(--ink);
  }
  .intro__title em {
    font-style: italic;
    color: var(--clay);
  }
  .intro__badge {
    position: absolute;
    right: 0;
    top: -1.5rem;
    width: clamp(78px, 9vw, 116px);
    height: clamp(78px, 9vw, 116px);
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid var(--bone);
    box-shadow: 0 14px 34px rgba(32, 38, 42, 0.22);
    transform: rotate(-4deg);
  }
  .intro__badge video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .intro__body p {
    font-family: var(--sans);
    font-weight: 300;
    font-size: clamp(1rem, 1.5vw, 1.18rem);
    line-height: 1.75;
