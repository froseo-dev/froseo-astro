  .lp-check-title em { color: var(--accent-highlight); font-style: normal; }
  .lp-check-lead { font-size: 1.05rem; line-height: 1.6; opacity: 0.9; margin-bottom: 1.5rem; }
  .lp-check-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.9rem; }
