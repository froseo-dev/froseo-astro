  .lp-field { display: grid; gap: 0.35rem; }
  .lp-field > span { font-size: 0.9rem; font-weight: 600; }
  .lp-optional { font-style: normal; font-weight: 400; opacity: 0.6; }
  .lp-field input,
  .lp-field select,
  .lp-field textarea {
