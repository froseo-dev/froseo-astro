  /* Hamburger — alleen onder de breakpoint waar .lp-nav verdwijnt. */
  .lp-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 42px;
    height: 38px;
    padding: 0 9px;
    background: transparent;
    border: 0;
    cursor: pointer;
  }
  .lp-burger span {
    display: block;
