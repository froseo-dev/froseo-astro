---
/**
 * Ads-landingspagina /wordpress-onderhoud.
 *
 * NOINDEX + niet in sitemap (zie astro.config sitemap-filter): puur voor
 * advertentieverkeer, zodat hij niet concurreert met de organische pagina's
 * /website-onderhoud/ en /wordpress-website-onderhoud/.
 *
 * Conversie-opzet:
 *   - Gestripte chrome (donkere mini-header, geen menu) = min uitgangen.
 *   - Hoofd-CTA = "Gratis WordPress-onderhoudscheck" (zacht, laagdrempelig),
 *     formulier lager op de pagina (#check), bereikbaar via hero-knop.
 *   - Pakketten met "Vraag X aan"-knoppen die naar hetzelfde formulier
 *     scrollen (PricingPackages ctaMode="leadform").
 *   - Vertrouwen wordt op de pagina zelf opgebouwd (stats, reviews, pijlers,
 *     vergelijking, FAQ) i.p.v. via een menu naar andere pagina's.
 *
 * Tracking: het formulier pusht `generate_lead` met lead_type
 * `onderhoud-check` (of `onderhoud-pakket` als een pakket is aangeklikt) naar
 * de dataLayer. GA4 vangt dit al op; de aparte Google Ads-conversie
 * ("WordPress onderhoud lead") maak je aan wanneer de campagne live gaat.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import EyebrowPill from '@components/ui/EyebrowPill.astro';
import ReviewAvatars from '@components/ui/ReviewAvatars.astro';
import ReviewBadge from '@components/ui/ReviewBadge.astro';
import StatsRibbon from '@components/sections/StatsRibbon.astro';
import LogosTicker from '@components/sections/LogosTicker.astro';
import BetterCallCalvin from '@components/sections/BetterCallCalvin.astro';
import PainPoints from '@components/sections/PainPoints.astro';
import Comparison from '@components/sections/Comparison.astro';
import PricingPackages from '@components/sections/PricingPackages.astro';
import Testimonial from '@components/sections/Testimonial.astro';
import FAQ from '@components/sections/FAQ.astro';
import { Image } from 'astro:assets';
import { contact, review, social } from '@data/site-config';
import heroImage from '@assets/hero/wordpress-website-onderhoud-hero.webp';
import logoWit from '@assets/brand/froseo-logo-wit.webp';

const pageTitle = 'WordPress onderhoud uitbesteden | Veilig & zorgeloos | Froseo';
const pageDesc =
  'WordPress onderhoud uitbesteden aan specialisten. Updates, backups, beveiliging en snelheid voor een vaste maandprijs. Vraag een gratis WordPress-onderhoudscheck aan.';

/* WhatsApp deep-link (wa.me) — voorkeurskanaal i.p.v. bellen. */
const waUrl = `https://wa.me/${contact.whatsappNumber}?text=${encodeURIComponent(contact.whatsappMessage + ' WordPress onderhoud')}`;

const statsItems = [
  { value: '60+', label: 'WordPress-sites in beheer' },
  { value: '15+', label: 'Jaar WordPress-ervaring' },
  { value: '24/7', label: 'Monitoring op elke site' },
  { value: '€350+', label: 'Aan plug-in-licenties per jaar' },
];

const checkItems = [
  'Laadtijd en Core Web Vitals: hoe snel is je site echt? (via Google PageSpeed)',
  'Veiligheid: draait alles netjes op HTTPS en staat je SSL goed?',
  'Zichtbaar verouderde WordPress-versie of plug-ins.',
  'Een heldere samenvatting in gewone taal, met concreet advies.',
];

const painPoints = [
  {
    stat: '90%',
    title: 'De meeste hacks lopen via oude plug-ins',
    body: 'Verreweg de meeste gehackte WordPress-sites zijn binnengekomen via een plug-in die te lang niet was bijgewerkt. Eén bekend lek dat blijft openstaan is al genoeg.',
  },
  {
    stat: '40%',
    title: 'Een trage site kost je bezoekers',
    body: 'Duurt het laden langer dan drie seconden, dan haakt een groot deel van je bezoekers alweer af. Meestal komt het door zware pagebuilders, plug-ins die niemand meer gebruikt en een database die volloopt.',
  },
  {
    stat: '43%',
    title: 'WordPress wordt het vaakst aangevallen',
    body: 'Bijna de helft van alle websites draait op WordPress. Daardoor is het ook het platform waar aanvallers het eerst aankloppen. Onderhoud is hier geen luxe, maar gewoon nodig.',
  },
  {
    icon: 'alertBurst',
    title: 'Een update kan zomaar iets breken',
    body: 'Automatisch updaten klinkt handig, tot een nieuwe versie je formulier of je paginabouwer omver trekt. Vaak merk je het pas als een klant belt dat het bestelformulier niet werkt.',
  },
  {
    icon: 'archiveStack',
    title: 'Backups waar je niets aan hebt',
    body: 'Veel sites hebben backups die al maanden niet meer goed worden weggeschreven, of die nog nooit zijn teruggezet. Bij een crash kom je daar op het slechtste moment achter.',
  },
  {
    icon: 'chartDown',
    title: 'Langzaam wegzakken in Google',
    body: 'Trage pagina\'s, kapotte links en verouderde code: Google ziet het allemaal. Je posities zakken beetje bij beetje, zonder dat je het aan één ding kunt ophangen.',
  },
];

const comparison = {
  title: 'WordPress zelf bijhouden versus',
  titleAccent: 'het uit handen geven.',
  withoutLabel: 'Zonder Froseo',
  withLabel: 'Met Froseo',
  items: [
    { without: 'Plug-ins draaien al maanden op een verouderde versie', with: 'Elke update gecontroleerd uitgevoerd, met restore-point binnen handbereik' },
    { without: 'Bij een vreemde foutmelding zelf zoeken op fora', with: 'Eén berichtje naar ons en we duiken erin, via mail, telefoon of WhatsApp' },
    { without: 'Een hack wordt pas opgemerkt als Google waarschuwt', with: 'Dagelijkse beveiligingsscan die kwetsbaarheden meldt voordat ze worden uitgebuit' },
    { without: 'Je site wordt elk kwartaal merkbaar trager', with: 'Maandelijkse performance-check en database-optimalisatie houden de boel licht' },
    { without: 'De laatste backup is van een halfjaar terug, of je weet het niet zeker', with: 'Verse backup van afgelopen nacht, off-site opgeslagen, terug te zetten als het moet' },
    { without: 'Voor elke premium plug-in een eigen abonnement en factuur', with: 'Elementor Pro, WP Rocket en Gravity Forms onder ons account, jij betaalt niks extra' },
  ],
};

const faqs = [
  {
    q: 'Wat is WordPress onderhoud precies?',
    a: 'Het up-to-date houden van core, plug-ins en thema\'s, het maken en testen van backups, dagelijks scannen op malware en kwetsbaarheden, uptime en snelheid bewaken en geregeld de database opruimen. Zonder dat onderhoud worden WordPress-sites in de loop van de tijd onveilig, trager en breekbaar bij grote core-updates.',
  },
  {
    q: 'Wat houdt de gratis check in?',
    a: 'We doen een externe check op basis van je URL. Daarbij kijken we onder andere naar snelheid, basisbeveiliging, HTTPS en SSL, zichtbare WordPress-signalen en opvallende technische risico\'s. Voor zaken als backups, exacte versies van je plug-ins en instellingen achter je login hebben we pas toegang nodig wanneer je klant wordt. Je krijgt een eerlijk advies, en blijkt onderhoud nog niet nodig, dan zeggen we dat gewoon.',
  },
  {
    q: 'Wat valt er onder "kleine reparaties"?',
    a: 'Korte fixes als er iets stuk gaat: een plug-in die na een update niet meer werkt, een formulier dat geen mail meer stuurt, een afbeelding die niet laadt of een vreemde foutmelding. Niet inbegrepen: nieuwe pagina\'s, ontwerpaanpassingen, nieuwe functionaliteit, content of SEO-werk. Dat gaat tegen ons normale uurtarief, met €10/u korting voor pakketklanten.',
  },
  {
    q: 'Hoe lang zit ik vast aan een pakket?',
    a: 'Nergens aan. Maandelijks abonnement is per maand opzegbaar, jaarlijks na afloop van het jaar. Geen langlopende contracten, geen stilzwijgende verlenging zonder bericht.',
  },
  {
    q: 'Welke premium plug-inlicenties krijg ik?',
    a: 'Bij elk pakket zit een set premium-licenties inbegrepen, samen goed voor €350+ per jaar, dus ook bij Basic Care. Denk aan ACF Pro, WP Rocket, Elementor Pro, WP Armour Premium en Gravity Forms. We installeren wat jouw site nodig heeft, niet alles tegelijk.',
  },
  {
    q: 'Wat als mijn site al gehackt blijkt te zijn?',
    a: 'Dan pakken we dat los op via een hack-recovery met een eigen prijsafspraak. De pakketten zijn bedoeld om problemen te voorkomen, niet om een bestaande hack gratis op te ruimen. Pakketklanten krijgen wel een gunstig tarief. Bij de check zien we vrijwel altijd direct of er iets actief misgaat.',
  },
];
---

<BaseLayout title={pageTitle} description={pageDesc} noindex={true}>
  <!-- ============================================================
       Gestripte header — logo + telefoon + pakketten-anchor.
       Geen menu: bewust min uitgangen op betaald verkeer.
       ============================================================ -->
  <header class="lp-header">
    <div class="lp-header-inner">
      <a class="lp-logo" href="/" aria-label="Froseo home">
        <Image src={logoWit} alt="Froseo" height={28} loading="eager" />
      </a>
      <nav class="lp-nav" aria-label="Menu">
        <a href="#waarom">Waarom onderhoud</a>
        <a href="#pakketten">Pakketten</a>
        <a href="/cases/">Ons werk</a>
        <a href="/over-ons/">Over ons</a>
        <a href="#faq">FAQ</a>
      </nav>
      <div class="lp-header-actions">
        <a class="lp-header-phone" href={waUrl} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M19.05 4.91A9.82 9.82 0 0012.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 004.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.91-7.01zm-7.01 15.24a8.23 8.23 0 01-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.21 8.21 0 01-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 012.42 5.83c0 4.55-3.7 8.23-8.25 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.17.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.39.11-.51.11-.11.25-.29.38-.43.12-.14.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.57.12.17 1.74 2.66 4.22 3.74.59.25 1.05.4 1.41.51.59.19 1.13.16 1.55.1.47-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29z"/></svg>
          WhatsApp
        </a>
        <a class="btn-primary lp-header-cta" href="#check">Gratis check ↗</a>
        <button class="lp-burger" type="button" aria-label="Menu openen" aria-expanded="false" data-lp-burger>
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
    {/* Mobiel uitklap-menu — verschijnt onder de breakpoint waar .lp-nav verdwijnt. */}
    <nav class="lp-mobile-menu" data-lp-mobile aria-label="Menu">
      <a href="#waarom">Waarom onderhoud</a>
      <a href="#pakketten">Pakketten</a>
      <a href="/cases/">Ons werk</a>
      <a href="/over-ons/">Over ons</a>
      <a href="#faq">FAQ</a>
      <a href={waUrl} target="_blank" rel="noopener noreferrer">WhatsApp ons</a>
    </nav>
  </header>

  <main class="lp-page">
    <!-- ============================================================
         Hero
         ============================================================ -->
    <section class="lp-hero">
      <div class="lp-hero-inner">
        <div class="lp-hero-text">
          <EyebrowPill>60+ WordPress-sites in beheer</EyebrowPill>
          <h1 class="lp-hero-title">
            WordPress onderhoud <em>zonder kopzorgen.</em>
          </h1>
          <p class="lp-hero-lead">
            Laat updates, backups, beveiliging en snelheid over aan WordPress-specialisten. Voor een vaste maandprijs houden wij je site veilig, snel en bijgewerkt. Jij hoeft nergens meer naar om te kijken.
          </p>
          <ul class="lp-hero-checks">
            <li>Jouw WordPress-site altijd veilig, snel en bijgewerkt</li>
            <li>Handmatige updates met automatisch restore-point</li>
            <li>Dagelijkse backups en beveiligingsscans</li>
            <li>Premium plug-inlicenties t.w.v. €350+/jaar inbegrepen</li>
          </ul>
          <div class="lp-hero-actions">
            <a class="btn-primary lp-hero-cta" href="#check">Gratis WordPress-check aanvragen ↗</a>
            <a class="btn-ghost lp-hero-secondary" href="#pakketten">Bekijk pakketten ↓</a>
          </div>
          <div class="lp-hero-reviews reviews-inline">
            <ReviewAvatars />
            <div class="stars">★★★★★</div>
            <span><strong>{review.ratingDisplay}</strong> · Google reviews</span>
          </div>
        </div>
        <div class="lp-hero-media">
          <Image
            src={heroImage}
            alt="WordPress website onderhoud door Froseo"
            class="lp-hero-img"
            widths={[640, 960, 1280, 1600]}
            sizes="(max-width: 1024px) 100vw, 560px"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </section>

    <StatsRibbon items={statsItems} />

    <div id="waarom">
      <PainPoints
        title="Waar je tegenaan loopt zonder"
        titleAccent="WordPress onderhoud."
        items={painPoints}
      />
    </div>

    {/* Pakketten — pagina-grid laten doorkomen (zie .lp-pkg-section in styles). */}
    <div class="lp-pkg-section">
      <PricingPackages
        title="Onze"
        titleAccent="WordPress-onderhoudspakketten."
        lead="Drie pakketten met heldere maandprijzen, speciaal voor WordPress-sites. Maandelijks opzegbaar of jaarlijks met één maand gratis. Tussen pakketten switchen kan altijd."
        ctaMode="leadform"
      />
    </div>

    {/* Klant-quote tussen pakketten en de vergelijking. */}
    <Testimonial id="auke-club12" variant="card" />

    {/* Vergelijking — donkerpaars + grid zodat dit blok visueel afwijkt. */}
    <div class="lp-cmp-section">
      <Comparison
        title={comparison.title}
        titleAccent={comparison.titleAccent}
        withoutLabel={comparison.withoutLabel}
        withLabel={comparison.withLabel}
        items={comparison.items}
      />
    </div>

    {/* Logo-ticker als proof-break tussen de vergelijking en het formulier. */}
    <LogosTicker />

    <!-- ============================================================
         Onderhoudscheck — staat bewust onderaan: eerst verlangen
         opbouwen (pijn → pakketten → vergelijking → proof), dán pas vragen.
         2-koloms: wat we checken + formulier.
         ============================================================ -->
    <section class="lp-check" id="check">
      <div class="lp-check-inner">
        <div class="lp-check-intro">
          <EyebrowPill variant="highlight">Gratis &amp; vrijblijvend</EyebrowPill>
          <h2 class="lp-check-title">Vraag je gratis <em>WordPress-check</em> aan.</h2>
          <p class="lp-check-lead">
            We draaien een snelle gezondheidscheck op je site (vooral snelheid en beveiliging) op basis van je URL en sturen je in begrijpelijke taal terug wat opvalt. Geen login nodig en geen verkooppraatje: blijkt onderhoud nog niet nodig, dan zeggen we dat.
          </p>
          <ul class="lp-check-list">
            {checkItems.map((c) => <li>{c}</li>)}
          </ul>
          <p class="lp-check-note">
            De diepere intake (backups, plug-in-versies en instellingen achter je login) doen we pas wanneer je klant wordt. Voor deze check hebben we alleen je webadres nodig.
          </p>
        </div>

        <div class="lp-form-wrap">
          <form class="lp-form" method="POST" action="/api/contact" data-lp-form novalidate>
            <div class="lp-form-title">Gratis WordPress-check aanvragen</div>

            <label class="lp-field">
              <span>Naam</span>
              <input type="text" name="name" required autocomplete="name" />
            </label>
            <label class="lp-field">
              <span>E-mailadres</span>
              <input type="email" name="email" required autocomplete="email" placeholder="je@bedrijf.nl" />
            </label>
            <label class="lp-field">
              <span>Je website-URL</span>
              <input type="url" name="current_website" required placeholder="www.jouwbedrijf.nl" />
            </label>
            <label class="lp-field">
              <span>Waar wil je hulp bij?</span>
              <select name="hulpvraag" data-lp-hulpvraag>
                <option value="">Kies een onderwerp</option>
                <option value="WordPress onderhoud">WordPress onderhoud (algemeen)</option>
                <option value="Updates en backups">Updates en backups</option>
                <option value="Beveiliging">Beveiliging</option>
                <option value="Trage website">Trage website</option>
                <option value="Pakket aanvragen">Een pakket aanvragen</option>
                <option value="Weet ik nog niet">Weet ik nog niet precies</option>
              </select>
            </label>
            <label class="lp-field">
              <span>Toelichting <em class="lp-optional">(optioneel)</em></span>
              <textarea name="toelichting" rows="3" placeholder="Vertel kort wat er speelt of wat je wilt weten."></textarea>
            </label>

            {/* Hidden context-velden voor de gedeelde /api/contact endpoint. */}
            <input type="hidden" name="form_source" value="onderhoud-lp" />
            <input type="hidden" name="onderwerp" value="WordPress onderhoudscheck" data-lp-onderwerp />
            <input type="hidden" name="package" value="" data-lp-package />
            <input type="hidden" name="message" value="Aanvraag gratis WordPress-check." data-lp-message />

            {/* Honeypots (verborgen) + tijd-check. Server valideert beide. */}
            <div class="form-honeypot" aria-hidden="true">
              <label>Website (laat dit veld leeg)
                <input type="text" name="website_url" tabindex="-1" autocomplete="off" />
              </label>
              <label>Onderwerp
                <input type="text" name="subject" tabindex="-1" autocomplete="off" />
              </label>
            </div>
            <input type="hidden" name="form_started_at" value="" data-lp-started-at />

            <button type="submit" class="btn-primary lp-form-submit">Vraag gratis check aan ↗</button>
            <span class="lp-form-status" data-lp-status role="status" aria-live="polite">100% vrijblijvend, reactie meestal binnen één werkdag.</span>
          </form>
        </div>
      </div>
    </section>

    <div id="faq">
      <FAQ items={faqs} />
    </div>

    {/* Slot-CTA: jouw vaste foto-blok i.p.v. een kaal contact-bandje.
        WhatsApp is de primaire actie (geen bellen pushen). */}
    <BetterCallCalvin
      eyebrow="Liever direct contact?"
      titleLine1="Even sparren over je"
      titleAccent="WordPress-onderhoud?"
      body={[
        'Geen zin in een formulier? Stuur ons een WhatsApp of een bericht. We kijken vrijblijvend mee naar je site en zeggen eerlijk wat we zouden doen.',
        'Je krijgt meestal binnen één werkdag antwoord.',
      ]}
      primaryLabel="Stuur een WhatsApp ↗"
      primaryHref={waUrl}
      secondaryLabel="Of stuur een bericht"
      secondaryHref="/contact/"
    />
  </main>

  <!-- ============================================================
       Slanke footer — vertrouwen (NAW + reviews) + paar zachte links
       ============================================================ -->
  <footer class="lp-footer">
    <div class="lp-footer-inner">
      <div class="lp-footer-brand">
        <Image src={logoWit} alt="Froseo" height={30} loading="lazy" />
        <p class="lp-footer-tagline">
          WordPress onderhoud zonder kopzorgen. Updates, backups, beveiliging en snelheid voor een vaste maandprijs, door specialisten uit Utrecht.
        </p>
        <div class="lp-footer-social">
          <a href={social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5zM.2 8h4.6v14H.2V8zm7.5 0h4.4v1.9h.06c.61-1.16 2.1-2.38 4.32-2.38 4.62 0 5.47 3.04 5.47 7v8.48h-4.6v-7.5c0-1.79-.03-4.1-2.5-4.1-2.5 0-2.88 1.95-2.88 3.97V22H7.7V8z"/></svg>
          </a>
          <a href="https://www.instagram.com/froseo_nl/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 01-1.38-.9 3.7 3.7 0 01-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zm0 1.62c-3.15 0-3.5.01-4.74.07-1.14.05-1.76.24-2.17.4-.55.21-.94.47-1.35.88-.41.41-.67.8-.88 1.35-.16.41-.35 1.03-.4 2.17-.06 1.24-.07 1.59-.07 4.74s.01 3.5.07 4.74c.05 1.14.24 1.76.4 2.17.21.55.47.94.88 1.35.41.41.8.67 1.35.88.41.16 1.03.35 2.17.4 1.24.06 1.59.07 4.74.07s3.5-.01 4.74-.07c1.14-.05 1.76-.24 2.17-.4.55-.21.94-.47 1.35-.88.41-.41.67-.8.88-1.35.16-.41.35-1.03.4-2.17.06-1.24.07-1.59.07-4.74s-.01-3.5-.07-4.74c-.05-1.14-.24-1.76-.4-2.17a3.6 3.6 0 00-.88-1.35 3.6 3.6 0 00-1.35-.88c-.41-.16-1.03-.35-2.17-.4-1.24-.06-1.59-.07-4.74-.07zm0 2.76a5.46 5.46 0 110 10.92 5.46 5.46 0 010-10.92zm0 9a3.54 3.54 0 100-7.08 3.54 3.54 0 000 7.08zm6.95-9.22a1.28 1.28 0 11-2.55 0 1.28 1.28 0 012.55 0z"/></svg>
          </a>
          <a href="https://www.facebook.com/froseomarketing" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.03 4.39 11.03 10.13 11.93v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.97h-1.52c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8v8.44C19.61 23.1 24 18.1 24 12.07z"/></svg>
          </a>
