  /* Pakketten: ook het pagina-grid laten doorkomen (dicht vlak weg). */
  .lp-pkg-section :global(.pricing-packages) { background: transparent; }
  /* Vergelijking: donkerpaars + subtiel grid-patroon (witte lijnen met
     radial-fade), zodat dit blok sterk afwijkt van de lichte secties. */
  .lp-cmp-section :global(.comparison) {
