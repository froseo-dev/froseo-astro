<script>
  /* ============================================================
     Mobiel hamburger-menu — toggelt het uitklap-menu onder de breakpoint.
     ============================================================ */
  const burger = document.querySelector<HTMLButtonElement>('[data-lp-burger]');
  const mobileMenu = document.querySelector<HTMLElement>('[data-lp-mobile]');
  burger?.addEventListener('click', () => {
    const open = mobileMenu?.classList.toggle('is-open') ?? false;
    burger.setAttribute('aria-expanded', open ? 'true' : 'false');
    burger.setAttribute('aria-label', open ? 'Menu sluiten' : 'Menu openen');
  });
  /* Sluit het menu zodra een link wordt gekozen (anchor scrollt al). */
  mobileMenu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      mobileMenu.classList.remove('is-open');
      burger?.setAttribute('aria-expanded', 'false');
    });
  });

  /* ============================================================
     Pakket-knoppen (PricingPackages ctaMode="leadform") koppelen aan
     het formulier: zet hulpvraag + verberg-velden en scroll naar #check.
     ============================================================ */
  const form = document.querySelector<HTMLFormElement>('[data-lp-form]');
  const status = document.querySelector<HTMLElement>('[data-lp-status]');
  const startedAt = document.querySelector<HTMLInputElement>('[data-lp-started-at]');
  const hulpvraag = document.querySelector<HTMLSelectElement>('[data-lp-hulpvraag]');
  const onderwerpField = document.querySelector<HTMLInputElement>('[data-lp-onderwerp]');
  const packageField = document.querySelector<HTMLInputElement>('[data-lp-package]');
  const messageField = document.querySelector<HTMLInputElement>('[data-lp-message]');

  if (startedAt) startedAt.value = String(Date.now());

  /* Klik op een pakket-knop → formulier voorvullen op "pakket aanvragen". */
  document.querySelectorAll<HTMLAnchorElement>('a[data-package]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const slug = btn.dataset.package ?? '';
      const name = btn.dataset.packageName ?? '';
      if (hulpvraag) hulpvraag.value = 'Pakket aanvragen';
      if (packageField) packageField.value = slug;
      if (onderwerpField) onderwerpField.value = `WordPress onderhoud — ${name}`;
      /* Korte visuele hint dat het formulier is voorgevuld. */
      if (status) {
        status.textContent = `Pakket gekozen: ${name}. Vul je gegevens in om aan te vragen.`;
        status.className = 'lp-form-status';
      }
      /* Expliciet (smooth) naar het formulier scrollen — betrouwbaarder
         dan alleen de #check-anchor. */
      document.getElementById('check')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !status) return;

    const submitBtn = form.querySelector<HTMLButtonElement>('.lp-form-submit');
    submitBtn?.setAttribute('disabled', 'true');
    status.textContent = 'Versturen…';
    status.className = 'lp-form-status';

    /* Bericht synthetiseren uit hulpvraag + website + toelichting zodat de
       gedeelde endpoint z'n validatie (message >= 10) haalt. */
    const data = new FormData(form);
    const website = (data.get('current_website') ?? '').toString();
    const vraag = (data.get('hulpvraag') ?? '').toString();
    const toelichting = (data.get('toelichting') ?? '').toString();
    const pkg = (data.get('package') ?? '').toString();
    const onderwerp = (onderwerpField?.value ?? 'WordPress onderhoudscheck');

    let msg = `Aanvraag gratis WordPress-onderhoudscheck. Onderwerp: ${onderwerp}.`;
    if (vraag) msg += ` Hulpvraag: ${vraag}.`;
    if (website) msg += ` Website: ${website}.`;
    if (toelichting) msg += ` Toelichting: ${toelichting}`;
    if (messageField) messageField.value = msg;
    data.set('message', msg);

    try {
      const res = await fetch('/api/contact', { method: 'POST', body: data });
      const json = await res.json().catch(() => ({}));
      if (res.ok && json.ok) {
        /* Conversie-signaal. lead_type onderscheidt check vs pakketaanvraag;
           de Ads-conversie "WordPress onderhoud lead" koppel je hier later op. */
        (window as any).dataLayer = (window as any).dataLayer || [];
        (window as any).dataLayer.push({
          event: 'generate_lead',
          lead_type: pkg ? 'onderhoud-pakket' : 'onderhoud-check',
          package: pkg || undefined,
          form_location: 'wordpress-onderhoud-lp',
        });
        status.textContent = '✓ Verstuurd. We nemen snel contact op met je gratis check.';
        status.className = 'lp-form-status is-success';
        form.reset();
        if (startedAt) startedAt.value = String(Date.now());
        if (onderwerpField) onderwerpField.value = 'WordPress onderhoudscheck';
        if (packageField) packageField.value = '';
      } else {
        status.textContent = json.error ?? 'Versturen mislukt. Probeer het opnieuw of mail ons direct.';
        status.className = 'lp-form-status is-error';
      }
    } catch {
      status.textContent = 'Versturen mislukt. Probeer het opnieuw of mail ons direct.';
      status.className = 'lp-form-status is-error';
    } finally {
      submitBtn?.removeAttribute('disabled');
    }
  });
</script>
