  .lp-form-submit { width: 100%; margin-top: 0.25rem; }
  .lp-form-status { font-size: 0.85rem; text-align: center; opacity: 0.7; }
  .lp-form-status.is-success { color: var(--accent-teal); opacity: 1; font-weight: 600; }
  .lp-form-status.is-error { color: #c0392b; opacity: 1; font-weight: 600; }
  @media (max-width: 900px) {
    .lp-check-inner { grid-template-columns: 1fr; }
