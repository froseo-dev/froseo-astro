  }
  .lp-footer-brand img { height: 30px; width: auto; margin-bottom: 1rem; }
  .lp-footer-tagline {
    font-size: 0.92rem;
    line-height: 1.6;
    max-width: 26rem;
    margin-bottom: 1.35rem;
    opacity: 0.8;
  }
  .lp-footer-social { display: flex; gap: 0.7rem; }
  .lp-footer-social a {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border: 1px solid rgba(255, 255, 255, 0.22);
