  /* ============================================================
     Hero
     ============================================================ */
  .lp-hero {
    /* Transparant: laat het pagina-grid (--bg-decoration-light op body)
       doorkomen, hetzelfde patroontje als de andere lichte secties. */
    background: transparent;
    padding: clamp(2.5rem, 6vw, 5rem) 1.5rem clamp(2.5rem, 5vw, 4rem);
