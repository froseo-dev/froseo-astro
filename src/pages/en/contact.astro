---
/**
 * /en/contact/ — Engelse contactpagina. Zelfde /api/contact-flow als NL:
 * post naar /api/contact (Zoho Web-to-Lead + Resend). Stuurt hidden lang="en"
 * (backend prefixt [EN] + tagt de lead) en form_source="contact-en" zodat
 * Calvin EN-leads kan segmenteren. De `topic`-querystring (vanaf de
 * servicebloks op /en/) wordt als onderwerp doorgegeven zodat de Zoho
 * Service interest klopt (deriveServiceInterest kent de Engelse termen).
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import NavEN from '@components/layout/NavEN.astro';
import FooterEN from '@components/layout/FooterEN.astro';
import EyebrowPill from '@components/ui/EyebrowPill.astro';
import ReviewAvatars from '@components/ui/ReviewAvatars.astro';
import { contact, review } from '@data/site-config';

/* WhatsApp deep-link met Engelse preset-tekst. */
const waMessage = 'Hi Froseo, I would like to discuss';
const waUrl = `https://wa.me/${contact.whatsappNumber}?text=${encodeURIComponent(waMessage)}`;

/* Topic-context via querystring (servicebloks op /en/ linken naar
   ?topic=<slug>). Toont een badge + hidden onderwerp-veld zodat de server
   de juiste Service interest afleidt. */
const topicLabels: Record<string, string> = {
  'web-design': 'Custom web design',
  'website-subscription': 'Website subscription',
  'local-seo': 'Local SEO',
  'seo-geo': 'SEO & GEO',
  'website-optimization': 'Website optimization',
  'website-maintenance': 'Website maintenance',
};
const topicKey = (Astro.url.searchParams.get('topic') ?? '').trim();
const topicLabel = topicLabels[topicKey];
---

<BaseLayout
  lang="en"
  title="Contact Froseo: web design & SEO agency in Utrecht"
  description="Have a question about your website, SEO or online marketing? Send us a message or plan a free intro call. We usually reply within one working day."
>
  <NavEN />
  <main>
    <article class="contact-page">
      <section class="contact-hero">
        <div class="contact-hero-inner">
          <EyebrowPill variant="rare">Contact</EyebrowPill>
          <h1 class="contact-hero-title">
            How can we <em>help?</em>
          </h1>
          <p class="contact-hero-lead">
            Have a question about your website, SEO or online marketing? Or do you want to talk through what makes sense for your business? Send us a message or plan an intro call. Always free and no obligation.
          </p>
          <div class="contact-hero-reviews reviews-inline">
            <ReviewAvatars />
            <div class="stars">★★★★★</div>
            <span><strong>{review.ratingDisplay}</strong> · Google reviews</span>
          </div>
        </div>
      </section>

      <section class="contact-main">
        <div class="contact-main-inner">
          <div class="contact-form-wrap">
            <div class="contact-form-head">
              <h2 class="contact-form-title">Send a message</h2>
              {topicLabel && (
                <div class="contact-onderwerp-badge" data-onderwerp-badge>
                  <span class="contact-onderwerp-label">Subject:</span>
                  <span class="contact-onderwerp-value">{topicLabel}</span>
                </div>
              )}
            </div>
            <form class="contact-form" method="POST" action="/api/contact" data-en-contact-form novalidate>
              <input type="hidden" name="form_source" value="contact-en" />
              <input type="hidden" name="lang" value="en" />
              {topicKey && (
                <input type="hidden" name="onderwerp" value={topicLabel ?? topicKey} />
              )}
              <div class="form-row">
                <label class="form-field">
                  <span class="form-label">Name <em>*</em></span>
                  <input type="text" name="name" required autocomplete="name" />
                </label>
                <label class="form-field">
                  <span class="form-label">Email <em>*</em></span>
                  <input type="email" name="email" required autocomplete="email" />
                </label>
              </div>
              <div class="form-row">
                <label class="form-field">
                  <span class="form-label">Phone</span>
                  <input type="tel" name="phone" autocomplete="tel" />
                </label>
                <label class="form-field">
                  <span class="form-label">Current website</span>
                  <input type="url" name="current_website" placeholder="https://" />
                </label>
              </div>
              <label class="form-field">
                <span class="form-label">Message <em>*</em></span>
                <textarea name="message" rows="6" required minlength="10" placeholder="Tell us briefly what you are looking for or what could be better."></textarea>
              </label>

              <div class="form-honeypot" aria-hidden="true">
                <label>Website (leave this field empty)
                  <input type="text" name="website_url" tabindex="-1" autocomplete="off" />
                </label>
                <label>Subject
                  <input type="text" name="subject" tabindex="-1" autocomplete="off" />
                </label>
              </div>
              <input type="hidden" name="form_started_at" value="" data-en-form-started-at />

              <div class="form-foot">
                <button type="submit" class="btn-primary form-submit">Send message ↗</button>
                <span class="form-status" data-en-form-status role="status" aria-live="polite"></span>
              </div>
              <p class="form-note">
                By submitting this form you agree to our <a href="/privacybeleid/">privacy statement</a>.
              </p>
            </form>
          </div>

          <div class="contact-aside">
            <aside class="contact-info">
              <h2 class="contact-info-title">Prefer direct contact</h2>

              <a class="contact-info-row" href={`mailto:${contact.email}`}>
                <span class="contact-info-icon" aria-hidden="true">✉</span>
                <span class="contact-info-body">
                  <span class="contact-info-label">Email us</span>
                  <span class="contact-info-value">{contact.email}</span>
                </span>
              </a>

              <a class="contact-info-row contact-info-row--whatsapp" href={waUrl} target="_blank" rel="noopener noreferrer">
                <span class="contact-info-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M19.05 4.91A9.82 9.82 0 0012.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 004.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.91-7.01zm-7.01 15.24a8.23 8.23 0 01-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.21 8.21 0 01-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 012.42 5.83c0 4.55-3.7 8.23-8.25 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.17.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.39.11-.51.11-.11.25-.29.38-.43.12-.14.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.57.12.17 1.74 2.66 4.22 3.74.59.25 1.05.4 1.41.51.59.19 1.13.16 1.55.1.47-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29z"/></svg>
                </span>
                <span class="contact-info-body">
                  <span class="contact-info-label">WhatsApp us</span>
                  <span class="contact-info-value">Chat directly</span>
                </span>
              </a>

              <a class="contact-info-row" href={`tel:${contact.phoneTel}`}>
                <span class="contact-info-icon" aria-hidden="true">☎</span>
                <span class="contact-info-body">
                  <span class="contact-info-label">Call us</span>
                  <span class="contact-info-value">{contact.phoneDisplay}</span>
                </span>
              </a>

              <div class="contact-info-meta">
                <div>
                  <span class="meta-key">Response time</span>
                  <span class="meta-val">Usually within one working day</span>
                </div>
                <div>
                  <span class="meta-key">Office</span>
                  <span class="meta-val">{contact.address.street}, {contact.address.city}</span>
                </div>
              </div>
            </aside>
          </div>
        </div>
      </section>
    </article>
  </main>
  <FooterEN />

  <script>
    /* Form submit met fetch — Engelse statusteksten, zelfde /api/contact-flow. */
    const form = document.querySelector<HTMLFormElement>('[data-en-contact-form]');
    const status = document.querySelector<HTMLElement>('[data-en-form-status]');
    const startedAt = document.querySelector<HTMLInputElement>('[data-en-form-started-at]');

    if (startedAt) startedAt.value = String(Date.now());

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form || !status) return;

      const submitBtn = form.querySelector<HTMLButtonElement>('.form-submit');
      submitBtn?.setAttribute('disabled', 'true');
      status.textContent = 'Sending…';
      status.className = 'form-status is-loading';

      try {
        const data = new FormData(form);
        const res = await fetch('/api/contact', { method: 'POST', body: data });
        const json = await res.json().catch(() => ({}));

        if (res.ok && json.ok) {
          (window as any).dataLayer = (window as any).dataLayer || [];
          (window as any).dataLayer.push({
            event: 'generate_lead',
            lead_type: 'contact',
            form_location: 'contact-en',
          });
          status.textContent = 'Message sent. We will get back to you soon.';
          status.className = 'form-status is-success';
          form.reset();
          if (startedAt) startedAt.value = String(Date.now());
        } else {
          status.textContent = json.error ?? 'Something went wrong. Please try again later or call us.';
          status.className = 'form-status is-error';
        }
      } catch {
        status.textContent = 'Something went wrong. Please try again later or call us.';
        status.className = 'form-status is-error';
      } finally {
        submitBtn?.removeAttribute('disabled');
      }
    });
  </script>
</BaseLayout>
