---
// Optie 4 — "Editorial" hero (compositie van _reference/peterzijlstra/v2).
// Eigen, self-contained ontwerp: grote PETER / ZIJLSTRA-namen, grijswaarden-
// foto die onderaan in het groen oplost, intro rechts, rollen-lijst linksonder.
// Bewust GEEN import van peter-hero.css (zou met de andere .hero botsen);
// de switcher-styles staan daarom hieronder inline.
// Basis = 1440p (2560x1440); puur vw-geschaald zodat 1080p er identiek uitziet.
import PeterSwitcher from "../../components/PeterSwitcher.astro";
const logo = "/peter-zijlstra/logo.png";
const photo = "/peter-zijlstra/peter-cropped.webp";
---

<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="robots" content="noindex, nofollow" />
<title>Peter Zijlstra — optie 4 (Editorial)</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400;1,9..144,500;1,9..144,600&family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
  rel="stylesheet"
/>
<style>
  :root {
    /* groen spectrum uit kleuren.txt (blauw bewust niet gebruikt) */
    --green-300: #5fe9b3;
    --green-500: #28DF99;
    --green-600: #1fbf82;
    --green-700: #1B9968;
    --green-900: #157a52;
    --sand:      #E4DFDA;

    --ink:       #16221d;   /* donkere tekstkleur */
    --ink-soft:  #5f6763;   /* grijze subtekst */

    /* horizontale marge — schaalt puur mee in 1080p–1440p band */
    --gutter: clamp(28px, 5vw, 150px);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    background: var(--sand);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  /* ============================================================
     HERO  (full-bleed, alles schaalt met de viewport)
     ============================================================ */
  .hero {
    position: relative;
    min-height: 100dvh;
    overflow: hidden;
    /* lichte zand-achtergrond + volle-breedte groene wash onderaan */
    background:
      linear-gradient(180deg, transparent 34%, rgba(40,223,153,0.40) 66%, rgba(31,184,127,0.66) 100%),
      linear-gradient(180deg, #efeeea 0%, var(--sand) 42%, #e6eae5 100%);
  }

  /* ---------- NAV ---------- */
  .hero__nav {
    position: relative;
    z-index: 8;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: clamp(26px, 3vh, 48px) var(--gutter);
  }
  .hero__logo img { height: clamp(38px, 3vw, 76px); width: auto; display: block; }
  .hero__nav-right { display: flex; align-items: center; gap: clamp(20px, 2vw, 44px); }
  .hero__call {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: clamp(15px, 1.05vw, 26px);
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: opacity 0.2s ease;
  }
  .hero__call:hover { opacity: 0.6; }
  .hero__call svg { width: 1.2em; height: 1.2em; }
  .hero__burger {
    display: flex; flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer; padding: 4px 0;
  }
  .hero__burger span { display: block; height: 2px; background: var(--ink); border-radius: 2px; }
  .hero__burger span:nth-child(1) { width: 1.7em; }
  .hero__burger span:nth-child(2) { width: 1.7em; }
  .hero__burger span:nth-child(3) { width: 1.1em; }

  /* ---------- GROTE NAAM ACHTER DE FOTO (Space Grotesk, clean) ---------- */
  .hero__bgname {
    position: absolute;
    z-index: 1;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.03em;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    /* één samenhangend groen verloop over beide woorden */
    background: linear-gradient(116deg, var(--green-500) 0%, var(--green-600) 50%, var(--green-700) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero__bgname--first {
    left: var(--gutter);
    bottom: 26%;
    font-size: clamp(120px, 16.5vw, 470px);
    opacity: 0.92;
  }
  .hero__bgname--last {
    right: clamp(-130px, -4vw, -28px);   /* bloedt rechts van het scherm af */
    bottom: 13%;
    font-size: clamp(112px, 15.5vw, 450px);
    opacity: 0.6;
  }

  /* ---------- GEOMETRISCHE PIJL (rechts) ---------- */
  .hero__shape {
    position: absolute;
    z-index: 5;
    top: 53%;
    right: clamp(70px, 11vw, 280px);
    width: clamp(64px, 7vw, 170px);
    color: #ccc6bd;
    pointer-events: none;
  }
  .hero__shape svg { width: 100%; height: auto; display: block; }

  /* ---------- FOTO (peter-cropped: groot, onderaan uitgelijnd, contain) ---------- */
  .hero__figure {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(680px, 60vw, 1640px);
    aspect-ratio: 2000 / 1728;   /* = de bron, dus contain croppt niets weg */
    z-index: 3;
  }
  .hero__photo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: bottom center;
    /* grijstinten + onderaan oplossen zodat de torso in het groen wegloopt */
    filter: grayscale(1) contrast(1.05) brightness(1.02);
    -webkit-mask-image: linear-gradient(180deg, #000 50%, rgba(0,0,0,0.5) 72%, transparent 90%);
    mask-image: linear-gradient(180deg, #000 50%, rgba(0,0,0,0.5) 72%, transparent 90%);
  }
  /* milde groene kleurwash over het onderlichaam (blendt met de wash erachter) */
  .hero__figure::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg,
      transparent 48%,
      rgba(40,223,153,0.45) 72%,
      rgba(21,122,82,0.55) 100%);
    mix-blend-mode: color;
    -webkit-mask-image: linear-gradient(180deg, transparent 50%, #000 72%, transparent 92%);
    mask-image: linear-gradient(180deg, transparent 50%, #000 72%, transparent 92%);
  }

  /* ---------- INTRO-BLOK RECHTSBOVEN ---------- */
  .hero__intro {
    position: absolute;
    z-index: 6;
    top: clamp(124px, 17vh, 300px);
    right: var(--gutter);
    width: clamp(230px, 19vw, 480px);
  }
  .hero__intro-name {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 500;
    font-size: clamp(27px, 2.4vw, 60px);
    line-height: 1.08;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: clamp(12px, 0.9vw, 22px);
  }
  .hero__intro-text {
    font-size: clamp(14px, 1.05vw, 26px);
    line-height: 1.58;
    color: var(--ink-soft);
  }

  /* ---------- ROLLEN-LIJST LINKSONDER ---------- */
  .hero__roles {
    position: absolute;
    z-index: 6;
    left: var(--gutter);
    bottom: clamp(44px, 7vh, 128px);
    display: flex;
    flex-direction: column;
    gap: clamp(2px, 0.5vh, 14px);
  }
  .hero__role {
    display: flex;
    align-items: baseline;
    gap: clamp(14px, 1.2vw, 30px);
    font-family: 'Fraunces', serif;
    font-style: italic;
    line-height: 1.04;
    color: var(--ink);
  }
  .hero__role-num {
    font-size: clamp(16px, 1.4vw, 36px);
    font-weight: 400;
    color: var(--ink-soft);
  }
  .hero__role-label {
    font-size: clamp(46px, 5.7vw, 150px);
    font-weight: 500;
    letter-spacing: -0.012em;
    color: var(--ink);
  }
  /* subtiele stagger zoals in de reference (02 verst naar binnen) */
  .hero__role:nth-child(1) { margin-left: 0; }
  .hero__role:nth-child(2) { margin-left: clamp(46px, 7vw, 184px); }
  .hero__role:nth-child(3) { margin-left: clamp(16px, 2.4vw, 64px); }

  /* ---------- ENTRANCE ANIMATIE ---------- */
  .hero__nav, .hero__intro, .hero__roles, .hero__figure, .hero__bgname {
    animation: rise 0.85s cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }
  .hero__nav    { animation-delay: 0.05s; }
  .hero__bgname { animation-delay: 0.1s; }
  .hero__figure { animation-delay: 0.12s; animation-name: riseFig; }
  .hero__intro  { animation-delay: 0.3s; }
  .hero__roles  { animation-delay: 0.38s; }
  @keyframes rise { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes riseFig { from { opacity: 0; transform: translate(-50%, 22px); } to { opacity: 1; transform: translate(-50%, 0); } }
  @media (prefers-reduced-motion: reduce) {
    .hero__nav, .hero__intro, .hero__roles, .hero__figure, .hero__bgname { animation: none; }
  }

  /* ---------- SWITCH-BALK (alleen voor deze demo) ----------
     :global() omdat de switcher een losse component is: Astro scoped
     deze page-<style>, dus zonder :global() raken de regels de
     component-markup niet en verdwijnt de balk. */
  :global(.peter-switcher) {
    position: fixed;
    left: 50%; bottom: 24px;
    transform: translateX(-50%);
    z-index: 50;
    display: flex; gap: 4px;
    padding: 5px;
    border-radius: 999px;
    background: rgba(12,20,16,0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.25);
  }
  :global(.peter-switcher a) {
    padding: 8px 16px;
    border-radius: 999px;
    font-family: 'Inter', sans-serif;
    font-size: 13px; font-weight: 600;
    color: rgba(255,255,255,0.72);
    text-decoration: none;
    transition: background 0.18s ease, color 0.18s ease;
    white-space: nowrap;
  }
  :global(.peter-switcher a:hover) { color: #fff; }
  :global(.peter-switcher a.is-active) { background: #fff; color: #0c241a; }

  /* ---------- RESPONSIVE (smaller dan ~laptop) ---------- */
  @media (max-width: 1100px) {
    .hero__figure { width: 78vw; }
    .hero__intro { top: 100px; }
    .hero__shape { right: 6%; top: 46%; }
    .hero__bgname--first { bottom: 28%; }
    .hero__bgname--last { bottom: 14%; }
  }
  @media (max-width: 640px) {
    .hero__call span { display: none; }
    .hero__intro {
      position: static;
      width: auto;
      padding: 22px var(--gutter) 0;
      max-width: 360px;
    }
    .hero__figure { width: 112vw; }
    .hero__shape { display: none; }
    .hero__roles { bottom: 30px; gap: 4px; }
    .hero__role { gap: 12px; }
    .hero__role-label { font-size: clamp(30px, 9vw, 40px); }
    .hero__role-num { font-size: 13px; }
    .hero__role:nth-child(2) { margin-left: 24px; }
    .hero__role:nth-child(3) { margin-left: 9px; }
    .hero__bgname--first { bottom: 32%; font-size: clamp(80px, 22vw, 150px); }
    .hero__bgname--last { bottom: 15%; font-size: clamp(74px, 20vw, 140px); }
  }
</style>
</head>
<body>
  <section class="hero">

    <nav class="hero__nav">
      <a class="hero__logo" href="#" aria-label="Peter Zijlstra">
        <img src={logo} alt="Peter Zijlstra" />
      </a>
      <div class="hero__nav-right">
        <a class="hero__call" href="#">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9" />
            <path d="M3 12h18" />
            <path d="M12 3c2.5 2.7 3.8 6 3.8 9s-1.3 6.3-3.8 9c-2.5-2.7-3.8-6-3.8-9s1.3-6.3 3.8-9z" />
          </svg>
          <span>Plan kennismaking</span>
        </a>
        <button class="hero__burger" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>

    <!-- grote naam achter de foto -->
    <div class="hero__bgname hero__bgname--first" aria-hidden="true">PETER</div>
    <div class="hero__bgname hero__bgname--last" aria-hidden="true">ZIJLSTRA</div>

    <!-- geometrische pijl -->
    <div class="hero__shape" aria-hidden="true">
      <svg viewBox="0 0 100 130" fill="currentColor">
        <path d="M0 0 H58 L100 42 V70 L58 28 H0 Z" />
        <path d="M0 60 H58 L100 102 V130 L58 88 H0 Z" />
      </svg>
    </div>

    <!-- foto -->
    <div class="hero__figure">
      <img class="hero__photo" src={photo} alt="Peter Zijlstra" width="2000" height="1728" />
    </div>

    <!-- intro rechtsboven -->
    <div class="hero__intro">
      <p class="hero__intro-name">Ik ben Peter<br />Zijlstra.</p>
      <p class="hero__intro-text">Ik help ondernemers die veel kunnen, veel doen en soms ook gewoon een beetje in de knoop zitten met zichzelf. Geen trucjes, geen gouden formule. Wel scherpe vragen, vertraging en eerlijk kijken naar wat er speelt.</p>
    </div>

    <!-- rollen linksonder -->
    <div class="hero__roles">
      <div class="hero__role">
        <span class="hero__role-num">(01)</span>
        <span class="hero__role-label">Ondernemerscoach</span>
      </div>
      <div class="hero__role">
        <span class="hero__role-num">(02)</span>
        <span class="hero__role-label">Patroonspotter</span>
      </div>
      <div class="hero__role">
        <span class="hero__role-num">(03)</span>
        <span class="hero__role-label">Groei zonder gedoe</span>
      </div>
    </div>

  </section>

  <PeterSwitcher active="optie4" />
</body>
</html>
