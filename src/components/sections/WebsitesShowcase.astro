---
/**
 * Visuele showcase van cases — clean mockup-grid.
 *
 * Per tegel: mockup (zonder extra omkadering, het mockup-beeld heeft
 * z'n eigen frame), client-naam, optionele korte subtitel. Desktop 6
 * tegels, mobile 4 (overige verborgen).
 *
 * Twee gelijke buttons onderaan: portfolio + cases. Past bij de
 * "browse veel werk" intent op service-pagina's.
 */
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import EyebrowPill from '../ui/EyebrowPill.astro';

interface Props {
  cases: CollectionEntry<'cases'>[];
  eyebrow?: string;
  title?: string;
  titleAccent?: string;
  /** Max aantal tegels op desktop. Default 6. */
  desktopLimit?: number;
  /** Max aantal tegels op mobile. Default 4. */
  mobileLimit?: number;
  /** Wanneer false: alleen client-naam onder de mockup, geen subtitel. */
  showSubtitle?: boolean;
  /** Twee CTA-buttons onderaan (gelijke groottes). */
  portfolioLabel?: string;
  portfolioHref?: string;
  casesLabel?: string;
  casesHref?: string;
}

const {
  cases,
  eyebrow,
  title,
  titleAccent,
  desktopLimit = 6,
  mobileLimit = 4,
  showSubtitle = true,
  portfolioLabel = 'Bekijk portfolio ↗',
  portfolioHref = '/portfolio/',
  casesLabel = 'Bekijk alle cases ↗',
  casesHref = '/cases/',
} = Astro.props;

const items = cases.slice(0, desktopLimit);
---

<section class="websites-showcase" aria-label="Werk dat we deden">
  {(eyebrow || title) && (
    <header class="websites-showcase-head">
      {eyebrow && <EyebrowPill>{eyebrow}</EyebrowPill>}
      {title && (
        <h2 class="websites-showcase-title">
          {title}
          {titleAccent && <em> {titleAccent}</em>}
        </h2>
      )}
    </header>
  )}

  <div class="websites-showcase-grid">
    {items.map((c, i) => (
      <a
        class={`websites-showcase-card ${i >= mobileLimit ? 'is-desktop-only' : ''}`}
        href={`/cases/${c.data.slug}/`}
        aria-label={`Bekijk case ${c.data.client}`}
      >
        <div class="websites-showcase-img-wrap">
          <Image
            src={c.data.hero}
            alt={`${c.data.client}: ${c.data.tagline}`}
            class="websites-showcase-img"
            widths={[400, 600, 800, 1000]}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 380px"
            loading="lazy"
          />
        </div>
        <div class="websites-showcase-meta">
          <h3 class="websites-showcase-name">{c.data.client}</h3>
          {showSubtitle && <p class="websites-showcase-subtitle">{c.data.tagline}</p>}
        </div>
      </a>
    ))}
  </div>

  <div class="websites-showcase-foot websites-showcase-foot--dual">
    <a class="btn-primary websites-showcase-foot-btn" href={casesHref}>{casesLabel}</a>
    <a class="btn-ghost websites-showcase-foot-btn" href={portfolioHref}>{portfolioLabel}</a>
  </div>
</section>
