---
/**
 * Horizontaal scroll-snap cases-rij met prev/next-knoppen. Breekt uit
 * de container-padding zodat cards rechts buiten beeld doorlopen (page-
 * wide gevoel). Geen zichtbare scrollbar. Op mobile: alleen eerste N
 * cards stacked, rest verborgen.
 *
 * Bedoeld als losse rij die door zowel CasesStrip (homepage) als
 * related-cases (single case page) wordt hergebruikt.
 */
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  cases: CollectionEntry<'cases'>[];
  /** Max aantal cards op mobile (eerste N), rest verborgen. Default 4. */
  mobileLimit?: number;
  /** ID voor de scroll-container; nodig om meerdere rows op één page te
      laten coexisteren met eigen prev/next-knoppen. */
  id?: string;
  /** Compact-modus: blijft binnen de container (geen page-wide breakout).
      Voor secties op pagina's met eigen layout (zoals related-cases op
      case-page) waar de full-bleed breakout misalignement geeft. */
  compact?: boolean;
  /** Override-link voor álle kaarten. Default: /cases/<slug>/. Gebruikt op
      de Engelse homepage om naar /en/contact/ te sturen zolang er nog geen
      Engelse case-pagina's zijn. */
  cardHref?: string;
  /** Render de kaarten zonder link (geen <a>, geen href). Voor de Engelse
      homepage: er zijn nog geen Engelse case-pagina's, dus de kaart zelf
      linkt nergens heen — alleen de knoppen onder de rij. */
  linkless?: boolean;
}

const { cases, mobileLimit = 4, id = 'cases-row', compact = false, cardHref, linkless = false } = Astro.props;

const items = cases.map((c) => ({
  slug: c.data.slug,
  client: c.data.client,
  tagline: c.data.tagline,
  result: c.data.result,
  metric: c.data.metrics?.[0],
  image: c.data.atmosphereImage ?? c.data.gallery?.[0] ?? c.data.hero,
  imageAlt: c.data.atmosphereAlt ?? `${c.data.client}: ${c.data.tagline}`,
}));
---

<div class={`cases-row-wrap${compact ? ' cases-row-wrap--compact' : ''}`} data-cases-wrap={id}>
  <div class="cases-row" data-cases-row={id} role="list" aria-label="Cases">
    {items.map((it, i) => {
      const Card = linkless ? 'div' : 'a';
      const linkAttrs = linkless
        ? {}
        : { href: cardHref ?? `/cases/${it.slug}/`, 'aria-label': `Bekijk case ${it.client}` };
      /* Listitem-role gaat op een wrapper-div, niet op de <a> zelf.
         Een <a> heeft impliciet role=link; daarop listitem zetten geeft
         een 'ARIA role not appropriate'-warning bij accessibility-checks
         en bij AI-agent-browsing (Lighthouse Agentic Browsing audit). */
      return (
      <div class={`cases-row-item ${i >= mobileLimit ? 'is-desktop-only' : ''}`.trim()} role="listitem">
      <Card
        class={`cases-row-card${linkless ? ' is-linkless' : ''}`}
        {...linkAttrs}
      >
        <div class="cases-row-media">
          <Image
            src={it.image}
            alt={it.imageAlt}
            class="cases-row-img"
            widths={[400, 600, 800, 1000, 1200]}
            sizes="(max-width: 640px) 88vw, (max-width: 1024px) 48vw, 38vw"
            loading="lazy"
          />
        </div>
        <div class="cases-row-body">
          <h3 class="cases-row-name">{it.client}</h3>
          <p class="cases-row-tagline">{it.tagline}</p>
          {it.metric && (
            <div class="cases-row-metric">
              <strong>{it.metric.value}</strong>
              <span>{it.metric.label}</span>
            </div>
          )}
          {!it.metric && it.result && (
            <div class="cases-row-result">{it.result}</div>
          )}
        </div>
      </Card>
      </div>
      );
    })}
  </div>

  <div class="cases-row-nav-wrap" aria-hidden="false">
    <button class="cases-row-nav" type="button" data-cases-prev={id} aria-label="Vorige cases">‹</button>
    <button class="cases-row-nav" type="button" data-cases-next={id} aria-label="Volgende cases">›</button>
  </div>
</div>

<style>
  /* Niet-klikbare kaarten (Engelse homepage): geen klik-affordance. */
  .cases-row-card.is-linkless { cursor: default; }
</style>

<script>
  /* Infinite carousel met silent-reset techniek:
     - Items worden via JS 2x gekloond (totaal 3 sets) zodat de rij
       visueel oneindig doorgaat.
     - Scrollpositie start in de middelste set.
     - Na elke scroll-eind (scrollend event of debounced fallback): als
       de gebruiker in de eerste of derde set zit, springen we silent
       (zonder animatie) terug naar de equivalente positie in de middelste
       set. Voor de gebruiker is dit onzichtbaar omdat de cards identiek
       zijn aan wat ze net zagen.
     - Op mobile is de rij stacked (geen scroll), dus geen cloning. */
  type Direction = -1 | 1;

  function cardStep(row: HTMLElement): number {
    const firstCard = row.querySelector<HTMLElement>('.cases-row-item');
    if (!firstCard) return 0;
    const styles = window.getComputedStyle(row);
    const gap = parseFloat(styles.columnGap || styles.gap || '0');
    return firstCard.offsetWidth + gap;
  }

  function scrollByCard(row: HTMLElement, direction: Direction) {
    const step = cardStep(row);
    if (step === 0) return;
    row.scrollBy({ left: step * direction, behavior: 'smooth' });
  }

  const mql = window.matchMedia('(max-width: 640px)');

  document.querySelectorAll<HTMLElement>('[data-cases-wrap]').forEach((wrap) => {
    const id = wrap.dataset.casesWrap;
    if (!id) return;
    const row = wrap.querySelector<HTMLElement>(`[data-cases-row="${id}"]`);
    const prev = wrap.querySelector<HTMLButtonElement>(`[data-cases-prev="${id}"]`);
    const next = wrap.querySelector<HTMLButtonElement>(`[data-cases-next="${id}"]`);
    if (!row || !prev || !next) return;

    const originals = Array.from(row.children) as HTMLElement[];
    let setWidth = 0;
    let cloned = false;

    /* Bouw clones op desktop, sloop ze op mobile. */
    function syncClones() {
      const isMobile = mql.matches;
      if (isMobile && cloned) {
        Array.from(row.querySelectorAll<HTMLElement>('.is-clone')).forEach((n) => n.remove());
        cloned = false;
        setWidth = 0;
      } else if (!isMobile && !cloned) {
        for (let i = 0; i < 2; i++) {
          originals.forEach((item) => {
            const clone = item.cloneNode(true) as HTMLElement;
            clone.classList.add('is-clone');
            clone.setAttribute('aria-hidden', 'true');
            clone.removeAttribute('id');
            row.appendChild(clone);
          });
        }
        cloned = true;
        const step = cardStep(row);
        setWidth = step * originals.length;
        /* Start in middelste set zodat zowel links als rechts content is. */
        row.scrollLeft = setWidth;
      }
    }

    /* Silent reposition naar middelste set wanneer scroll buiten range valt. */
    function maybeReposition() {
      if (!cloned || setWidth === 0) return;
      if (row.scrollLeft < setWidth * 0.5) {
        row.scrollTo({ left: row.scrollLeft + setWidth, behavior: 'instant' as ScrollBehavior });
      } else if (row.scrollLeft > setWidth * 2.5) {
        row.scrollTo({ left: row.scrollLeft - setWidth, behavior: 'instant' as ScrollBehavior });
      }
    }

    /* Listener: scrollend waar mogelijk, anders debounced scroll. */
    const supportsScrollend = 'onscrollend' in window;
    if (supportsScrollend) {
      row.addEventListener('scrollend', maybeReposition);
    } else {
      let timer = 0;
      row.addEventListener('scroll', () => {
        clearTimeout(timer);
        timer = window.setTimeout(maybeReposition, 180);
      }, { passive: true });
    }

    prev.addEventListener('click', () => scrollByCard(row, -1));
    next.addEventListener('click', () => scrollByCard(row, 1));

    function updateNav() {
      const navWrap = wrap.querySelector<HTMLElement>('.cases-row-nav-wrap');
      if (!navWrap) return;
      if (mql.matches) {
        navWrap.style.display = 'none';
        return;
      }
      const noOverflow = row.scrollWidth <= row.clientWidth + 4;
      navWrap.style.display = noOverflow ? 'none' : '';
    }

    syncClones();
    updateNav();
    window.addEventListener('resize', () => {
      syncClones();
      updateNav();
    });
  });
</script>
