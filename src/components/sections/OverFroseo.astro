---
import EyebrowPill from '../ui/EyebrowPill.astro';

interface USPItem {
  num: string;
  headline: string;
}

interface Props {
  cities?: string[];
  usps?: USPItem[];
  eyebrow?: string;
  titleLine1?: string;
  titleAccent?: string;
  /** Lead-alinea's. Default = NL-copy. Engelse homepage geeft eigen tekst mee. */
  lead?: string[];
}

const {
  eyebrow = 'Over Froseo',
  titleLine1 = 'Utrechtse eigenzinnigheid.',
  titleAccent = 'Efficiënt & creatief.',
  lead = [
    'Froseo is born and raised in Utrecht en daar zijn we trots op! Zo benutten wij onze Utrechtse eigenzinnigheid volop tijdens het uitvoeren van onze webdesign & marketing projecten.',
    'Ons hoofdkwartier staat weliswaar in de Domstad, maar we beperken ons natuurlijk niet tot Utrecht. Wij werken met dezelfde passie voor bedrijven buiten "het hartsie van het land". Zo zijn wij minimaal net zo blij met onze samenwerkingen in onder andere Amersfoort, Zeist, Rotterdam, Delft, Hoorn, Doetinchem en Deventer.',
  ],
  cities = [
    'Utrecht',
    'Amersfoort',
    'Zeist',
    'Rotterdam',
    'Delft',
    'Hoorn',
    'Doetinchem',
    'Deventer',
    'Amsterdam',
    'Haarlem',
    'Den Bosch',
    'Eindhoven',
  ],
  usps = [
    { num: '01', headline: 'Direct contact met je expert.' },
    { num: '02', headline: 'Geen lange wurgcontracten.' },
    { num: '03', headline: 'Volledig ontzorgd, done-for-you.' },
    { num: '04', headline: 'De kracht van AI volop benut.' },
  ],
} = Astro.props;

// Duplicate cities for seamless infinite scroll
const cityLoop = [...cities, ...cities];
---

<section class="over-froseo" id="over-ons">
  <div class="over-froseo-inner">
    <div class="over-froseo-head">
      <EyebrowPill variant="highlight" star="◆">{eyebrow}</EyebrowPill>
      <h2 class="over-froseo-title">
        {titleLine1}<br /><em>{titleAccent}</em>
      </h2>
    </div>

    <div class="over-froseo-body">
      <div class="over-froseo-lead">
        {lead.map((p) => <p>{p}</p>)}
      </div>

      <ol class="over-froseo-usps">
        {
          usps.map((u) => (
            <li class="over-usp">
              <span class="over-usp-num">{u.num}</span>
              <span class="over-usp-headline">{u.headline}</span>
            </li>
          ))
        }
      </ol>
    </div>

    <div class="over-froseo-cities">
      <div class="cities-strip">
        {
          cityLoop.map((c, i) => (
            <>
              <span class="city">{c}</span>
              {i < cityLoop.length - 1 && <span class="city-sep">★</span>}
            </>
          ))
        }
      </div>
    </div>
  </div>
</section>
