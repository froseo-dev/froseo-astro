---
import EyebrowPill from '../ui/EyebrowPill.astro';
import { stats as configStats } from '@data/site-config';

interface Stat { num: string; label: string; }
interface Props {
  eyebrow?: string;
  titleLine1?: string;
  titleLine2?: string;
  titleAccent?: string;
  stats?: Stat[];
}

const {
  eyebrow = 'De cijfers',
  titleLine1 = 'Webdesign & marketing',
  titleLine2 = 'uit Utrecht,',
  titleAccent = 'voor heel Nederland.',
  /* Default vanuit site-config — zo passen alle pagina's met Stats-blok
     zich automatisch aan als je een cijfer wijzigt. */
  stats = configStats.map((s) => ({ num: s.value, label: s.label })),
} = Astro.props;
---

<section class="stats">
  <div class="stats-inner">
    <div class="stats-head">
      <EyebrowPill variant="highlight" star="◆">{eyebrow}</EyebrowPill>
      <h2 class="title">
        {titleLine1}<br />{titleLine2}<br /><em>{titleAccent}</em>
      </h2>
    </div>
    <div class="stats-grid">
      {
        stats.map((s) => (
          <div class="stat-card">
            <div class="num">{s.num}</div>
            <div class="lbl">{s.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
