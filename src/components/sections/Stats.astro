---
import EyebrowPill from '../ui/EyebrowPill.astro';

interface Stat { num: string; label: string; }
interface Props {
  eyebrow?: string;
  titleLine1?: string;
  titleLine2?: string;
  stats?: Stat[];
}

const {
  eyebrow = 'De cijfers',
  titleLine1 = 'Webdesign & marketing uit Utrecht,',
  titleLine2 = 'voor heel Nederland.',
  stats = [
    { num: '80+', label: 'Projecten live' },
    { num: '25+', label: "Plaatsen #1 ranking" },
    { num: '5/5', label: 'Op Google reviews' },
    { num: '15+', label: 'Jaar ervaring' },
  ],
} = Astro.props;
---

<section class="stats">
  <div class="stats-inner">
    <div class="stats-head">
      <EyebrowPill variant="highlight" star="◆">{eyebrow}</EyebrowPill>
      <h2 class="title">
        {titleLine1}<br /><em>{titleLine2}</em>
      </h2>
    </div>
    <div class="stats-grid">
      {
        stats.map((s) => (
          <div class="stat-card">
            <div class="num">{s.num}</div>
            <div class="lbl">{s.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
