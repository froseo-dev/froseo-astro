---
/**
 * Website-abonnement-pakketten-sectie voor /website-abonnement.
 * Twee cards naast elkaar (Online Start + Online Plus). Eén vaste
 * maandprijs per pakket; geen maand/jaar-toggle meer.
 *
 * Setup-fee verschil bij Online Start staat als sub-line onder de
 * prijs ("Geen setup fee bij jaarcontract, €199 bij maandcontract").
 *
 * Data komt uit src/data/abo-packages.ts (single source of truth).
 */

import EyebrowPill from '../ui/EyebrowPill.astro';
import { aboPackages, aboTerms } from '@data/abo-packages';
import { pricing as sitePricing } from '@data/site-config';

interface Props {
  eyebrow?: string;
  title?: string;
  titleAccent?: string;
  lead?: string;
}

const {
  eyebrow = 'Pakketten',
  title = 'Twee abonnementen,',
  titleAccent = 'één framework.',
  lead = 'Kies de tier die past bij waar je nu staat. Je groeit op elk moment door naar Online Plus zonder nieuwe build.',
} = Astro.props;
---

<section class="pricing-packages abo-packages" id="pakketten">
  <div class="pricing-head">
    <EyebrowPill variant="rare">{eyebrow}</EyebrowPill>
    <h2 class="pricing-title">
      {title} <em>{titleAccent}</em>
    </h2>
    <p class="pricing-lead">{lead}</p>
  </div>

  <div class="pricing-grid abo-grid">
    {aboPackages.map((pkg) => (
      <article class={`pricing-card ${pkg.isFeatured ? 'is-featured' : ''}`}>
        {pkg.isFeatured && <span class="pricing-card-badge">Meest gekozen</span>}
        <header class="pricing-card-head">
          <h3 class="pricing-card-name">{pkg.name}</h3>
          <p class="pricing-card-tagline">{pkg.tagline}</p>
          <div class="pricing-card-price">
            <span class="pricing-amount-prefix">€</span>
            <span class="pricing-amount">{pkg.monthlyPrice}</span>
            <span class="pricing-period">/maand</span>
          </div>
          <p class="pricing-billing">
            {pkg.setupFeeMonthlyContract && pkg.setupFeeMonthlyContract > 0 ? (
              <span>Geen setup fee bij jaarcontract · €{pkg.setupFeeMonthlyContract} setup bij maandcontract · {sitePricing.vatNote}</span>
            ) : (
              <span>Geen setup fee · {sitePricing.vatNote}</span>
            )}
          </p>
          <p class="pricing-card-for">{pkg.forWhom}</p>
        </header>
        <ul class="pricing-card-features">
          {pkg.features.map((f) => (
            <li class={`${f.highlight ? 'is-highlight' : ''} ${f.upcoming ? 'is-upcoming' : ''}`.trim()}>
              <span class="check-icon" aria-hidden="true">{f.upcoming ? '◷' : '✓'}</span>
              <span>
                {f.label}
                {f.upcoming && <span class="abo-feature-tag">Binnenkort</span>}
              </span>
            </li>
          ))}
        </ul>
        <a
          class={pkg.isFeatured ? 'btn-primary pricing-card-cta' : 'btn-ghost pricing-card-cta'}
          href={`/contact/?onderwerp=${pkg.slug}`}
        >
          Kies {pkg.shortName ?? pkg.name} ↗
        </a>
      </article>
    ))}
  </div>

  <ul class="abo-terms-strip" aria-label="Voorwaarden">
    {aboTerms.map((t) => (
      <li>
        <span class="abo-terms-icon" aria-hidden="true">✓</span>
        <span>{t}</span>
      </li>
    ))}
  </ul>
</section>
