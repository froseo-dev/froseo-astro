---
import EyebrowPill from '../ui/EyebrowPill.astro';
import logoWhite from '@assets/brand/froseo-logo-wit.webp';

interface Step { num: string; title: string; description: string; }
interface Props {
  eyebrow?: string;
  titleLine1?: string;
  titleAccent?: string;
  titleLine3?: string;
  desc1?: string;
  desc2?: string;
  ctaLabel?: string;
  ctaHref?: string;
  steps?: Step[];
  /** When true, renders the Froseo logo as a faded watermark behind the section. */
  watermark?: boolean;
}

const {
  eyebrow = 'Zo werken we',
  titleLine1 = 'Een aanpak',
  titleAccent = 'zonder',
  titleLine3 = 'gedoe.',
  desc1 = 'Geen wekenlange discovery-fases, geen vage offertes en geen lagen van accountmanagers tussen jou en het werk. We kijken wat jouw bedrijf online nodig heeft en vertalen dat naar een concreet plan voor website, vindbaarheid en groei.',
  desc2 = 'Daarna gaan we bouwen, verbeteren en meten. In duidelijke stappen, met korte lijnen en zonder onnodige poespas.',
  ctaLabel = 'Maak een afspraak →',
  ctaHref = '#cta',
  steps = [
    {
      num: '01',
      title: 'Kennismaken',
      description: 'We leren je bedrijf kennen en bepalen wat je online nodig hebt: een sterke website, betere vindbaarheid, meer aanvragen of alles tegelijk.',
    },
    {
      num: '02',
      title: 'Groeiplan maken',
      description: 'We vertalen je doelen naar een concreet plan voor webdesign, content, SEO en marketing. Geen dikke rapporten, maar duidelijke keuzes.',
    },
    {
      num: '03',
      title: 'Bouwen & optimaliseren',
      description: "We maken wat nodig is om vooruit te komen: websites, pagina's, content, SEO-verbeteringen, campagnes en conversie-optimalisatie.",
    },
    {
      num: '04',
      title: 'Meten & doorgroeien',
      description: 'Na livegang of start van het traject blijven we meten, verbeteren en bijsturen. Zo wordt je online basis steeds sterker.',
    },
  ],
  watermark = false,
} = Astro.props;
---

<section class={`approach${watermark ? ' approach--watermark' : ''}`} id="aanpak">
  {watermark && (
    <img src={logoWhite.src} alt="" class="approach-watermark" aria-hidden="true" loading="lazy" />
  )}
  <div class="approach-grid">
    <div class="approach-left">
      <EyebrowPill variant="rare">{eyebrow}</EyebrowPill>
      <h2 class="title">
        {titleLine1}<br /><em>{titleAccent}</em> {titleLine3}
      </h2>
      <p class="desc">{desc1}</p>
      <p class="desc">{desc2}</p>
      <a class="btn-primary" href={ctaHref}>{ctaLabel}</a>
    </div>

    <div class="steps">
      {
        steps.map((step) => (
          <div class="step">
            <div class="step-num">{step.num}</div>
            <div class="step-content">
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
