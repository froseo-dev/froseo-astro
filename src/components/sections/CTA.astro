---
import EyebrowPill from '../ui/EyebrowPill.astro';

interface Props {
  eyebrow?: string;
  titleLine1?: string;
  titleAccent?: string;
  text?: string;
  features?: string[];
  formTitle?: string;
  submitLabel?: string;
  formAction?: string;
  /** `form` (default) renders the analyse-aanvraag form on the right.
   *  `link`  renders a single CTA button (used for the secondary "plan een gesprek"). */
  variant?: 'form' | 'link';
  linkLabel?: string;
  linkHref?: string;
  linkMeta?: string;
  /** Override the section id for anchor linking. */
  sectionId?: string;
}

const {
  eyebrow = 'Klaar voor groei?',
  titleLine1 = 'Van onzichtbaar',
  titleAccent = 'naar onmisbaar.',
  text = 'Gratis website-analyse in 48 uur. We kijken naar SEO, snelheid en conversie van je huidige site en sturen drie concrete aanbevelingen terug waar je meteen mee aan de slag kunt.',
  features = ['Binnen 48u', 'Vrijblijvend', 'Geen sales'],
  formTitle = 'Start je analyse ↗',
  submitLabel = 'Verstuur analyse-verzoek ↗',
  formAction,
  variant = 'form',
  linkLabel = 'Plan een gesprek ↗',
  linkHref = '/contact/',
  linkMeta = '30 minuten · vrijblijvend',
  sectionId = 'cta',
} = Astro.props;
---

<section class={`cta cta--${variant}`} id={sectionId}>
  <div class="cta-card">
    <div class="cta-left">
      <EyebrowPill variant="highlight">{eyebrow}</EyebrowPill>
      <h2 class="cta-title">
        {titleLine1}<br /><em>{titleAccent}</em>
      </h2>
      <p class="cta-text">{text}</p>
      {variant === 'form' && features.length > 0 && (
        <div class="cta-features">
          {features.map((f) => <span><span class="check">✓</span> {f}</span>)}
        </div>
      )}
    </div>

    {variant === 'form' ? (
      <form
        class="cta-form"
        action="/api/contact"
        method="post"
        data-analyse-form
        novalidate
      >
        <div class="cta-form-title">{formTitle}</div>
        <div class="form-field">
          <label for="cta-website">Jouw website</label>
          <input id="cta-website" name="current_website" type="url" placeholder="www.jouwbedrijf.nl" required />
        </div>
        <div class="form-field">
          <label for="cta-email">E-mailadres</label>
          <input id="cta-email" name="email" type="email" placeholder="je@jouwbedrijf.nl" required />
        </div>

        {/* Hidden context-velden — onderwerp tag + synthetische name/message
            zodat /api/contact's validatie slaagt zonder dat we extra inputs
            van de bezoeker vragen. JS vult name+message bij submit aan. */}
        <input type="hidden" name="onderwerp" value="Gratis website-analyse" />
        <input type="hidden" name="name" value="Analyse-aanvraag" data-cta-name />
        <input type="hidden" name="message" value="Verzoek voor een gratis website-analyse." data-cta-message />

        {/* Anti-bot: honeypot + tijd-op-pagina. Server checkt beide. */}
        <div class="form-honeypot" aria-hidden="true">
          <label>Website (laat dit veld leeg)
            <input type="text" name="website_url" tabindex="-1" autocomplete="off" />
          </label>
          <label>Onderwerp
            <input type="text" name="subject" tabindex="-1" autocomplete="off" />
          </label>
          <label>Bedrijf
            <input type="text" name="company" tabindex="-1" autocomplete="off" />
          </label>
        </div>
        <input type="hidden" name="form_started_at" value="" data-cta-started-at />

        <button class="form-btn" type="submit">{submitLabel}</button>
        <span class="form-small" data-cta-status role="status" aria-live="polite">100% vrijblijvend</span>
      </form>
    ) : (
      <div class="cta-action">
        <a class="btn-primary cta-action-btn" href={linkHref}>{linkLabel}</a>
        <div class="cta-action-meta">{linkMeta}</div>
      </div>
    )}
  </div>
</section>

<script>
  /* CTA-form submit-handler — fetch naar /api/contact zonder page-reload.
     Synthetiseert name + message uit de URL/email zodat de gedeelde endpoint
     z'n validatie kan doen, en geeft inline status terug aan de bezoeker. */
  const form = document.querySelector<HTMLFormElement>('[data-analyse-form]');
  const status = document.querySelector<HTMLElement>('[data-cta-status]');
  const startedAt = document.querySelector<HTMLInputElement>('[data-cta-started-at]');
  const nameField = document.querySelector<HTMLInputElement>('[data-cta-name]');
  const messageField = document.querySelector<HTMLInputElement>('[data-cta-message]');

  if (startedAt) startedAt.value = String(Date.now());

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !status) return;

    const submitBtn = form.querySelector<HTMLButtonElement>('.form-btn');
    submitBtn?.setAttribute('disabled', 'true');
    status.textContent = 'Versturen…';

    /* Vul name + message met context vanuit het ingevulde formulier
       (e-mail-prefix als naam, URL in het bericht) — server-side
       validatie eist beide velden ≥ 1 char en bericht ≥ 10 chars. */
    const formData = new FormData(form);
    const email = (formData.get('email') ?? '').toString();
    const website = (formData.get('current_website') ?? '').toString();
    if (nameField && email) {
      nameField.value = email.split('@')[0] || 'Analyse-aanvraag';
      formData.set('name', nameField.value);
    }
    if (messageField && website) {
      messageField.value = `Verzoek voor een gratis website-analyse van ${website}.`;
      formData.set('message', messageField.value);
    }

    try {
      const res = await fetch('/api/contact', { method: 'POST', body: formData });
      const json = await res.json().catch(() => ({}));
      if (res.ok && json.ok) {
        status.textContent = '✓ Verstuurd. We nemen snel contact op.';
        status.className = 'form-small is-success';
        form.reset();
        if (startedAt) startedAt.value = String(Date.now());
      } else {
        status.textContent = json.error ?? 'Versturen mislukt. Probeer het later opnieuw.';
        status.className = 'form-small is-error';
      }
    } catch {
      status.textContent = 'Versturen mislukt. Probeer het later opnieuw.';
      status.className = 'form-small is-error';
    } finally {
      submitBtn?.removeAttribute('disabled');
    }
  });
</script>
