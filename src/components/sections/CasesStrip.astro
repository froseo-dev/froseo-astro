---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import EyebrowPill from '../ui/EyebrowPill.astro';

interface Props {
  eyebrow?: string;
  titleLine1?: string;
  titleLead?: string;
  titleAccent?: string;
  lead?: string;
  /** Array of slugs to control order. First slug becomes the featured (large) case. */
  pickSlugs?: string[];
  moreLabel?: string;
  moreHref?: string;
}

const {
  eyebrow = 'Cases · Echte resultaten',
  titleLine1 = 'Bewezen succesverhalen',
  titleLead = 'voor',
  titleAccent = 'ambitieus MKB.',
  lead = 'Geen loze beloftes, maar meetbare resultaten. Ontdek hoe wij MKB-bedrijven helpen groeien met slimme strategieën en doordachte uitvoering.',
  pickSlugs,
  moreLabel = 'Meer cases →',
  moreHref = '/werk',
} = Astro.props;

const all = await getCollection('cases', ({ data }) => data.published !== false);
const sorted = all.sort((a, b) => a.data.order - b.data.order);
const cases = pickSlugs
  ? pickSlugs.map((s) => sorted.find((c) => c.data.slug === s)).filter(Boolean)
  : sorted.filter((c) => c.data.featured);

const [featured, ...rest] = cases;
const others = rest.slice(0, 3);
---

<section class="cases-strip" id="werk">
  <div class="cases-strip-head">
    <EyebrowPill variant="rare">{eyebrow}</EyebrowPill>
    <h2 class="cases-strip-title">
      {titleLine1}<br />{titleLead} <em>{titleAccent}</em>
    </h2>
    <p class="cases-strip-lead">{lead}</p>
  </div>

  {featured && (
    <div class="cases-grid">
      <article class="case-card case-card--featured">
        <div class="case-card-media">
          <Image
            src={featured.data.hero}
            alt={`${featured.data.client} — ${featured.data.tagline}`}
            class="case-card-img"
            widths={[600, 900, 1200]}
            sizes="(max-width: 1024px) 100vw, 600px"
            loading="lazy"
          />
          <div class="case-tags">
            {featured.data.tags.map((t) => (
              <span class={`case-tag ${t.color}`}>{t.label}</span>
            ))}
          </div>
          <div class="case-featured-badge" aria-hidden="true">
            <span class="case-featured-star">★</span>
          </div>
        </div>
        <div class="case-card-body">
          <h3 class="case-card-name">{featured.data.client}</h3>
          <p class="case-card-tagline">{featured.data.description ?? featured.data.tagline}</p>
          {featured.data.metrics && (
            <div class="case-card-metrics">
              {featured.data.metrics.map((m) => (
                <div class="case-metric">
                  <div class="case-metric-value">{m.value}</div>
                  <div class="case-metric-label">{m.label}</div>
                </div>
              ))}
            </div>
          )}
          <div class="case-card-cta">
            <span>Bekijk case</span>
            <span class="arrow">→</span>
          </div>
        </div>
      </article>

      {others.map((c) => (
        <article class="case-card">
          <div class="case-card-media">
            <Image
              src={c!.data.hero}
              alt={`${c!.data.client} — ${c!.data.tagline}`}
              class="case-card-img"
              widths={[400, 600, 800]}
              sizes="(max-width: 1024px) 100vw, 400px"
              loading="lazy"
            />
            <div class="case-tags">
              {c!.data.tags.map((t) => (
                <span class={`case-tag ${t.color}`}>{t.label}</span>
              ))}
            </div>
            {!c!.data.metrics && <div class="case-result">{c!.data.result}</div>}
          </div>
          <div class="case-card-body">
            <h3 class="case-card-name">{c!.data.client}</h3>
            <p class="case-card-tagline">{c!.data.description ?? c!.data.tagline}</p>
            {c!.data.metrics && (
              <div class="case-card-metrics">
                {c!.data.metrics.map((m) => (
                  <div class="case-metric">
                    <div class="case-metric-value">{m.value}</div>
                    <div class="case-metric-label">{m.label}</div>
                  </div>
                ))}
              </div>
            )}
            <div class="case-card-cta">
              <span>Bekijk case</span>
              <span class="arrow">→</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  )}

  <div class="cases-footer">
    <a class="btn-ghost cases-more" href={moreHref}>{moreLabel}</a>
  </div>
</section>
