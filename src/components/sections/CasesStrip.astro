---
/**
 * Homepage cases-strip. Eyebrow + h2 + lead bovenin, daaronder de
 * scroll-snap cases-rij (CasesRow), met dual-button footer (cases +
 * portfolio).
 */
import { getCollection } from 'astro:content';
import EyebrowPill from '../ui/EyebrowPill.astro';
import CasesRow from './CasesRow.astro';

interface Props {
  eyebrow?: string;
  titleLine1?: string;
  titleLead?: string;
  titleAccent?: string;
  lead?: string;
  /** Welke cases tonen (in deze volgorde). Default = featured cases op order. */
  pickSlugs?: string[];
  mobileLimit?: number;
  casesLabel?: string;
  casesHref?: string;
  portfolioLabel?: string;
  portfolioHref?: string;
}

const {
  eyebrow = 'Onze cases',
  titleLine1 = 'Bewezen succesverhalen',
  titleLead = 'voor',
  titleAccent = 'ambitieus MKB.',
  lead = 'Een selectie van klanten waar onze aanpak meetbaar verschil heeft gemaakt. Cijfers staan erbij, vaag groeipraatje achterwege.',
  pickSlugs,
  mobileLimit = 4,
  casesLabel = 'Bekijk alle cases ↗',
  casesHref = '/cases/',
  portfolioLabel = 'Bekijk portfolio ↗',
  portfolioHref = '/portfolio/',
} = Astro.props;

const all = await getCollection('cases', ({ data }) => data.published !== false);
const sorted = all.sort((a, b) => a.data.order - b.data.order);
const cases = pickSlugs
  ? (pickSlugs
      .map((s) => sorted.find((c) => c.data.slug === s))
      .filter(Boolean) as typeof sorted)
  : sorted.filter((c) => c.data.featured);
---

<section class="cases-strip" id="cases">
  <div class="cases-strip-head">
    <EyebrowPill variant="rare">{eyebrow}</EyebrowPill>
    <h2 class="cases-strip-title">
      {titleLine1}<br />{titleLead} <em>{titleAccent}</em>
    </h2>
    <p class="cases-strip-lead">{lead}</p>
  </div>

  <CasesRow cases={cases} mobileLimit={mobileLimit} id="homepage-cases" />

  <div class="cases-footer cases-footer--dual">
    <a class="btn-primary cases-footer-btn" href={casesHref}>{casesLabel}</a>
    <a class="btn-ghost cases-footer-btn" href={portfolioHref}>{portfolioLabel}</a>
  </div>
</section>
