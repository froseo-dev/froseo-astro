---
import { getCollection } from 'astro:content';
import EyebrowPill from '../ui/EyebrowPill.astro';

interface Props {
  eyebrow?: string;
  titleLine1?: string;
  titleLine2?: string;
  accent?: string;
  intro?: string;
}

const {
  eyebrow = 'Wat we doen',
  titleLine1 = 'Geen bullshit.',
  titleLine2 = 'Wel',
  accent = 'resultaat.',
  intro = 'De meeste bureaus leveren een site af en wensen je succes. Wij niet. Wij bouwen een doordachte basis en zorgen daarna met gerichte marketing dat die site daadwerkelijk geld gaat opleveren.',
} = Astro.props;

const services = (await getCollection('services', ({ data }) => data.featured))
  .sort((a, b) => a.data.order - b.data.order);
---

<section class="services" id="diensten">
  <div class="section-head">
    <div class="section-head-left">
      <EyebrowPill>{eyebrow}</EyebrowPill>
      <h2 class="title">
        {titleLine1}<br />{titleLine2} <span class="accent">{accent}</span>
      </h2>
    </div>
    <div class="section-head-right">
      <p>{intro}</p>
    </div>
  </div>

  <div class="services-grid">
    {
      services.map((service) => (
        <a href={`/diensten/${service.data.slug}`} class={`service-card ${service.data.shadow}-shadow`}>
          <div class="service-icon">{service.data.icon}</div>
          <div class="service-num">{service.data.eyebrow}</div>
          <h3 class="service-title">{service.data.title}</h3>
          <p class="service-desc">{service.data.description}</p>
          <ul class="service-list">
            {service.data.bullets.map((b) => <li>{b}</li>)}
          </ul>
          <div class="service-arrow">↗</div>
        </a>
      ))
    }
  </div>
</section>
