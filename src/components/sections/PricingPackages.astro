---
/**
 * Pricing-pakket-sectie met 3 cards naast elkaar (basis/standaard/premium)
 * + Custom-strip eronder + maand/jaar toggle.
 *
 * Data komt uit src/data/maintenance-packages.ts (single source of truth).
 * Wijzig prijzen of features daar; deze component pakt automatisch de update.
 */

import EyebrowPill from '../ui/EyebrowPill.astro';
import {
  maintenancePackages,
  maintenanceCustom,
} from '@data/maintenance-packages';

interface Props {
  eyebrow?: string;
  title?: string;
  titleAccent?: string;
  lead?: string;
  /** 'contact' (default): knop linkt naar /contact/?onderwerp=<slug>.
   *  'leadform': knop scrollt naar het #check-formulier op dezelfde pagina
   *  (gebruikt op de Ads-landingspagina, houdt de bezoeker op het pad). */
  ctaMode?: 'contact' | 'leadform';
  /** Toon de "Andere wensen?"-custom-strip onder de cards. Op de Ads-LP uit
   *  om de bezoeker in de conversieflow te houden. */
  showCustom?: boolean;
}

const {
  eyebrow = 'Pakketten',
  title = 'Onze',
  titleAccent = 'onderhoudspakketten.',
  lead = 'Drie pakketten met heldere prijzen. Maandelijks opzegbaar, of jaarlijks met één maand gratis. Doorgroeien tussen pakketten kan op elk moment.',
  ctaMode = 'contact',
  showCustom = true,
} = Astro.props;
---

<section class="pricing-packages" id="pakketten">
  <div class="pricing-head">
    <EyebrowPill variant="rare">{eyebrow}</EyebrowPill>
    <h2 class="pricing-title">
      {title} <em>{titleAccent}</em>
    </h2>
    <p class="pricing-lead">{lead}</p>

    <!-- Maand/jaar toggle. Default = jaarlijks (CRO-strategie: lagere
         effectieve maandprijs zichtbaar bij landing). -->
    <div class="pricing-toggle" role="tablist" aria-label="Betalingsfrequentie">
      <button type="button" class="pricing-toggle-btn" data-frequency="monthly" role="tab" aria-selected="false">
        Per maand
      </button>
      <button type="button" class="pricing-toggle-btn is-active" data-frequency="yearly" role="tab" aria-selected="true">
        Per jaar <span class="pricing-toggle-badge">1 maand gratis</span>
      </button>
    </div>
  </div>

  <div class="pricing-grid">
    {maintenancePackages.map((pkg) => {
      /* Effectieve maandprijs bij jaarlijkse facturatie = yearly / 12. */
      const yearlyMonthly = (pkg.yearlyPrice / 12).toFixed(2).replace('.', ',');
      return (
      <article class={`pricing-card ${pkg.isFeatured ? 'is-featured' : ''}`}>
        {pkg.isFeatured && <span class="pricing-card-badge">Meest gekozen</span>}
        <header class="pricing-card-head">
          <h3 class="pricing-card-name">{pkg.name}</h3>
          <p class="pricing-card-tagline">{pkg.tagline}</p>
          <div class="pricing-card-price">
            <span class="pricing-amount-prefix">€</span>
            <span class="pricing-amount" data-monthly={pkg.monthlyPrice} data-yearly-effective={yearlyMonthly}>
              {yearlyMonthly}
            </span>
            <span class="pricing-period">/maand</span>
          </div>
          <p class="pricing-billing">
            <span data-frequency-label="monthly" hidden>Maandelijks gefactureerd</span>
            <span data-frequency-label="yearly">Jaarlijks gefactureerd, €{pkg.yearlyPrice}/jaar</span>
          </p>
        </header>
        <ul class="pricing-card-features">
          {pkg.summary && (
            <li class="pricing-summary is-highlight">
              <span class="check-icon" aria-hidden="true">✓</span>
              <span>{pkg.summary}</span>
            </li>
          )}
          {pkg.features.filter((f) => f.primary).map((f) => (
            <li class={f.highlight ? 'is-highlight' : ''}>
              <span class="check-icon" aria-hidden="true">✓</span>
              <span>{f.label}{f.detail && <small class="pricing-feat-detail">{f.detail}</small>}</span>
            </li>
          ))}
          {pkg.features.filter((f) => !f.primary).map((f) => (
            <li class={`pricing-feat-extra${f.highlight ? ' is-highlight' : ''}`}>
              <span class="check-icon" aria-hidden="true">✓</span>
              <span>{f.label}{f.detail && <small class="pricing-feat-detail">{f.detail}</small>}</span>
            </li>
          ))}
        </ul>
        {pkg.features.some((f) => !f.primary) && (
          <button type="button" class="pricing-more" data-more aria-expanded="false">
            Bekijk alle onderdelen
          </button>
        )}
        {ctaMode === 'leadform' ? (
          <a
            class={pkg.isFeatured ? 'btn-primary pricing-card-cta' : 'btn-ghost pricing-card-cta'}
            href="#check"
            data-package={pkg.slug}
            data-package-name={pkg.shortName ?? pkg.name}
          >
            Vraag {pkg.shortName ?? pkg.name} aan ↗
          </a>
        ) : (
          <a class={pkg.isFeatured ? 'btn-primary pricing-card-cta' : 'btn-ghost pricing-card-cta'} href={`/contact/?onderwerp=${pkg.slug}`}>
            Kies {pkg.shortName ?? pkg.name} ↗
          </a>
        )}
      </article>
      );
    })}
  </div>

  <!-- Custom-strip onder de drie cards -->
  {showCustom && (
    <div class="pricing-custom">
      <div class="pricing-custom-text">
        <h3 class="pricing-custom-title">{maintenanceCustom.title}</h3>
        <p class="pricing-custom-body">{maintenanceCustom.body}</p>
      </div>
      <a class="btn-ghost pricing-custom-cta" href={maintenanceCustom.ctaHref}>{maintenanceCustom.ctaLabel}</a>
    </div>
  )}
</section>

<script>
  /* Toggle tussen maand/jaar prijzen — switcht prijsbedrag + periode-label
     in elke card. Geen reload, geen flicker. */
  const toggleBtns = document.querySelectorAll<HTMLButtonElement>('.pricing-toggle-btn');
  const amounts = document.querySelectorAll<HTMLElement>('.pricing-amount');
  const periodLabels = document.querySelectorAll<HTMLElement>('[data-frequency-label]');

  function setFrequency(freq: 'monthly' | 'yearly') {
    toggleBtns.forEach((b) => {
      const active = b.dataset.frequency === freq;
      b.classList.toggle('is-active', active);
      b.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    /* Bij maandelijks: gewone monthlyPrice. Bij jaarlijks: yearly/12 (=
       effectieve maandprijs). Periode-label blijft altijd "/maand", alleen
       de billing-tekst eronder wisselt. */
    amounts.forEach((el) => {
      const value = freq === 'monthly' ? el.dataset.monthly : el.dataset.yearlyEffective;
      el.textContent = value ?? '';
    });
    periodLabels.forEach((el) => {
      el.hidden = el.dataset.frequencyLabel !== freq;
    });
  }

  toggleBtns.forEach((b) => {
    b.addEventListener('click', () => setFrequency(b.dataset.frequency as 'monthly' | 'yearly'));
  });

  /* "Bekijk alle onderdelen" — klapt de volledige lijst per card uit/in.
     Ingeklapt: summary + kernpunten. Uitgeklapt: summary weg, alle onderdelen. */
  document.querySelectorAll<HTMLButtonElement>('[data-more]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.pricing-card');
      if (!card) return;
      const expanded = card.classList.toggle('is-expanded');
      btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      btn.textContent = expanded ? 'Verberg onderdelen' : 'Bekijk alle onderdelen';
    });
  });
</script>

<style>
  /* Ingeklapt: extra-onderdelen verborgen, summary zichtbaar.
     Uitgeklapt (.is-expanded): extra's zichtbaar (grid, zoals global li),
     summary verborgen zodat de volledige concrete lijst overblijft. */
  .pricing-card-features li.pricing-feat-extra { display: none; }
  .pricing-card.is-expanded .pricing-card-features li.pricing-feat-extra { display: grid; }
  .pricing-card.is-expanded .pricing-summary { display: none; }
  /* Licentie-detailregel: alleen zichtbaar bij uitklappen. */
  .pricing-feat-detail { display: none; }
  .pricing-card.is-expanded .pricing-feat-detail {
    display: block;
    margin-top: 3px;
    font-size: 0.82em;
    line-height: 1.4;
    opacity: 0.7;
  }
  .pricing-more {
    align-self: flex-start;
    margin: 0.4rem 0 0.75rem;
    padding: 0;
    background: none;
    border: 0;
    font: inherit;
    font-weight: 600;
    color: var(--accent-primary, #6901aa);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  /* Featured (Standaard) card heeft een donkerpaarse achtergrond: paars valt
     daar weg, dus daar geel. */
  .pricing-card.is-featured .pricing-more { color: var(--accent-highlight); }
  .pricing-more:hover { opacity: 0.75; }
</style>
