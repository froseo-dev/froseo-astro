---
import { Image } from 'astro:assets';
import EyebrowPill from '../ui/EyebrowPill.astro';
import type { ImageMetadata } from 'astro';
import froseoMockup from '@assets/hero/froseo-mockup.webp';
import { pricing } from '@data/site-config';

interface Props {
  eyebrow?: string;
  titleLine1?: string;
  titleLine2?: string;
  accent?: string;
  /** Optional single-paragraph sub. Ignored if `bullets` is provided. */
  sub?: string;
  /** When set, renders a magenta-checkmark list below the h1 instead of the sub paragraph. */
  bullets?: string[];
  primaryCta?: { label: string; href: string };
  /** Optional second CTA — laat default leeg voor single-CTA hero. */
  secondaryCta?: { label: string; href: string };
  reviewsLabel?: string;
  resultLabel?: string;
  resultValue?: string;
  resultMeta?: string;
  /** Optional override for the hero mockup. Defaults to Calvin's composed Froseo mockup. */
  mockup?: ImageMetadata;
  mockupAlt?: string;
}

const {
  eyebrow = '15+ jaar ervaring · 80+ MKB-projecten',
  titleLine1 = 'Van onzichtbaar',
  titleLine2 = 'naar',
  accent = 'onmisbaar.',
  sub,
  bullets = [
    'AI-powered websites met een eigen smoel.',
    'Marketing die niet alleen bezoekers, maar klanten oplevert.',
    'Lokale SEO & GEO voor Google, Maps en AI.',
    `Nieuw: all-inclusive website abonnementen vanaf ${pricing.abboFromShort}.`,
  ],
  primaryCta = { label: 'Gratis analyse ↗', href: '#cta' },
  secondaryCta,
  reviewsLabel = '5/5',
  resultLabel = '★ Recent',
  resultValue = '+180% verkeer',
  resultMeta = 'Renovatie Totaal',
  mockup = froseoMockup,
  mockupAlt = 'Froseo — voorbeeld website mockup',
} = Astro.props;
---

<div class="hero-wrap">
  <section class="hero">
    <div class="hero-left">
      <EyebrowPill>{eyebrow}</EyebrowPill>
      <h1 class="hero-title">
        {titleLine1}<br />
        {titleLine2} <span class="accent">{accent}</span>
      </h1>
      {bullets && bullets.length > 0 ? (
        <ul class="hero-bullets">
          {bullets.map((b) => <li>{b}</li>)}
        </ul>
      ) : (
        <p class="hero-sub">{sub}</p>
      )}
      <div class="hero-actions">
        <a class="btn-primary" href={primaryCta.href}>{primaryCta.label}</a>
        {secondaryCta && (
          <a class="btn-ghost" href={secondaryCta.href}>{secondaryCta.label}</a>
        )}
      </div>
      <div class="reviews-inline">
        <div class="review-avatars">
          <div class="review-avatar"></div>
          <div class="review-avatar"></div>
          <div class="review-avatar"></div>
        </div>
        <div class="stars">★★★★★</div>
        <span><strong>{reviewsLabel}</strong> · Google reviews</span>
      </div>
    </div>

    <div class="hero-right">
      <div class="hero-mockups">
        <Image
          src={mockup}
          alt={mockupAlt}
          class="hero-mockup"
          widths={[640, 960, 1280, 1600, 1800]}
          sizes="(max-width: 1024px) 100vw, 640px"
          loading="eager"
          fetchpriority="high"
        />
        <div class="hero-result-card">
          <div class="result-icon">↗</div>
          <div class="result-content">
            <div class="label">{resultLabel}</div>
            <div class="value">{resultValue}</div>
            <div class="meta">{resultMeta}</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

