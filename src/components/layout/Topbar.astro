---
/**
 * Topbar boven het menu — promo-strookje, sticky bovenaan (samen met de
 * nav die eronder pint). Hele balk is een link naar het website abonnement,
 * want daar gaat de promo over. Zelfde tekst op desktop én mobiel.
 */
import { pricing } from '@data/site-config';

interface Props {
  /** Promo-tekst. */
  text?: string;
  /** Doel van de klik. Default = website abonnement pagina. */
  href?: string;
}
const {
  text = `Populair: een all-inclusive website vanaf ${pricing.abboFromShort}`,
  href = '/website-abonnement/',
} = Astro.props;
---

<a class="topbar" href={href}><span class="star">★</span> {text}</a>
