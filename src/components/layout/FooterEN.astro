---
/**
 * Engelse footer — compacte variant van de NL-footer (geen losse
 * servicepagina's in het Engels, dus minder kolommen). Hergebruikt de
 * globale .footer-classes en de taal-neutrale data uit site-config.
 */

import { Image } from 'astro:assets';
import ReviewBadge from '@components/ui/ReviewBadge.astro';
import logoWhite from '@assets/brand/froseo-logo-wit.webp';
import { contact, social } from '@data/site-config';
import { getSwitchHref } from '@data/i18n';

const langSwitchHref = getSwitchHref(Astro.url.pathname, 'en');
const year = new Date().getFullYear();

interface FooterLink { label: string; href: string; }
interface FooterColumn { title: string; links: FooterLink[]; }

const linkColumns: FooterColumn[] = [
  {
    title: 'What we do',
    links: [
      { label: 'Custom web design', href: '/en/#services' },
      { label: 'Website subscription', href: '/en/#services' },
      { label: 'Local SEO', href: '/en/#services' },
      { label: 'SEO & GEO', href: '/en/#services' },
      { label: 'Website maintenance', href: '/en/#services' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About us', href: '/en/about/' },
      { label: 'Contact', href: '/en/contact/' },
      { label: 'Privacy & cookies', href: '/privacybeleid/' },
      { label: 'Nederlandse versie', href: langSwitchHref },
    ],
  },
];
---

<footer class="footer">
  <a class="footer-logo" href="/en/" aria-label="Froseo home">
    <Image
      src={logoWhite}
      alt="Froseo"
      class="footer-logo-img"
      widths={[400, 800, 1200]}
      sizes="(max-width: 720px) 70vw, 600px"
      loading="lazy"
    />
  </a>

  <div class="footer-grid">
    <div class="footer-col footer-col--gegevens">
      <div class="footer-col-title">Details</div>
      <address class="footer-address">
        <p class="footer-address-line"><strong>Head office</strong></p>
        <p class="footer-address-line">{contact.address.street}</p>
        <p class="footer-address-line">{contact.address.postalCode} {contact.address.city}</p>
        <p class="footer-address-line">The Netherlands</p>
      </address>
      <ul class="footer-contact-list">
        <li><span class="footer-contact-label">Tel:</span> <a href={`tel:${contact.phoneTel}`}>{contact.phoneDisplay}</a></li>
        <li><span class="footer-contact-label">Mail:</span> <a href={`mailto:${contact.email}`}>{contact.email}</a></li>
        <li><span class="footer-contact-label">CoC:</span> {contact.kvk}</li>
      </ul>
    </div>

    {linkColumns.map((col) => (
      <div class="footer-col">
        <div class="footer-col-title">{col.title}</div>
        <ul>
          {col.links.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="footer-social">
    <ReviewBadge variant="compact" />
    <a
      class="footer-linkedin"
      href={social.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Follow Froseo on LinkedIn"
    >
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
        <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.26 2.37 4.26 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zm1.78 13.02H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
      </svg>
      <span>Follow us on LinkedIn</span>
    </a>
  </div>

  <div class="footer-bottom">
    <span>© {year} Froseo · Digital Agency</span>
    <a class="footer-lang" href={langSwitchHref} hreflang="nl" lang="nl">Nederlandse versie ↗</a>
    <span>Made with ♥ in Utrecht</span>
  </div>
</footer>

<style>
  .footer-lang {
    color: inherit;
    text-decoration: none;
    opacity: 0.85;
    transition: opacity var(--transition-fast);
  }
  .footer-lang:hover { opacity: 1; text-decoration: underline; }
</style>
