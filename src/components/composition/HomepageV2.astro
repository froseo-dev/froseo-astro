---
import Topbar from '../layout/Topbar.astro';
import Nav from '../layout/Nav.astro';
import Hero from '../sections/Hero.astro';
import LogosTicker from '../sections/LogosTicker.astro';
import CasesStrip from '../sections/CasesStrip.astro';
import ServicesTicker from '../sections/ServicesTicker.astro';
import ServicesGrid from '../sections/ServicesGrid.astro';
import InlineCTA from '../sections/InlineCTA.astro';
import Testimonial from '../sections/Testimonial.astro';
import Stats from '../sections/Stats.astro';
import OverFroseo from '../sections/OverFroseo.astro';
import Approach from '../sections/Approach.astro';
import PricingTeaser from '../sections/PricingTeaser.astro';
import CTA from '../sections/CTA.astro';
import FAQ from '../sections/FAQ.astro';
import BetterCallCalvin from '../sections/BetterCallCalvin.astro';
import CalvinNote from '../sections/CalvinNote.astro';
import TeamNote from '../sections/TeamNote.astro';
import HeroReason from '../sections/HeroReason.astro';
import Footer from '../layout/Footer.astro';

import testiBg from '@assets/testimonials/renovatie-totaal-bg.webp';
import basAvatar from '@assets/testimonials/bas-bertrams.webp';
import ruthLastersScreenshot from '@assets/website-opfrissen/ruth-lasters.webp';

/* CRO ordering rationale (Calvin's Optie A):
   - FAQ moves to the very bottom (objection handling, low intent, SEO body)
   - Analyse-form CTA moves UP between OverFroseo and Approach so the two
     conversion blocks (form-CTA + Better Call Calvin) aren't back-to-back. */
---

<Topbar />
<Nav />
<main>
  {/* H1-truc: hero-title is 'p' i.p.v. h1, en de eyebrow-pill boven de
      cases krijgt h1-tag met keyword-rich tekst "Webdesign, SEO &
      marketing Utrecht". Zelfde visuele layout, andere semantiek. */}
  <Hero titleAs="p" />
  <LogosTicker />
  <CasesStrip
    eyebrow="Webdesign, SEO & marketing Utrecht"
    eyebrowAs="h1"
    pickSlugs={[
      'club12',
      'renovatie-totaal',
      'studio-contenido',
      'independent-artists-agency',
      'studio-max-dance',
      'millstreet',
      'tatanka',
      'dakdekkersbedrijf-dkh-ede',
    ]}
  />
  <PricingTeaser />
  <ServicesTicker />
  <TeamNote />
  <ServicesGrid />
  <InlineCTA
    primaryLabel="Plan een vrijblijvend gesprek ↗"
    primaryHref="/contact/"
    secondaryLabel="of bekijk alle diensten ↗"
    secondaryHref="/diensten/"
  />
  <Testimonial bgImage={testiBg} bgAlt="Renovatie Totaal aan het werk" avatar={basAvatar} />
  <Stats />
  <OverFroseo />
  <HeroReason
    variant="left"
    eyebrow="Digitaal partner"
    title="Websites en marketing voor"
    titleAccent="zzp & mkb."
    body={[
      "We hebben ons in de loop der jaren steeds meer gericht op mkb en zzp. Goede marketing en een professionele website moeten ook voor 'kleinere' ondernemers realistisch zijn, niet alleen voor de grote partijen.",
      "We doen ons best om voor ieder bedrijf en ieder budget een passende oplossing te vinden. Soms is dat een one-pager, soms een website abonnement, soms maatwerk webdesign of doorlopende SEO. Samen behalen wij jouw doelen.",
    ]}
    image={ruthLastersScreenshot}
    imageAlt="webdesigners voor mkb en zzp"
    ctaLabel="Bekijk zzp websites ↗"
    ctaHref="/website-laten-maken-zzp/"
  />
  <CTA
    variant="form"
    sectionId="analyse"
    eyebrow="Gratis website-analyse"
    titleLine1="Eerst weten waar je staat?"
    titleAccent="Vraag een gratis analyse."
    text="Ontvang een gratis analyse met concrete verbeterpunten. Zonder verplichtingen."
    features={[]}
  />
  <Approach watermark={true} />
  <BetterCallCalvin />
  <FAQ />
</main>
<Footer />
