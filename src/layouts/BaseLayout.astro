---
/* Self-hosted fonts via @fontsource — bundled with the build, no Google Fonts
   CDN render-block. Only the weights we actually use are imported. */
import '@fontsource/outfit/700.css';
import '@fontsource/outfit/800.css';
import '@fontsource/outfit/900.css';
import '@fontsource/inter-tight/400.css';
import '@fontsource/inter-tight/500.css';
import '@fontsource/inter-tight/600.css';
import '@fontsource/inter-tight/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';

import '@styles/global.css';
import PaletteSwitcher from '../components/dev/PaletteSwitcher.astro';
import MobileCTA from '../components/layout/MobileCTA.astro';
import ScanPopup from '../components/ScanPopup.astro';
import WebMCP from '../components/WebMCP.astro';
import { social, review as reviewData } from '@data/site-config';
import { getAlternates, type Lang } from '@data/i18n';

interface Props {
  title?: string;
  description?: string;
  /** Theme slug — falls back to default in tokens.css if omitted. */
  theme?: string;
  /** Canonical URL path. */
  pathname?: string;
  /** Paginataal — stuurt <html lang>, og:locale en hreflang-afleiding. */
  lang?: Lang;
  /** Zet de pagina op noindex (bv. Ads-landingspagina's die niet mogen ranken). */
  noindex?: boolean;
}

const {
  title = 'Webdesign, SEO & marketing bureau | Froseo Utrecht',
  description = 'Effectieve websites & SEO uit Utrecht voor ambitieuze ondernemers. 15+ jaar ervaring, 80+ projecten live, 5/5 op Google reviews. Plan een gratis website-analyse.',
  theme,
  pathname = Astro.url.pathname,
  lang = 'nl',
  noindex = false,
} = Astro.props;

const site = Astro.site ?? 'https://froseo.nl';
const canonical = new URL(pathname, site).toString();

/* Hreflang volgt uit de centrale route-map (src/data/i18n.ts) o.b.v. het pad:
   alleen tweetalige pagina's krijgen alternate-tags, eentalige niets. */
const alt = getAlternates(pathname);
const absolutize = (path: string) => new URL(path, site).toString();

/* JSON-LD: LocalBusiness + Organization on every page. Search engines use
   this for rich snippets, the local pack and brand-knowledge graph.
   Naam: officieel "Froseo" (geen "Digital Agency"-suffix, want zo heten
   we niet in Google Business Profile, op de gevel of in correspondentie).
   Image: publiek-bereikbare logo-asset in /public/, geen Astro-gehashte
   src/assets URL want JSON-LD parseert geen build-time imports. */
const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://froseo.nl/#agency',
  name: 'Froseo',
  description: 'Webdesign, SEO en online marketing voor ambitieuze ondernemers in Utrecht en omgeving.',
  url: 'https://froseo.nl/',
  telephone: '+31302378053',
  email: 'info@froseo.nl',
  image: 'https://froseo.nl/froseo-logo.webp',
  logo: 'https://froseo.nl/froseo-logo.webp',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Leidseveer 10',
    postalCode: '3511 SB',
    addressLocality: 'Utrecht',
    addressCountry: 'NL',
  },
  areaServed: { '@type': 'Country', name: 'Nederland' },
  priceRange: '€€',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: reviewData.rating,
    reviewCount: reviewData.count,
    bestRating: '5',
  },
  /* Diensten-catalogus zodat Google snapt waarop we actief zijn en kandidaat
     wordt voor service-rich-results en de knowledge-graph "services" sectie. */
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Diensten Froseo',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Webdesign', url: 'https://froseo.nl/webdesign/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Website abonnement', url: 'https://froseo.nl/website-abonnement/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Website onderhoud', url: 'https://froseo.nl/website-onderhoud/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Website opfrissen', url: 'https://froseo.nl/website-opfrissen/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Website optimalisatie', url: 'https://froseo.nl/website-optimalisatie/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'WordPress onderhoud', url: 'https://froseo.nl/wordpress-website-onderhoud/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'SEO en GEO', url: 'https://froseo.nl/seo/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Lokale SEO', url: 'https://froseo.nl/lokale-seo/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Content abonnement', url: 'https://froseo.nl/content-abonnement/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Paid media', url: 'https://froseo.nl/paid-media/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'OpenAI Ads', url: 'https://froseo.nl/openai-ads/' } },
    ],
  },
  sameAs: [...social.sameAs, 'https://nl.trustpilot.com/review/froseo.nl'],
};
---

<!doctype html>
<html lang={lang} data-theme={theme}>
  <head>
    {/* Google Tag Manager — zo hoog mogelijk in <head> volgens Google's
        installatie-instructies. Container-ID GTM-TLW4G9R beheert alle
        analytics + advertising tags via de Tag Manager UI. */}
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-TLW4G9R');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    {/* Preconnect naar derde-partij origins zodat de TCP+TLS-handshake
        al begint terwijl de HTML nog parset. Bespaart ~100-200ms op de
        eerste request naar GTM en Clarity. Max 4 preconnects per Google's
        eigen advies; we houden 't bij de 2 echt-zware. */}
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="preconnect" href="https://scripts.clarity.ms" crossorigin />
    {/* Google Search Console verification — sitewide zodat een refresh van
        welke pagina dan ook GSC's check kan beantwoorden. */}
    <meta name="google-site-verification" content="gJdefKHd5pQ7vnvoFgiIMjoE5WFN4BYQTHUAP_uPEFw" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonical} />
    {alt && (
      <>
        <link rel="alternate" hreflang="nl" href={absolutize(alt.nl)} />
        <link rel="alternate" hreflang="en" href={absolutize(alt.en)} />
        <link rel="alternate" hreflang="x-default" href={absolutize(alt.nl)} />
      </>
    )}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'nl_NL'} />
    <meta property="og:site_name" content="Froseo" />
    <meta property="og:image" content={new URL('/og-froseo.png', Astro.site ?? 'https://froseo.nl').toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Froseo — Webdesign & SEO uit Utrecht" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-froseo.png', Astro.site ?? 'https://froseo.nl').toString()} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />

    {/* Apply persisted theme BEFORE body renders to avoid a flash.
         Falls back to "calvin" so a fresh visitor sees Calvin's working palette. */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('froseo-theme');
          document.documentElement.dataset.theme = t || 'calvin';
        } catch (e) {
          document.documentElement.dataset.theme = 'calvin';
        }
      })();
    </script>

    {/* Per-pagina head-injecties (bv. hero-image preload op de homepage).
        Vorm: <Fragment slot="head"><link rel="preload" .../></Fragment>. */}
    <slot name="head" />
  </head>
  <body>
    {/* GTM noscript-fallback direct na <body> openen — voor bezoekers
        zonder JavaScript (en voor server-side rendering analytics). */}
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-TLW4G9R"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
        title="Google Tag Manager"
      ></iframe>
    </noscript>
    <slot />
    {/* Mobiele sticky CTA sitewide, behalve op de contactpagina (NL + EN):
        daar is de bezoeker al bij het formulier. */}
    {!pathname.includes('/contact') && (
      <MobileCTA
        label={lang === 'en' ? 'Request a free proposal' : undefined}
        href={lang === 'en' ? '/en/contact/' : undefined}
      />
    )}
    <PaletteSwitcher />

    {/* Scan-aanvraag popup — sitewide. Trigger-logica (scroll/timer, session-cap,
        path-exclusions /contact + /wordpress-onderhoud) zit ín het component zelf,
        zodat we 'm hier zonder conditionals universeel kunnen mounten. De
        test-pagina /test-scan-popup/ rendert deze met forceOpen=true. */}
    <ScanPopup />

    {/* WebMCP tools-registratie. Lighthouse Agentic Browsing leest het
        declaratieve <script type="application/mcp+json"> blok; Chrome
        Canary registreert daarnaast runtime handlers via window.mcp. */}
    <WebMCP />

    {/* Attributie-capture voor CRM-leads: legt UTM-params, gclid, referrer en
        landingspagina vast en injecteert ze als verborgen velden in de
        website-formulieren (action=/api/contact). De server stuurt ze door
        naar Zoho. Campagne-bezoek (gclid/utm) overschrijft, anders first-touch. */}
    <script>
      (function () {
        var KEY = 'froseo_attribution';
        var FIELDS = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'gclid', 'referrer_url', 'landing_page'];

        function readStored() {
          try { return JSON.parse(localStorage.getItem(KEY) || '{}') || {}; }
          catch (e) { return {}; }
        }
        function store(data) {
          try { localStorage.setItem(KEY, JSON.stringify(data)); } catch (e) {}
        }

        function capture() {
          var stored = readStored();
          var p = new URLSearchParams(location.search);
          var hasCampaign = p.get('gclid') || p.get('utm_source') || p.get('utm_medium') || p.get('utm_campaign');

          // Campagne-bezoek → altijd vastleggen (last campaign touch, nodig voor
          // Google Ads gclid-matching).
          if (hasCampaign) {
            var data = {
              utm_source: p.get('utm_source') || '',
              utm_medium: p.get('utm_medium') || '',
              utm_campaign: p.get('utm_campaign') || '',
              utm_term: p.get('utm_term') || '',
              gclid: p.get('gclid') || '',
              referrer_url: document.referrer || '',
              landing_page: location.href || '',
            };
            store(data);
            return data;
          }
          // Anders: bestaande attributie behouden (first-touch).
          if (stored && (stored.landing_page || stored.gclid)) return stored;
          // Eerste bezoek zonder campagne → referrer + landingspagina vastleggen.
          var first = {
            utm_source: '', utm_medium: '', utm_campaign: '', utm_term: '', gclid: '',
            referrer_url: document.referrer || '',
            landing_page: location.href || '',
          };
          store(first);
          return first;
        }

        function inject(attr) {
          var forms = document.querySelectorAll('form[action="/api/contact"], form[action$="/api/contact"]');
          forms.forEach(function (form) {
            FIELDS.forEach(function (name) {
              if (form.querySelector('input[name="' + name + '"]')) return;
              var input = document.createElement('input');
              input.type = 'hidden';
              input.name = name;
              input.value = attr[name] || '';
              form.appendChild(input);
            });
          });
        }

        inject(capture());
      })();
    </script>

    {/* Klik-leads: site-brede listener die tel-, WhatsApp- en mailto-kliks
        als `contact_click`-event naar de dataLayer pusht. Bedoeld als
        secundaire/micro-conversie (in Google Ads op "observeren" zetten,
        niet om op te bieden). Eén listener vangt alle instanties op. */}
    <script>
      (function () {
        document.addEventListener('click', function (e) {
          var link = (e.target as HTMLElement)?.closest?.('a[href]') as HTMLAnchorElement | null;
          if (!link) return;
          var href = link.getAttribute('href') || '';
          var method = '';
          if (href.indexOf('tel:') === 0) method = 'phone';
          else if (href.indexOf('mailto:') === 0) method = 'email';
          else if (/wa\.me|whatsapp/i.test(href)) method = 'whatsapp';
          if (!method) return;
          (window as any).dataLayer = (window as any).dataLayer || [];
          (window as any).dataLayer.push({
            event: 'contact_click',
            contact_method: method,
          });
        });
      })();
    </script>
  </body>
</html>
